<!-- Die Barista – Cart Toast -->
<div class="db-cart-toast" id="db-cart-toast" role="status" aria-live="polite">
  <span class="icon">✓</span>
  <span id="db-toast-msg">Im Warenkorb!</span>
</div>

<script>
(function () {
  'use strict';

  /* ── Scroll Reveal ── */
  var revealEls = document.querySelectorAll('.db-reveal');
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('db-visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    revealEls.forEach(function (el) { observer.observe(el); });
  } else {
    revealEls.forEach(function (el) { el.classList.add('db-visible'); });
  }

  /* ── Cart Toast ── */
  var toastTimer;
  window.baristaShowToast = function (msg, isError) {
    var toast = document.getElementById('db-cart-toast');
    var msgEl = document.getElementById('db-toast-msg');
    if (!toast || !msgEl) return;
    msgEl.textContent = msg;
    toast.style.background = isError ? '#A01A13' : '#0F0F0D';
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { toast.classList.remove('show'); }, 3200);
  };

  /* ── Scroll: shrink navbar ── */
  var navbar = document.querySelector('header, .shopify-section-header, [data-section-type="header"]');
  if (navbar) {
    window.addEventListener('scroll', function () {
      navbar.classList.toggle('db-scrolled', window.scrollY > 60);
    }, { passive: true });
  }

})();
</script>
