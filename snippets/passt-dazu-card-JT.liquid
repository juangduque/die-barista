{% comment %}
  Passt Dazu — delegates markup and styles to landing-roast-product-card (same as landing roast grid).
{% endcomment %}

{%- liquid
  assign cp = cross_product
  assign ca = cp.metafields.coffee_attributes
  assign badge_label = ''
  if ca.badge_label != blank
    assign badge_label = ca.badge_label.value | default: ca.badge_label
  endif
  if badge_label == blank
    assign badge_tags = 'espresso,single origin,single-origin,ganze bohne,ganze-bohne,kaffee,filter,crema'
    assign badge_tags_arr = badge_tags | split: ','
    for tag in cp.tags
      assign tag_lower = tag | downcase | strip
      for badge_tag in badge_tags_arr
        if tag_lower == badge_tag
          assign badge_label = tag | upcase
          break
        endif
      endfor
      if badge_label != ''
        break
      endif
    endfor
  endif
  assign subtitle_roast = ''
  assign subtitle_taste = ''
  if ca.roastprofil_value != blank
    assign subtitle_roast = ca.roastprofil_value.value | default: ca.roastprofil_value
  endif
  if ca.geschmack_value != blank
    assign subtitle_taste = ca.geschmack_value.value | default: ca.geschmack_value
  endif
  if subtitle_roast != blank and subtitle_taste != blank
    assign subtitle = subtitle_roast | append: ' · ' | append: subtitle_taste
  elsif subtitle_roast != blank
    assign subtitle = subtitle_roast
  elsif subtitle_taste != blank
    assign subtitle = subtitle_taste
  else
    assign subtitle = ''
  endif
  assign passt_show_badge = false
  if badge_label != blank
    assign passt_show_badge = true
  endif
-%}

<li class="landing-roast-grid__item">
  {%- render 'landing-roast-product-card',
    card_product: cp,
    section_id: section.id,
    form_suffix: cp.id,
    subtitle: subtitle,
    show_badge: passt_show_badge,
    badge_label: badge_label,
    tone: 'beige',
    inset_mode: 'none',
    large_square_media: false,
    image_sizes: '(max-width: 640px) 100vw, (max-width: 1099px) 50vw, 25vw'
  -%}
</li>
