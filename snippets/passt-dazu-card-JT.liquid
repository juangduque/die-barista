{% comment %}
  passt-dazu-card-JT — Figma 18:422–469 (Soapstone card, badge, image 236/314.66, body, 24px ATC)
{% endcomment %}

{%- liquid
  assign cp = cross_product
  assign cp_variant = cp.selected_or_first_available_variant
  assign badge_label = cp.metafields.coffee_attributes.badge_label
  if badge_label == blank
    assign badge_label = ''
    assign badge_tags = 'espresso,single origin,single-origin,ganze bohne,ganze-bohne,kaffee,filter,crema'
    assign badge_tags_arr = badge_tags | split: ','
    for tag in cp.tags
      assign tag_lower = tag | downcase | strip
      for badge_tag in badge_tags_arr
        if tag_lower == badge_tag
          assign badge_label = tag | upcase
          break
        endif
      endfor
      if badge_label != ''
        break
      endif
    endfor
  endif
  assign subtitle_roast = cp.metafields.coffee_attributes.roastprofil_value
  assign subtitle_taste = cp.metafields.coffee_attributes.geschmack_value
  if subtitle_roast != blank and subtitle_taste != blank
    assign subtitle = subtitle_roast | append: ' · ' | append: subtitle_taste
  elsif subtitle_roast != blank
    assign subtitle = subtitle_roast
  elsif subtitle_taste != blank
    assign subtitle = subtitle_taste
  else
    assign subtitle = ''
  endif
-%}

<li class="passt-card">
  <article class="passt-card__article" aria-label="{{ cp.title | escape }}">

    <a href="{{ cp.url }}" class="passt-card__image-link" tabindex="-1" aria-hidden="true">
      <figure class="passt-card__figure">
        <div class="passt-card__media-bg" aria-hidden="true"></div>
        {%- if cp.featured_media -%}
          <img
            src="{{ cp.featured_media | image_url: width: 600 }}"
            srcset="
              {{ cp.featured_media | image_url: width: 300 }} 300w,
              {{ cp.featured_media | image_url: width: 600 }} 600w
            "
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
            alt="{{ cp.featured_media.alt | default: cp.title | escape }}"
            width="{{ cp.featured_media.width }}"
            height="{{ cp.featured_media.height }}"
            loading="lazy"
            decoding="async"
            class="passt-card__img"
          >
        {%- else -%}
          <div class="passt-card__img-placeholder" aria-hidden="true">
            <span>{{ cp.title | escape }}</span>
          </div>
        {%- endif -%}
        {%- unless badge_label == blank -%}
          <span class="passt-card__badge">{{ badge_label | escape }}</span>
        {%- endunless -%}
      </figure>
    </a>

    <div class="passt-card__body">
      <a href="{{ cp.url }}" class="passt-card__title-link">
        <h3 class="passt-card__title">{{ cp.title | escape }}</h3>
      </a>
      {%- unless subtitle == blank -%}
        <p class="passt-card__subtitle">{{ subtitle | escape }}</p>
      {%- endunless -%}

      <div class="passt-card__bottom">
        <span class="passt-card__price">{{ cp_variant.price | money }}</span>
        {%- form 'product', cp, id: 'passt-atc-' | append: cp.id, class: 'passt-card__form' -%}
          <input type="hidden" name="id" value="{{ cp_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button
            type="submit"
            class="passt-card__atc-btn"
            aria-label="{{ cp.title | escape }} in den Warenkorb"
            {% unless cp_variant.available %}disabled aria-disabled="true"{% endunless %}
          >
            {%- if cp_variant.available -%}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="#efdfd3" stroke-width="2" stroke-linejoin="round"/>
                <line x1="3" y1="6" x2="21" y2="6" stroke="#efdfd3" stroke-width="2"/>
                <path d="M16 10a4 4 0 01-8 0" stroke="#efdfd3" stroke-width="2"/>
              </svg>
            {%- else -%}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18" stroke="#efdfd3" stroke-width="2" stroke-linecap="round"/>
                <line x1="6" y1="6" x2="18" y2="18" stroke="#efdfd3" stroke-width="2" stroke-linecap="round"/>
              </svg>
            {%- endif -%}
          </button>
        {%- endform -%}
      </div>
    </div>

  </article>
</li>

<style>
.passt-card {
  --db-black:       #00090b;
  --db-crema:       #efdfd3;
  --db-opium:       #906f6a;
  --db-soapstone:   #fff8f5;
  --db-warm:        #f5e5d9;
  --db-radius:      2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
  list-style: none;
}

.passt-card__article {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--db-soapstone);
  border-radius: var(--db-radius);
  overflow: hidden;
}

.passt-card__image-link {
  display: block;
  text-decoration: none;
}

.passt-card__figure {
  position: relative;
  margin: 0;
  overflow: hidden;
  aspect-ratio: 236 / 314.66;
  border-radius: var(--db-radius) var(--db-radius) 0 0;
}

.passt-card__media-bg {
  position: absolute;
  inset: 0;
  background: var(--db-warm);
  border-radius: inherit;
}

.passt-card__img {
  position: relative;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  border-radius: inherit;
  transition: transform 0.35s ease;
}

.passt-card__image-link:hover .passt-card__img {
  transform: scale(1.03);
}

.passt-card__img-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--db-warm);
  color: var(--db-opium);
  font-family: var(--db-font-body);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 1rem;
  text-align: center;
}

.passt-card__badge {
  position: absolute;
  top: 0.625rem;
  left: 0.625rem;
  z-index: 2;
  background: var(--db-black);
  color: var(--db-crema);
  font-family: var(--db-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  line-height: 1.6;
  padding: 0.2rem 0.625rem;
  border-radius: var(--db-radius);
  pointer-events: none;
}

.passt-card__body {
  padding: 1.25rem 1.25rem 1.2rem;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.25rem;
  flex: 1;
  min-height: 7.5rem;
  box-sizing: border-box;
}

.passt-card__title-link {
  text-decoration: none;
  width: 100%;
}

.passt-card__title {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: 1.25rem;
  text-transform: uppercase;
  line-height: 1.34;
  color: var(--db-black);
  margin: 0;
  transition: opacity 0.2s;
}

.passt-card__title-link:hover .passt-card__title {
  opacity: 0.72;
}

.passt-card__subtitle {
  font-family: var(--db-font-body);
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  line-height: 1.6;
  color: var(--db-opium);
  margin: 0;
}

.passt-card__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  width: 100%;
  margin-top: auto;
  padding-top: 0.35rem;
}

.passt-card__price {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--db-black);
}

.passt-card__form {
  flex-shrink: 0;
  margin: 0;
}

.passt-card__atc-btn {
  width: 24px;
  height: 24px;
  padding: 0;
  background: var(--db-black);
  border: none;
  border-radius: var(--db-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: opacity 0.2s;
}

.passt-card__atc-btn:hover {
  opacity: 0.82;
}

.passt-card__atc-btn:disabled {
  background: var(--db-opium);
  cursor: not-allowed;
  opacity: 0.55;
}
</style>
