<div class="coffee-scale">
  {% assign roast = product.metafields.coffee_attributes.roasting_level.value | default: 4 %}
  {% assign acidity = product.metafields.coffee_attributes.acid_level.value | default: 3 %}
  {% assign strength = product.metafields.coffee_attributes.strength_level.value | default: 2 %}

  <div class="scale-row">
    <span class="label">Röstgrad</span>
    <div class="scale-container">
      <div class="scale-bar">
        <div class="scale-fill" style="width: {{ roast | times: 100 | divided_by: 6 }}%; background-color: #1f1f1f; display: block;"></div>
      </div>
    </div>
  </div>
  <div class="scale-row">
    <span class="label">Säure</span>
    <div class="scale-container">
      <div class="scale-bar">
        <div class="scale-fill" style="width: {{ acidity | times: 100 | divided_by: 6 }}%; background-color: #1f1f1f; display: block;"></div>
      </div>
    </div>
  </div>
  <div class="scale-row">
    <span class="label">Stärke</span>
    <div class="scale-container">
      <div class="scale-bar">
        <div class="scale-fill" style="width: {{ strength | times: 100 | divided_by: 6 }}%; background-color: #1f1f1f; display: block;"></div>
      </div>
    </div>
  </div>
</div>


<style>
  .coffee-scale {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    margin: 20px auto;
    background-color: #f9f9f9;
    padding: 10px;
    border-radius: 5px;
  }
  .scale-row {
    display: flex;
    align-items: center;
    margin: 10px 0;
    gap: 20px;
  }
  .label {
    flex: 0 0 100px;
    font-size: 14px;
    color: #333;
    font-weight: 500;
  }
  .scale-container {
    flex: 1;
  }
  .scale-bar {
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    position: relative;
    overflow: visible;
  }
  .scale-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    min-width: 0;
    border-radius: 3px;
    z-index: 1;
  }
</style>
