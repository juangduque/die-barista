.section-{{ section.id }}-padding {
{% if section.settings.padding_top == 'no-indent' %}
	padding-top: 0;
{% elsif section.settings.padding_top == 'xl' %}
	padding-top: 8rem;
{% elsif section.settings.padding_top == 'l' %}
	padding-top: 8rem;
{% elsif section.settings.padding_top == 'm' %}
	padding-top: 6.4rem;
{% elsif section.settings.padding_top == 's' %}
	padding-top: 4rem;
{% else %}
	padding-top: 2.4rem;
{% endif %}

{% if section.settings.padding_bottom == 'no-indent' %}
	padding-bottom: 0;
{% elsif section.settings.padding_bottom == 'xl' %}
	padding-bottom: 8rem;
{% elsif section.settings.padding_bottom == 'l' %}
	padding-bottom: 8rem;
{% elsif section.settings.padding_bottom == 'm' %}
	padding-bottom: 6.4rem;
{% elsif section.settings.padding_bottom == 's' %}
	padding-bottom: 4rem;
{% else %}
	padding-bottom: 2.4rem;
{% endif %}
}

@media screen and (min-width: 750px) { .section-{{ section.id }}-padding {
{% if section.settings.padding_top == 'no-indent' %}
	padding-top: 0;
{% elsif section.settings.padding_top == 'xl' %}
	padding-top: 10rem;
{% elsif section.settings.padding_top == 'l' %}
	padding-top: 8rem;
{% elsif section.settings.padding_top == 'm' %}
	padding-top: 8rem;
{% elsif section.settings.padding_top == 's' %}
	padding-top: 6.4rem;
{% else %}
	padding-top: 2.4rem;
{% endif %}

{% if section.settings.padding_bottom == 'no-indent' %}
	padding-bottom: 0;
{% elsif section.settings.padding_bottom == 'xl' %}
	padding-bottom: 10rem;
{% elsif section.settings.padding_bottom == 'l' %}
	padding-bottom: 8rem;
{% elsif section.settings.padding_bottom == 'm' %}
	padding-bottom: 8rem;
{% elsif section.settings.padding_bottom == 's' %}
	padding-bottom: 6.4rem;
{% else %}
	padding-bottom: 2.4rem;
{% endif %}
} }

