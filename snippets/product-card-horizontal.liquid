<div class="card-horizontal-wrapper {{ classMod }}">
	<span class="visually-hidden">{{ product_card_product.title | escape }}</span>

	<div class="card-horizontal__image" tabindex="-1">
		{%- liquid
			assign featured_media_aspect_ratio = product_card_product.featured_media.aspect_ratio

			if product_card_product.featured_media.aspect_ratio == null
				assign featured_media_aspect_ratio = 1
			endif
		-%}

		<div
			class="media media--transparent media--hover-effect"
			{%- if media_size == 'landscape' -%}
				style="padding-bottom: 70%;"
			{%- endif -%}
			{%- if media_size == 'portrait' -%}
				style="padding-bottom: 120%;"
			{%- endif -%}
			{%- if media_size == 'square' -%}
				style="padding-bottom: 100%;"
			{%- endif -%}
		>
			{% capture style %}
				{%- if media_fit == 'contain' -%}
					object-fit: contain;
				{%- endif -%}
				{%- if media_fit == 'cover' -%}
					object-fit: cover;
				{%- endif -%}
			{% endcapture %}

			{%- if product_card_product.featured_media -%}
				{% liquid
					assign aspect_ratio = product_card_product.featured_media.preview_image.aspect_ratio

					case media_size
						when 'portrait'
							assign image_ratio = 1.3
							assign image_width = 90
						when 'square'
							assign image_ratio = 1
							assign image_width = 70
						else
							assign image_ratio = 0.7
							assign image_width = 70
					endcase

					if aspect_ratio > image_ratio and product_card_product.featured_media.preview_image.width > product_card_product.featured_media.preview_image.height
						assign width = aspect_ratio | times: image_width
					elsif aspect_ratio > image_ratio and product_card_product.featured_media.preview_image.width < product_card_product.featured_media.preview_image.height
						assign width = image_width | divided_by: aspect_ratio
					else
						assign width = 70
					endif
				%}

				{{
					product_card_product.featured_media
					| image_url: width: 240
					| image_tag:
						loading: 'lazy',
						widths: ' 80, 160,240',
						class: 'motion-reduce',
						style: style
				}}
			{%- else -%}
				{%- if placeholder_index < 5 -%}
					{{
						'product-apparel-'
						| append: placeholder_index
						| placeholder_svg_tag: 'placeholder-svg'
					}}
				{%- else -%}
					{{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
				{%- endif -%}
			{%- endif -%}
		</div>
	</div>

	<div class="card-horizontal__information">
		<div class="card-horizontal__information-group">
			<h3 class="card-horizontal__title">
				<a
					class="full-unstyled-link"
					href="{{ product_card_product.url | default: '#' }}"
					title="{{ product_card_product.title | escape }}"
				>
					{% if product_card_product.title %}
						{{ product_card_product.title | escape }}
					{% else %}
						{{ 'products.product.product_heading' | t }}
					{% endif %}
				</a>
			</h3>
			{%- if show_vendor -%}
				<span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
				<div class="card-horizontal__subtitle subtitle">
					{% if product_card_product.vendor %}
						{% if settings.enable_vendor_link %}
							<a
								href="{{ product_card_product.vendor | url_for_vendor }}"
								class="vendor_link"
							>
								{{ product_card_product.vendor }}
							</a>
						{% else %}
						{{ product_card_product.vendor | escape }}
					{% endif %}

					{% else %}
						{{ 'products.product.vendor' | t }}
					{% endif %}
				</div>
			{%- endif -%}
		</div>
		<div class="card-horizontal__view-details">
			<span>
				{% render 'price', product: product_card_product, price_class: '' %}
			</span>
			<span>{{- 'general.card.view__details' | t -}}</span>
		</div>
	</div>
	<a
		href="{{ product_card_product.url | default: '#' }}"
		class="link link--overlay card-wrapper__link--overlay"
		aria-label="{{ "accessibility.product_link" | t }}"
	></a>
</div>
