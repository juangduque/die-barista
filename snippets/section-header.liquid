{%- if section.settings.heading != blank
	or section.settings.button_label != blank
-%}
	<div class="section-header__line">
		<div class="container">
			<div class="section-header__item">
				<div class="section-header__title__block">
					{%- if section.settings.heading != blank -%}
						<h2 class="section-header__title title--section {% if has_header_size %} {{ section.settings.heading_size }} {% else %} h2 {% endif %}">
							{{ section.settings.heading }}
						</h2>
					{% endif %}
					{% if blog_button == true %}
						{% render 'button',
							layout: section,
							simple: true,
							blog_link: section.settings.blog.url
						%}
					{% elsif button_icon == true %}
						{% render 'button', layout: section, simple: true, icon: true %}
					{% else %}
						{% render 'button', layout: section, simple: true %}
					{% endif %}
				</div>
			</div>
		</div>
	</div>
{%- endif -%}
