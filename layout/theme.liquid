<!doctype html>
<html
	class="no-js"
	lang="{{ request.locale.iso_code }}"
	data-scheme="{{ settings.color_scheme }}"
	dir="{% render 'direction' %}"
>{{ 'barista-theme.css' | asset_url | stylesheet_tag }}
