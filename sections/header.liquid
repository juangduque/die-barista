		{
		  "@context": "http://schema.org",
		  "@type": "WebSite",
		  "name": {{ shop.name | json }},
		  "potentialAction": {
		    "@type": "SearchAction",
		    "target": {{ potential_action_target | json }},
		    "query-input": "required name=search_term_string"
		  },
		  "url": {{ shop.url | append: page.url | json }}
		}
	</script>
{%- endif -%}

