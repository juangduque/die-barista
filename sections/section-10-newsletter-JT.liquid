{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 10: NEWSLETTER
  Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:470

  - BG #759769, outer py 64px / horizontal clamp to 410px (same as Passt dazu)
  - Inner max 1100px, px 48; left: headline 44.8px / lh 50 / tracking 1.2px, gap 25px → subtext 16px / lh 25.6 / opacity 0.7 / max 440px
  - Form: input rgba(255,255,255,0.08), 2px #00090b, radius 2px, placeholder Social Gothic 12px / 0.96px / black; button #E23528, New Frank 13.6px / 0.68px, py 16.5 px 28, min row ~50px
  - Trust: avatar 106px circle, 2px red border; quote #7B5D4D 15px / lh 20 / tracking 1px (Figma)
  - Native contact form contact[tags]=newsletter; optional Klaviyo

  IMPORTANT — Klaviyo integration:
    Native Shopify contact form stores in Shopify Contacts only.
    To sync to Klaviyo, either:
    A) Enable Klaviyo embed below (section setting toggle)
    B) Set up Shopify Flow: contact form submitted → Klaviyo subscribe
    Option A is recommended if you want it to "just work".
  ============================================================
{% endcomment %}

{%- capture nl_default_headline %}Kaffee-Wissen.
Direkt von Cemil.{%- endcapture -%}
{%- liquid
  assign use_klaviyo     = section.settings.use_klaviyo
  assign klaviyo_form_id = section.settings.klaviyo_form_id
  assign nl_form_dom_id  = 'newsletter-form-' | append: section.id
  assign bg_color        = section.settings.bg_color    | default: '#759769'
  assign text_color      = section.settings.text_color  | default: '#EFDFD3'
  assign headline        = section.settings.headline | default: nl_default_headline | strip
  assign subtext         = section.settings.subtext
  assign placeholder     = section.settings.placeholder | default: 'Deine E-Mail-Adresse'
  assign btn_label       = section.settings.btn_label   | default: 'Abonnieren'
  assign avatar_image    = section.settings.avatar_image
  assign quote_text      = section.settings.quote_text
  assign quote_author    = section.settings.quote_author | default: '— Cemil'
-%}

<section
  class="nl-section"
  id="newsletter-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Newsletter Anmeldung"
  style="--nl-bg: {{ bg_color }}; --nl-text: {{ text_color }};"
>
  <div class="nl-inner">

    <!-- ═══ LEFT: EDITORIAL TEXT ═══ -->
    <div class="nl-left">
      <h2 class="nl-headline">{{ headline | newline_to_br }}</h2>
      {%- unless subtext == blank -%}
        <p class="nl-subtext">{{- subtext -}}</p>
      {%- endunless -%}
    </div>

    <!-- ═══ RIGHT: FORM + QUOTE ═══ -->
    <div class="nl-right">

      {%- if use_klaviyo and klaviyo_form_id != blank -%}

        <!-- ── KLAVIYO EMBED ── -->
        <!-- Recommended: syncs directly to your Klaviyo list -->
        <div class="nl-klaviyo-embed" data-klaviyo-form="{{ klaviyo_form_id }}">
          <div class="klaviyo-form-{{ klaviyo_form_id }}"></div>
        </div>

      {%- else -%}

        <!-- ── NATIVE SHOPIFY CONTACT FORM ── -->
        <!-- Uses contact form (NOT customer form) — correct for newsletter capture -->
        <!-- contact[tags]: newsletter — appears in Shopify Contacts as tagged subscriber -->
        {%- form 'contact',
            id: nl_form_dom_id,
            class: 'nl-form-wrapper'
        -%}

          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}

            <!-- Success state — replaces form row -->
            <div class="nl-success" role="alert" aria-live="polite">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{{ section.settings.success_msg | default: 'Danke! Du bist dabei.' }}</span>
            </div>

          {%- else -%}

            <!-- Error message (if any) -->
            {%- if form.errors -%}
              <p class="nl-error" role="alert" aria-live="polite">
                {{ form.errors.translated_fields['email'] | capitalize }}
                {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}

            <!-- Form row: input + button -->
            <div class="nl-form-row">
              <label for="nl-email-{{ section.id }}" class="visually-hidden">
                E-Mail-Adresse
              </label>
              <input
                type="email"
                id="nl-email-{{ section.id }}"
                name="contact[email]"
                class="nl-input"
                placeholder="{{ placeholder | escape }}"
                autocomplete="email"
                required
                aria-required="true"
                aria-label="{{ placeholder | escape }}"
              >
              <button
                type="submit"
                class="nl-btn"
                aria-label="{{ btn_label | escape }}"
              >
                {{- btn_label -}}
              </button>
            </div>

          {%- endif -%}

        {%- endform -%}

      {%- endif -%}

      <!-- ── CEMIL AVATAR + QUOTE ── -->
      <!-- Shown regardless of form type or success state -->
      {%- unless quote_text == blank -%}
      <div class="nl-trust">

        {%- assign avatar_src = 'landing-newsletter-cemil-18-483.png' | asset_url -%}
        {%- if avatar_image != blank -%}
          {%- assign avatar_src = avatar_image | image_url: width: 320 -%}
        {%- endif -%}
        <img
          src="{{ avatar_src }}"
          alt="{{ quote_author | default: 'Cemil' | escape }}"
          width="106"
          height="106"
          loading="lazy"
          class="nl-trust__avatar{% if avatar_image == blank %} nl-trust__avatar--default{% endif %}"
        >

        <figure class="nl-trust__quote-block">
          <blockquote class="nl-trust__quote">
            <p>{{- quote_text | escape | newline_to_br -}}</p>
          </blockquote>
          <figcaption class="nl-trust__author">
            <cite>{{- quote_author | escape -}}</cite>
          </figcaption>
        </figure>

      </div>
      {%- endunless -%}

    </div><!-- /nl-right -->

  </div><!-- /nl-inner -->
</section>


<style>
/* ── DESIGN TOKENS ── */
#newsletter-{{ section.id }} {
  --db-red:         #e23528;
  --db-black:       #00090b;
  --db-crema:       #efdfd3;
  --db-green:       #759769;
  --db-quote:       #7b5d4d;
  --db-radius:      2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── SECTION (Figma 18:470: py 64, horizontal max 410) ── */
.nl-section {
  background: var(--nl-bg, #759769);
  padding: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 10vw, 25.625rem);
  box-sizing: border-box;
}

.nl-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
  gap: clamp(2rem, 4vw, 4.125rem);
  align-items: start;
  box-sizing: border-box;
}

/* ── LEFT: headline + sub (gap 25px) ── */
.nl-left {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.nl-headline {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: clamp(1.75rem, 4vw, 44.8px);
  text-transform: uppercase;
  letter-spacing: 1.2px;
  line-height: 1.15;
  color: var(--nl-text, #efdfd3);
  margin: 0;
  max-width: 100%;
}

@media (min-width: 901px) {
  .nl-headline {
    line-height: 50px;
  }
}

.nl-subtext {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 16px;
  line-height: 25.6px;
  color: var(--nl-text, #efdfd3);
  opacity: 0.7;
  max-width: 440px;
  margin: 0;
}

/* ── RIGHT: form + trust ── */
.nl-right {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.nl-form-wrapper {
  width: 100%;
}

.nl-form-row {
  display: flex;
  align-items: stretch;
  width: 100%;
  min-height: 50px;
}

.nl-input {
  flex: 1;
  min-width: 0;
  min-height: 50px;
  box-sizing: border-box;
  padding: 18px 18px 16px;
  background: rgba(255, 255, 255, 0.08);
  border: 2px solid var(--db-black);
  border-right: none;
  border-radius: var(--db-radius) 0 0 var(--db-radius);
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 16px;
  color: var(--db-black);
  outline: none;
  transition: border-color 0.2s, background 0.2s;
}

.nl-input::placeholder {
  color: #000000;
  font-family: var(--db-font-display);
  font-weight: 400;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.96px;
  line-height: normal;
}

.nl-input:focus {
  border-color: var(--db-black);
  background: rgba(255, 255, 255, 0.12);
}

.nl-input:focus-visible {
  outline: 2px solid var(--db-crema);
  outline-offset: 2px;
  z-index: 1;
}

.nl-btn {
  flex-shrink: 0;
  min-height: 50px;
  box-sizing: border-box;
  padding: 16.5px 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--db-red);
  color: #ffffff;
  border: none;
  border-radius: 0 var(--db-radius) var(--db-radius) 0;
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 13.6px;
  text-transform: uppercase;
  letter-spacing: 0.68px;
  line-height: normal;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}

.nl-btn:hover {
  background: #c9291e;
}

.nl-btn:focus-visible {
  outline: 2px solid var(--db-crema);
  outline-offset: 2px;
}

/* ── SUCCESS STATE ── */
.nl-success {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: rgba(239, 223, 211, 0.15);
  border: 2px solid rgba(239, 223, 211, 0.4);
  border-radius: var(--db-radius);
  color: var(--nl-text, #efdfd3);
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* ── ERROR STATE ── */
.nl-error {
  font-family: var(--db-font-body);
  font-size: 0.78rem;
  color: #ffcccc;
  margin: 0 0 0.5rem;
  padding: 0;
}

/* ── KLAVIYO EMBED OVERRIDES ── */
/* Force our typography and colors onto the Klaviyo embed form */
.nl-klaviyo-embed .klaviyo-form input[type="email"] {
  border: 2px solid var(--db-black) !important;
  border-right: none !important;
  border-radius: var(--db-radius) 0 0 var(--db-radius) !important;
  font-family: var(--db-font-body) !important;
  background: rgba(255, 255, 255, 0.08) !important;
}

.nl-klaviyo-embed .klaviyo-form button[type="submit"] {
  background: var(--db-red) !important;
  border-radius: 0 var(--db-radius) var(--db-radius) 0 !important;
  font-family: var(--db-font-body) !important;
  font-weight: 500 !important;
  font-size: 13.6px !important;
  letter-spacing: 0.68px !important;
  text-transform: uppercase !important;
}

/* ── CEMIL TRUST (Figma: 106px ring, quote #7B5D4D) ── */
.nl-trust {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.nl-trust__avatar {
  width: 106px;
  height: 106px;
  box-sizing: border-box;
  border-radius: 50%;
  background-color: rgba(131, 124, 124, 1);
  color: rgba(24, 24, 24, 1);
  object-fit: cover;
  object-position: center top;
  border: 2px solid rgba(255, 17, 0, 1);
  flex-shrink: 0;
  display: block;
}

.nl-trust__avatar--default {
  filter: saturate(0);
  object-fit: contain;
  object-position: center;
}

.nl-trust__quote-block {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  min-width: 0;
  max-width: 307px;
}

.nl-trust__quote {
  margin: 0;
  padding: 0;
  border: 0;
  font-size: inherit;
  line-height: inherit;
  color: inherit;
}

.nl-trust__quote p {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 15px;
  line-height: 20px;
  letter-spacing: 1px;
  color: var(--db-quote);
  margin: 0;
  font-style: normal;
}

.nl-trust__author {
  display: block;
  margin: 0;
}

.nl-trust__author cite {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 15px;
  line-height: 16.25px;
  color: var(--db-quote);
  font-style: normal;
}

/* ── ACCESSIBILITY ── */
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ── RESPONSIVE ── */

@media (max-width: 900px) {
  .nl-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 0 2rem;
  }

  .nl-subtext {
    max-width: 100%;
  }
}

@media (max-width: 520px) {
  .nl-section {
    padding: clamp(2rem, 5vw, 3rem) 1.25rem;
  }

  .nl-inner {
    padding: 0;
  }

  .nl-form-row {
    flex-direction: column;
    gap: 0;
  }

  .nl-input {
    border: 2px solid var(--db-black);
    border-bottom: none;
    border-radius: var(--db-radius) var(--db-radius) 0 0;
    border-right: 2px solid var(--db-black);
  }

  .nl-btn {
    width: 100%;
    min-height: 48px;
    padding: 1rem 1.25rem;
    border-radius: 0 0 var(--db-radius) var(--db-radius);
  }

  .nl-trust {
    align-items: flex-start;
  }

  .nl-trust__avatar {
    width: 88px;
    height: 88px;
  }
}
</style>


{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "barista-section-newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#759769",
      "info": "Grün (Standard), Rot (#E23528) oder Schwarz (#00090B)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#EFDFD3"
    },
    {
      "type": "header",
      "content": "Linke Spalte"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Überschrift",
      "default": "Kaffee-Wissen.\nDirekt von Cemil.",
      "info": "Zeilenumbruch für zweizeilige Social-Gothic-Überschrift (Figma 18:470)."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Beschreibungstext",
      "default": "Erhalte Röst-Tipps, Zubereitungsrezepte und exklusive Angebote — direkt in dein Postfach. Kein Spam, nur Kaffee."
    },
    {
      "type": "header",
      "content": "Formular"
    },
    {
      "type": "checkbox",
      "id": "use_klaviyo",
      "label": "Klaviyo-Formular verwenden",
      "default": false,
      "info": "Empfohlen wenn Klaviyo installiert ist — synct direkt in deine Klaviyo-Liste. Klaviyo Form ID unten eingeben."
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo Form ID",
      "info": "Zu finden in Klaviyo → Forms → dein Formular → Embed-Code. Nur benötigt wenn Klaviyo aktiviert.",
      "placeholder": "TXabcd"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Deine E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button-Text",
      "default": "Abonnieren"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Erfolgsmeldung",
      "default": "Danke! Du bist dabei."
    },
    {
      "type": "header",
      "content": "Cemil Avatar & Zitat"
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Cemil Foto",
      "info": "Quadratisch, min. ca. 300×300px. Wird als Kreis 106px (Figma 18:470) angezeigt. Ohne Bild: Standardfoto aus dem Theme."
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Zitat",
      "default": "Kein Spam, versprochen. Nur echte Leidenschaft für Genießer des schwarzen Goldes."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Autor",
      "default": "— Cemil"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "bg_color": "#759769",
        "text_color": "#EFDFD3",
        "headline": "Kaffee-Wissen.\nDirekt von Cemil.",
        "subtext": "Erhalte Röst-Tipps, Zubereitungsrezepte und exklusive Angebote — direkt in dein Postfach. Kein Spam, nur Kaffee.",
        "placeholder": "Deine E-Mail-Adresse",
        "btn_label": "Abonnieren",
        "success_msg": "Danke! Du bist dabei.",
        "quote_text": "Kein Spam, versprochen. Nur echte Leidenschaft für Genießer des schwarzen Goldes.",
        "quote_author": "— Cemil",
        "use_klaviyo": false
      }
    }
  ]
}
{% endschema %}
