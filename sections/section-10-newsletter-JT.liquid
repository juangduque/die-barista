{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 10: NEWSLETTER
  File: sections/section-10-newsletter.liquid

  Design: Full-width green (#759769) section, 45/55 split
  - Left: headline + body text in crema/white
  - Right: email form (input + button) + Cemil avatar + quote
  - Native Shopify contact form (NOT customer form — correct for newsletter)
    contact[tags] = newsletter pushes to Shopify contacts
  - Optional: Klaviyo embed override (you have Klaviyo installed)
  - Success state replaces form row
  - Avatar: 80×80 circle with 2px red border (Figma-accurate)
  - Input: 2px solid black border (consistent with "no 1px borders" rule)

  IMPORTANT — Klaviyo integration:
    Native Shopify contact form stores in Shopify Contacts only.
    To sync to Klaviyo, either:
    A) Enable Klaviyo embed below (section setting toggle)
    B) Set up Shopify Flow: contact form submitted → Klaviyo subscribe
    Option A is recommended if you want it to "just work".
  ============================================================
{% endcomment %}

{%- liquid
  assign use_klaviyo     = section.settings.use_klaviyo
  assign klaviyo_form_id = section.settings.klaviyo_form_id
  assign bg_color        = section.settings.bg_color    | default: '#759769'
  assign text_color      = section.settings.text_color  | default: '#EFDFD3'
  assign headline        = section.settings.headline    | default: 'Kaffee-Wissen. Direkt von Cemil.'
  assign subtext         = section.settings.subtext
  assign placeholder     = section.settings.placeholder | default: 'Deine E-Mail-Adresse'
  assign btn_label       = section.settings.btn_label   | default: 'Abonnieren'
  assign avatar_image    = section.settings.avatar_image
  assign quote_text      = section.settings.quote_text
  assign quote_author    = section.settings.quote_author | default: '— Cemil'
-%}

<section
  class="nl-section"
  id="newsletter-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Newsletter Anmeldung"
  style="--nl-bg: {{ bg_color }}; --nl-text: {{ text_color }};"
>
  <div class="nl-inner">

    <!-- ═══ LEFT: EDITORIAL TEXT ═══ -->
    <div class="nl-left">
      <h2 class="nl-headline">{{- headline -}}</h2>
      {%- unless subtext == blank -%}
        <p class="nl-subtext">{{- subtext -}}</p>
      {%- endunless -%}
    </div>

    <!-- ═══ RIGHT: FORM + QUOTE ═══ -->
    <div class="nl-right">

      {%- if use_klaviyo and klaviyo_form_id != blank -%}

        <!-- ── KLAVIYO EMBED ── -->
        <!-- Recommended: syncs directly to your Klaviyo list -->
        <div class="nl-klaviyo-embed" data-klaviyo-form="{{ klaviyo_form_id }}">
          <div class="klaviyo-form-{{ klaviyo_form_id }}"></div>
        </div>

      {%- else -%}

        <!-- ── NATIVE SHOPIFY CONTACT FORM ── -->
        <!-- Uses contact form (NOT customer form) — correct for newsletter capture -->
        <!-- contact[tags]: newsletter — appears in Shopify Contacts as tagged subscriber -->
        {%- form 'contact',
            id: 'newsletter-form-' | append: section.id,
            class: 'nl-form-wrapper'
        -%}

          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}

            <!-- Success state — replaces form row -->
            <div class="nl-success" role="alert" aria-live="polite">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{{ section.settings.success_msg | default: 'Danke! Du bist dabei.' }}</span>
            </div>

          {%- else -%}

            <!-- Error message (if any) -->
            {%- if form.errors -%}
              <p class="nl-error" role="alert" aria-live="polite">
                {{ form.errors.translated_fields['email'] | capitalize }}
                {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}

            <!-- Form row: input + button -->
            <div class="nl-form-row">
              <label for="nl-email-{{ section.id }}" class="visually-hidden">
                E-Mail-Adresse
              </label>
              <input
                type="email"
                id="nl-email-{{ section.id }}"
                name="contact[email]"
                class="nl-input"
                placeholder="{{ placeholder | escape }}"
                autocomplete="email"
                required
                aria-required="true"
                aria-label="{{ placeholder | escape }}"
              >
              <button
                type="submit"
                class="nl-btn"
                aria-label="{{ btn_label | escape }}"
              >
                {{- btn_label -}}
              </button>
            </div>

          {%- endif -%}

        {%- endform -%}

      {%- endif -%}

      <!-- ── CEMIL AVATAR + QUOTE ── -->
      <!-- Shown regardless of form type or success state -->
      {%- unless quote_text == blank -%}
      <div class="nl-trust">

        {%- if avatar_image != blank -%}
          <img
            src="{{ avatar_image | image_url: width: 160 }}"
            alt="{{ quote_author | default: 'Cemil' | escape }}"
            width="80"
            height="80"
            loading="lazy"
            class="nl-trust__avatar"
          >
        {%- else -%}
          <div class="nl-trust__avatar nl-trust__avatar--placeholder" aria-hidden="true"></div>
        {%- endif -%}

        <figure class="nl-trust__quote-block">
          <blockquote class="nl-trust__quote">
            <p>{{- quote_text | escape -}}</p>
          </blockquote>
          <figcaption class="nl-trust__author">
            <cite>{{- quote_author | escape -}}</cite>
          </figcaption>
        </figure>

      </div>
      {%- endunless -%}

    </div><!-- /nl-right -->

  </div><!-- /nl-inner -->
</section>


<style>
/* ── DESIGN TOKENS ── */
#newsletter-{{ section.id }} {
  --db-red:       #E23528;
  --db-black:     #00090B;
  --db-crema:     #EFDFD3;
  --db-green:     #759769;
  --db-radius:    2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── SECTION ── */
.nl-section {
  background: var(--nl-bg, #759769);
  padding: clamp(3rem, 5vw, 4.5rem) 0;
}

.nl-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  display: grid;
  /* 45/55 split — matches Figma, not 50/50 */
  grid-template-columns: 45fr 55fr;
  gap: clamp(3rem, 4vw, 5rem);
  align-items: center;
}

/* ── LEFT: EDITORIAL TEXT ── */
.nl-left {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.nl-headline {
  font-family: var(--db-font-display);
  font-weight: 900;
  font-size: clamp(1.9rem, 3.5vw, 2.8rem);
  text-transform: uppercase;
  letter-spacing: -0.02em;
  line-height: 0.95;
  color: var(--nl-text, #EFDFD3);
  margin: 0;
}

.nl-subtext {
  font-family: var(--db-font-body);
  font-size: 0.95rem;
  line-height: 1.65;
  /* Crema at 80% opacity — NOT a red tint, matches Figma */
  color: rgba(239, 223, 211, 0.8);
  max-width: 420px;
  margin: 0;
}

/* ── RIGHT: FORM + QUOTE ── */
.nl-right {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

/* ── FORM ROW ── */
.nl-form-wrapper {
  width: 100%;
}

.nl-form-row {
  display: flex;
  gap: 0;  /* input and button flush against each other */
  width: 100%;
}

/* Email input */
.nl-input {
  flex: 1;
  min-width: 0;
  padding: 0.875rem 1rem;
  background: transparent;
  /* 2px border — consistent with design system "no 1px borders" rule */
  border: 2px solid var(--db-black);
  border-right: none;  /* merged with button */
  border-radius: 0;    /* sharp corners */
  font-family: var(--db-font-body);
  font-size: 0.88rem;
  color: var(--db-black);
  outline: none;
  transition: border-color 0.2s;
}

.nl-input::placeholder {
  color: rgba(0, 9, 11, 0.45);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 0.78rem;
}

.nl-input:focus {
  border-color: var(--db-black);
  background: rgba(255,255,255, 0.08);
}

/* Subscribe button */
.nl-btn {
  flex-shrink: 0;
  padding: 0.875rem 1.5rem;
  background: var(--db-red);
  color: #ffffff;
  border: none;
  border-radius: 0;    /* sharp corners — matches input */
  font-family: var(--db-font-display);
  font-weight: 900;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
  line-height: 1;
}

.nl-btn:hover {
  background: #c9291e;
}

/* ── SUCCESS STATE ── */
.nl-success {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: rgba(239, 223, 211, 0.15);
  border: 2px solid rgba(239, 223, 211, 0.4);
  color: var(--nl-text, #EFDFD3);
  font-family: var(--db-font-display);
  font-weight: 900;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* ── ERROR STATE ── */
.nl-error {
  font-family: var(--db-font-body);
  font-size: 0.78rem;
  color: #ffcccc;
  margin: 0 0 0.5rem;
  padding: 0;
}

/* ── KLAVIYO EMBED OVERRIDES ── */
/* Force our typography and colors onto the Klaviyo embed form */
.nl-klaviyo-embed .klaviyo-form input[type="email"] {
  border: 2px solid var(--db-black) !important;
  border-right: none !important;
  border-radius: 0 !important;
  font-family: var(--db-font-body) !important;
  background: transparent !important;
}

.nl-klaviyo-embed .klaviyo-form button[type="submit"] {
  background: var(--db-red) !important;
  border-radius: 0 !important;
  font-family: var(--db-font-display) !important;
}

/* ── CEMIL TRUST BLOCK ── */
.nl-trust {
  display: flex;
  align-items: flex-start;
  gap: 1.25rem;
  padding-top: 0.5rem;
}

/* Avatar: 80×80 circle + 2px red border (Figma-accurate) */
.nl-trust__avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 2px solid var(--db-red);
  flex-shrink: 0;
  display: block;
}

.nl-trust__avatar--placeholder {
  background: rgba(239, 223, 211, 0.2);
}

/* Quote block */
.nl-trust__quote-block {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.nl-trust__quote {
  margin: 0;
}

.nl-trust__quote p {
  font-family: var(--db-font-body);
  font-size: 0.88rem;
  line-height: 1.6;
  /* Crema at 75% — warm, readable on green, matches Figma */
  color: rgba(239, 223, 211, 0.75);
  margin: 0;
  font-style: normal;
}

/* Author attribution */
.nl-trust__author {
  display: block;
}

.nl-trust__author cite {
  font-family: var(--db-font-body);
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--nl-text, #EFDFD3);
  font-style: normal;
  letter-spacing: 0.02em;
}

/* ── ACCESSIBILITY ── */
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ── RESPONSIVE ── */

@media (max-width: 900px) {
  .nl-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 0 2rem;
  }

  .nl-subtext {
    max-width: 100%;
  }
}

@media (max-width: 520px) {
  .nl-section {
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .nl-inner {
    padding: 0 1.25rem;
  }

  /* Stack button below input on very narrow screens */
  .nl-form-row {
    flex-direction: column;
    gap: 0;
  }

  .nl-input {
    border: 2px solid var(--db-black);
    border-bottom: none;
  }

  .nl-btn {
    width: 100%;
    padding: 1rem;
  }

  .nl-trust__avatar {
    width: 64px;
    height: 64px;
  }
}
</style>


{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "barista-section-newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#759769",
      "info": "Grün (Standard), Rot (#E23528) oder Schwarz (#00090B)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#EFDFD3"
    },
    {
      "type": "header",
      "content": "Linke Spalte"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Überschrift",
      "default": "Kaffee-Wissen. Direkt von Cemil."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Beschreibungstext",
      "default": "Erhalte Röst-Tipps, Zubereitungsrezepte und exklusive Angebote — direkt in dein Postfach. Kein Spam, nur Kaffee."
    },
    {
      "type": "header",
      "content": "Formular"
    },
    {
      "type": "checkbox",
      "id": "use_klaviyo",
      "label": "Klaviyo-Formular verwenden",
      "default": false,
      "info": "Empfohlen wenn Klaviyo installiert ist — synct direkt in deine Klaviyo-Liste. Klaviyo Form ID unten eingeben."
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo Form ID",
      "info": "Zu finden in Klaviyo → Forms → dein Formular → Embed-Code. Nur benötigt wenn Klaviyo aktiviert.",
      "placeholder": "TXabcd"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Deine E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button-Text",
      "default": "Abonnieren"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Erfolgsmeldung",
      "default": "Danke! Du bist dabei."
    },
    {
      "type": "header",
      "content": "Cemil Avatar & Zitat"
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Cemil Foto",
      "info": "Quadratisch, min. 160×160px. Wird als Kreis angezeigt."
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Zitat",
      "default": "Kein Spam, versprochen. Nur echte Leidenschaft für Genießer des schwarzen Goldes."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Autor",
      "default": "— Cemil"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "bg_color": "#759769",
        "text_color": "#EFDFD3",
        "headline": "Kaffee-Wissen. Direkt von Cemil.",
        "subtext": "Erhalte Röst-Tipps, Zubereitungsrezepte und exklusive Angebote — direkt in dein Postfach. Kein Spam, nur Kaffee.",
        "placeholder": "Deine E-Mail-Adresse",
        "btn_label": "Abonnieren",
        "success_msg": "Danke! Du bist dabei.",
        "quote_text": "Kein Spam, versprochen. Nur echte Leidenschaft für Genießer des schwarzen Goldes.",
        "quote_author": "— Cemil",
        "use_klaviyo": false
      }
    }
  ]
}
{% endschema %}
