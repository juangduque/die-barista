{% comment %}
  DIE BARISTA — Die Story (Produkt)
  Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:372 — Soapstone page, 1.10fr : 1fr grid, 48px gap, inset 6px cutout.
  Defaults: assets/die-story-hero.jpg + die-story-inset.jpg (Figma exports).
  Metafields: coffee_attributes.story_*
{% endcomment %}

{%- liquid
  assign mf = product.metafields.coffee_attributes

  assign main_image   = mf.story_main_image.value   | default: section.settings.main_image
  assign inset_image  = mf.story_inset_image.value  | default: section.settings.inset_image

  assign default_story_hero  = 'die-story-hero.jpg'
  assign default_story_inset = 'die-story-inset.jpg'

  assign kicker       = section.settings.kicker       | default: 'Die Story'
  assign headline     = mf.story_headline             | default: section.settings.headline
  assign paragraph_1  = mf.story_paragraph_1          | default: section.settings.paragraph_1
  assign paragraph_2  = mf.story_paragraph_2          | default: section.settings.paragraph_2

  assign ursprung     = mf.story_ursprung    | default: section.settings.ursprung
  assign roestung     = mf.story_roestung    | default: section.settings.roestung
  assign charakter    = mf.story_charakter   | default: section.settings.charakter
  assign varietaet    = mf.story_varietaet   | default: section.settings.varietaet
-%}

<section
  class="story-section"
  id="die-story-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Die Story — Herkunft und Handwerk"
>
  <div class="story-inner">

    <!-- ═══ COL 1: images (left desktop, first stacked mobile) ═══ -->
    <figure class="story-collage" aria-label="Herkunftsbilder">
      <div class="story-collage__main">
        {%- if main_image != blank -%}
          <img
            src="{{ main_image | image_url: width: 1000 }}"
            srcset="
              {{ main_image | image_url: width: 500  }} 500w,
              {{ main_image | image_url: width: 800  }} 800w,
              {{ main_image | image_url: width: 1000 }} 1000w
            "
            sizes="(max-width: 900px) 100vw, 42vw"
            alt="{{ main_image.alt | default: 'Kaffeeherkunft' | escape }}"
            width="{{ main_image.width }}"
            height="{{ main_image.height }}"
            loading="lazy"
            decoding="async"
            class="story-collage__main-img"
          >
        {%- else -%}
          <img
            src="{{ default_story_hero | asset_url }}"
            alt=""
            width="500"
            height="500"
            loading="lazy"
            decoding="async"
            class="story-collage__main-img"
          >
        {%- endif -%}
      </div>

      <div class="story-collage__inset">
        <div class="story-collage__inset-crop">
          {%- if inset_image != blank -%}
            <img
              src="{{ inset_image | image_url: width: 500 }}"
              srcset="
                {{ inset_image | image_url: width: 300 }} 300w,
                {{ inset_image | image_url: width: 500 }} 500w
              "
              sizes="(max-width: 900px) 42vw, 28vw"
              alt="{{ inset_image.alt | default: 'Kaffeebauerin' | escape }}"
              width="{{ inset_image.width }}"
              height="{{ inset_image.height }}"
              loading="lazy"
              decoding="async"
              class="story-collage__inset-img"
            >
          {%- else -%}
            <img
              src="{{ default_story_inset | asset_url }}"
              alt=""
              width="500"
              height="500"
              loading="lazy"
              decoding="async"
              class="story-collage__inset-img"
            >
          {%- endif -%}
        </div>
      </div>

      <figcaption class="visually-hidden">Herkunftsbilder: Kaffeeplantage und Ernte</figcaption>
    </figure>

    <!-- ═══ COL 2: copy ═══ -->
    <div class="story-content">
      {%- unless kicker == blank -%}
        <p class="story-kicker">{{ kicker | escape }}</p>
      {%- endunless -%}

      {%- unless headline == blank -%}
        <h2 class="story-headline">{{ headline | escape }}</h2>
      {%- endunless -%}

      <div class="story-body">
        {%- unless paragraph_1 == blank -%}
          <p>{{ paragraph_1 | escape }}</p>
        {%- endunless -%}
        {%- unless paragraph_2 == blank -%}
          <p>{{ paragraph_2 | escape }}</p>
        {%- endunless -%}
      </div>

      {%- unless ursprung == blank and roestung == blank and charakter == blank and varietaet == blank -%}
        <dl class="story-facts">
          {%- unless ursprung == blank -%}
            <div class="story-facts__row">
              <dt class="story-facts__label">Ursprung</dt>
              <dd class="story-facts__value">{{ ursprung | escape }}</dd>
            </div>
          {%- endunless -%}
          {%- unless roestung == blank -%}
            <div class="story-facts__row">
              <dt class="story-facts__label">Röstung</dt>
              <dd class="story-facts__value">{{ roestung | escape }}</dd>
            </div>
          {%- endunless -%}
          {%- unless charakter == blank -%}
            <div class="story-facts__row">
              <dt class="story-facts__label">Charakter</dt>
              <dd class="story-facts__value">{{ charakter | escape }}</dd>
            </div>
          {%- endunless -%}
          {%- unless varietaet == blank -%}
            <div class="story-facts__row">
              <dt class="story-facts__label">Varietät</dt>
              <dd class="story-facts__value">{{ varietaet | escape }}</dd>
            </div>
          {%- endunless -%}
        </dl>
      {%- endunless -%}
    </div>

  </div>
</section>

<style>
/* Figma 18:372 tokens */
.story-section {
  --db-red:         #e23528;
  --db-black:       #00090b;
  --db-soapstone:   #fff8f5;
  --db-opium:       #906f6a;
  --db-roman:       #755848;
  --db-radius:      2px;
  --db-inset-border: 6px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

.story-section {
  background: var(--db-soapstone);
  padding: 5rem clamp(1.25rem, 10vw, 25.625rem);
  box-sizing: border-box;
}

.story-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
  gap: 3rem;
  align-items: start;
}

/* ── collage ── */
.story-collage {
  position: relative;
  margin: 0;
  width: 100%;
  padding-bottom: 3.5rem;
}

.story-collage__main {
  position: relative;
  width: 100%;
  border-radius: var(--db-radius);
  overflow: hidden;
  background: #e8dfd6;
}

/* Figma frame ~500.75 / 625.94 */
.story-collage__main-img {
  width: 100%;
  height: auto;
  aspect-ratio: 500.75 / 625.94;
  object-fit: cover;
  object-position: center;
  display: block;
  border-radius: var(--db-radius);
}

.story-collage__inset {
  position: absolute;
  width: min(52%, 275px);
  aspect-ratio: 1;
  bottom: -2rem;
  right: -4%;
  border: var(--db-inset-border) solid var(--db-soapstone);
  border-radius: var(--db-radius);
  box-sizing: border-box;
  background: var(--db-soapstone);
  overflow: hidden;
  z-index: 1;
}

.story-collage__inset-crop {
  position: absolute;
  inset: 0;
  overflow: hidden;
  border-radius: 1px;
}

/* Figma: image ~118% in frame */
.story-collage__inset-img {
  position: absolute;
  width: 118%;
  height: 118%;
  left: -9%;
  top: -3%;
  object-fit: cover;
}

/* ── typography ── */
.story-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}

.story-kicker {
  font-family: var(--db-font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.096em;
  line-height: 1.028;
  color: var(--db-red);
  margin: 0 0 0.75rem;
}

.story-headline {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: clamp(1.75rem, 4.2vw, 2.8rem);
  text-transform: uppercase;
  letter-spacing: 0.067em;
  line-height: 1.34;
  color: var(--db-black);
  margin: 0 0 1rem;
  max-width: 100%;
}

.story-body {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin: 0 0 1rem;
  max-width: 480px;
  width: 100%;
}

.story-body p {
  font-family: var(--db-font-body);
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.6;
  color: var(--db-roman);
  margin: 0;
}

.story-facts {
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 520px;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.story-facts__row {
  display: grid;
  grid-template-columns: 100px minmax(0, 1fr);
  column-gap: 0.875rem;
  align-items: baseline;
}

.story-facts__label {
  font-family: var(--db-font-display);
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  line-height: 1.6;
  color: var(--db-opium);
  margin: 0;
}

.story-facts__value {
  font-family: var(--db-font-body);
  font-size: 10px;
  font-weight: 500;
  line-height: 1.59;
  color: var(--db-black);
  margin: 0;
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ── columnar: stack under 900px (images first) ── */
@media (max-width: 900px) {
  .story-section {
    padding: 3rem 1.5rem;
  }

  .story-inner {
    grid-template-columns: 1fr;
    gap: 2.25rem;
    padding: 0 1.5rem;
  }

  .story-collage {
    max-width: 34rem;
    margin-inline: auto;
    padding-bottom: 3rem;
  }

  .story-collage__inset {
    width: min(48%, 220px);
    bottom: -1.5rem;
    right: -2%;
    border-width: 5px;
  }

  .story-content {
    max-width: 34rem;
    margin-inline: auto;
  }

  .story-body,
  .story-facts {
    max-width: 100%;
  }

  .story-headline {
    letter-spacing: 0.05em;
  }
}

@media (max-width: 540px) {
  .story-section {
    padding: 2.5rem 1rem;
  }

  .story-inner {
    padding: 0 0.75rem;
    gap: 1.75rem;
  }

  .story-collage {
    padding-bottom: 2.5rem;
  }

  .story-collage__main-img {
    aspect-ratio: 1 / 1.15;
  }

  .story-collage__inset {
    width: min(46%, 200px);
    bottom: -1.25rem;
    border-width: 4px;
  }

  .story-facts__row {
    grid-template-columns: 88px minmax(0, 1fr);
    column-gap: 0.5rem;
    gap: 0.25rem 0.5rem;
  }

  .story-facts__value {
    font-size: 0.875rem;
  }
}
</style>

{% schema %}
{
  "name": "Die Story — Herkunft",
  "tag": "section",
  "class": "barista-section-story",
  "settings": [
    {
      "type": "paragraph",
      "content": "Bilder, Headline und Fakten: coffee_attributes.story_* (Metafields). Leer = Fallback unten bzw. Theme-Bilder die-story-hero.jpg / die-story-inset.jpg."
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker-Label",
      "default": "Die Story"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Überschrift (Fallback)",
      "default": "Temperamentvolle Italienische Lebensart"
    },
    {
      "type": "header",
      "content": "Bilder (Fallback)"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Hauptbild (Plantage)",
      "info": "Ohne Bild: die-story-hero.jpg. Metafield: coffee_attributes.story_main_image"
    },
    {
      "type": "image_picker",
      "id": "inset_image",
      "label": "Inset (Ernte / Person)",
      "info": "Ohne Bild: die-story-inset.jpg. Metafield: coffee_attributes.story_inset_image"
    },
    {
      "type": "header",
      "content": "Text (Fallback)"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Absatz 1",
      "default": "Seit 2018 röstet Die Barista in Hamburg. Was als Leidenschaft für den Garage begann, ist heute eine Mission: Den ehrlichsten Kaffee der Region zu produzieren."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Absatz 2 (optional)",
      "default": "Jede Röstung erzählt eine Geschichte — von der Kooperative in Brasilien bis zur Trommel in Hamburg-Wandsbek. Direkt gehandelt, persönlich ausgewählt."
    },
    {
      "type": "header",
      "content": "Mini-Tabelle (Fallback)"
    },
    {
      "type": "text",
      "id": "ursprung",
      "label": "Ursprung",
      "placeholder": "Brasilien, Indien"
    },
    {
      "type": "text",
      "id": "roestung",
      "label": "Röstung",
      "placeholder": "Dunkle Trommelröstung für maximale Süße"
    },
    {
      "type": "text",
      "id": "charakter",
      "label": "Charakter",
      "placeholder": "Vollmundig mit Noten von Kakao und Haselnuss"
    },
    {
      "type": "text",
      "id": "varietaet",
      "label": "Varietät",
      "placeholder": "60% Arabica, 40% Robusta"
    }
  ],
  "presets": [
    {
      "name": "Die Story — Herkunft",
      "settings": {
        "kicker": "Die Story",
        "headline": "Temperamentvolle Italienische Lebensart",
        "paragraph_1": "Seit 2018 röstet Die Barista in Hamburg. Was als Leidenschaft für den Garage begann, ist heute eine Mission: Den ehrlichsten Kaffee der Region zu produzieren.",
        "paragraph_2": "Jede Röstung erzählt eine Geschichte — von der Kooperative in Brasilien bis zur Trommel in Hamburg-Wandsbek. Direkt gehandelt, persönlich ausgewählt.",
        "ursprung": "Brasilien, Indien",
        "roestung": "Dunkle Trommelröstung für maximale Süße",
        "charakter": "Vollmundig mit Noten von Kakao und Haselnuss",
        "varietaet": "60% Arabica, 40% Robusta"
      }
    }
  ]
}
{% endschema %}
