{{ 'section-brands.css' | asset_url | stylesheet_tag }}

{%- style -%}
	{% render 'section-padding' %}
	{% render 'section-margin' %}
{%- endstyle -%}

<div class="brands">
	<div class="container">
		<div class="section-{{ section.id }}-padding {% if section.settings.border_top %}brands__border-top{% endif %} {% if section.settings.border_bottom %}brands__border-bottom{% endif %}">
			{%- if section.settings.subheading != blank -%}
				<div class="subtitle">
					{{ section.settings.subheading }}
				</div>
			{%- endif -%}
			<div class="brands__items">
				{%- for block in section.blocks -%}
					<a
						class="brands__item"
						{% if block.settings.brand_link.url != blank %}
							href="{{ block.settings.brand_link }}"
						{% endif %}
						{% if block.settings.brand_link.url == blank %}
							aria-disabled="true"
						{% endif %}
						{{ block.shopify_attributes }}
					>
						{%- assign width = block.settings.image_width -%}
						{%- assign height = width | divided_by: block.settings.image_1.aspect_ratio | round: 2 -%}
						{% capture class %} brands__image brands__image--dark brands__image{{ forloop.index }} {% endcapture %}
						{% capture class2 %} brands__image brands__image--light brands__image{{ forloop.index }} {% endcapture %}
						{%- style -%}
							@media screen and (max-width: 1300px) {
								.brands__image{{ forloop.index }} {
									width: {{ block.settings.image_width | times: 0.8 | round: 0 }}px;
								}
							}
							@media screen and (max-width: 750px) {
								.brands__image{{ forloop.index }} {
									width: {{ block.settings.image_width }}px;
								}
							}
						{%- endstyle -%}

						{%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}
						{%- if block.settings.image_2 != blank
							or block.settings.image_1 != blank
						-%}
							{%- if block.settings.image_2 != blank -%}
								{{
									block.settings.image_2
									| image_url: width: 710
									| image_tag:
										loading: 'lazy',
										sizes: sizes,
										widths: '275, 550, 750',
										height: height,
										width: width,
										class: class
								}}
							{%- endif -%}
							{%- if block.settings.image_1 != blank -%}
								{{
									block.settings.image_1
									| image_url: width: 710
									| image_tag:
										loading: 'lazy',
										sizes: sizes,
										widths: '275, 550, 750',
										height: height,
										width: width,
										class: class2
								}}
							{%- endif -%}
						{% else %}
							<div class="brands__placeholder">Brand</div>
						{%- endif -%}
					</a>
				{% endfor %}
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.brands.name",
	"class": "spaced-section brands-section",
	"tag": "section",
	"max_blocks": 16,
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "text",
			"id": "subheading",
			"default": "t:sections.brands.settings.subheading.default",
			"label": "t:sections.all.subheading.label"
		},
		{
			"type": "checkbox",
			"id": "border_top",
			"default": false,
			"label": "t:sections.all.border_top.label"
		},
		{
			"type": "checkbox",
			"id": "border_bottom",
			"default": true,
			"label": "t:sections.all.border_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-margin.options__6.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-margin.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"blocks": [
		{
			"type": "column",
			"name": "t:sections.brands.blocks.column.name",
			"settings": [
				{
					"type": "image_picker",
					"id": "image_1",
					"label": "t:sections.brands.blocks.column.settings.image_1.label"
				},
				{
					"type": "image_picker",
					"id": "image_2",
					"label": "t:sections.brands.blocks.column.settings.image_2.label"
				},
				{
					"type": "range",
					"id": "image_width",
					"min": 10,
					"max": 300,
					"step": 5,
					"default": 100,
					"unit": "px",
					"label": "t:sections.brands.blocks.column.settings.image_width.label"
				},
				{
					"type": "url",
					"id": "brand_link",
					"label": "t:sections.brands.blocks.column.settings.brand_link.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.brands.name",
			"blocks": [
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				}
			]
		}
	]
}
{% endschema %}
