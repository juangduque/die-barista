{{ 'section-landing-trust-bar.css' | asset_url | stylesheet_tag }}

{% style %}
  #landing-hw-trust-{{ section.id }} {
    --landing-hw-trust-surface: {{ section.settings.background_color }};
    --landing-hw-trust-icon-bg: {{ section.settings.icon_tile_color }};
    --landing-hw-trust-title: {{ section.settings.title_color }};
    --landing-hw-trust-desc: {{ section.settings.subtext_color }};
    --landing-hw-trust-accent: {{ section.settings.accent_icon_color }};
  }
{% endstyle %}

<section
  id="landing-hw-trust-{{ section.id }}"
  class="landing-hw-trust{% if section.settings.layout == 'stacked' %} landing-hw-trust--stacked{% elsif section.settings.show_vertical_rules == false %} landing-hw-trust--no-rules{% endif %}"
  aria-label="{{ section.settings.section_label | escape }}"
>
  <div class="landing-hw-trust__inner">
    {%- if section.blocks.size > 0 -%}
      <ul class="landing-hw-trust__grid" role="list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'item' -%}
              <li
                class="landing-hw-trust__item{% if block.settings.show_star_row %} landing-hw-trust__item--stars{% endif %}"
                role="listitem"
                {{ block.shopify_attributes }}
              >
                <div class="landing-hw-trust__item-inner">
                <div
                  class="landing-hw-trust__icon-box{% unless section.settings.show_icon_tile %} landing-hw-trust__icon-box--plain{% endunless %}{% if block.settings.icon_preset != blank and block.settings.icon_image == blank %} landing-hw-trust__icon-box--accent{% endif %}"
                  aria-hidden="true"
                >
                  {%- if block.settings.icon_image != blank -%}
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 96 }}"
                      alt=""
                      width="48"
                      height="48"
                      loading="lazy"
                      class="landing-hw-trust__icon-img"
                    >
                  {%- elsif block.settings.icon_preset == 'location' -%}
                    <svg class="landing-hw-trust__preset-svg" viewBox="0 0 24 24" width="22" height="22" focusable="false">
                      <path fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" d="M12 21s-6-5.33-6-10a6 6 0 1 1 12 0c0 4.67-6 10-6 10z"/>
                      <circle cx="12" cy="11" r="2.2" fill="none" stroke="currentColor" stroke-width="1.65"/>
                    </svg>
                  {%- elsif block.settings.icon_preset == 'layers' -%}
                    <svg class="landing-hw-trust__preset-svg" viewBox="0 0 24 24" width="22" height="22" focusable="false">
                      <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d="M12 3.5 20 8l-8 4.5L4 8l8-4.5z"/>
                      <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d="M4 12.5 12 17l8-4.5"/>
                      <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d="M4 16.5 12 21l8-4.5"/>
                    </svg>
                  {%- elsif block.settings.icon_preset == 'truck' -%}
                    <svg class="landing-hw-trust__preset-svg" viewBox="0 0 24 24" width="22" height="22" focusable="false">
                      <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d="M2.5 6.5h8.5v6.5H2.5z"/>
                      <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d="M11 10h2.2l3.3 3.3V13h4.5v3.5H11V10z"/>
                      <circle cx="7.5" cy="17.5" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="17.5" cy="17.5" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  {%- elsif block.settings.emoji != blank -%}
                    <span class="landing-hw-trust__emoji" role="img">{{ block.settings.emoji }}</span>
                  {%- elsif block.settings.show_star_row -%}
                    <span class="landing-hw-trust__stars" aria-hidden="true">
                      {%- for i in (1..4) -%}
                        <svg class="landing-hw-trust__star landing-hw-trust__star--filled" viewBox="0 0 20 20" width="15" height="15" focusable="false">
                          <path fill="currentColor" d="M10 1.5 12.7 6.48l5.55.81-4 3.9.95 5.52L10 14.9l-4.97 2.61.94-5.52-4-3.9 5.55-.81L10 1.5Z"/>
                        </svg>
                      {%- endfor -%}
                      <svg class="landing-hw-trust__star landing-hw-trust__star--outline" viewBox="0 0 20 20" width="15" height="15" focusable="false">
                        <path fill="none" stroke="currentColor" stroke-width="1.15" stroke-linejoin="round" d="M10 1.5 12.7 6.48l5.55.81-4 3.9.95 5.52L10 14.9l-4.97 2.61.94-5.52-4-3.9 5.55-.81L10 1.5Z"/>
                      </svg>
                    </span>
                  {%- else -%}
                    <span class="landing-hw-trust__emoji" role="img" aria-hidden="true">☕</span>
                  {%- endif -%}
                </div>
                <dl class="landing-hw-trust__text">
                  {%- if block.settings.label != blank -%}
                    <dt class="landing-hw-trust__title">{{ block.settings.label | escape }}</dt>
                  {%- endif -%}
                  {%- if block.settings.subtext != blank -%}
                    <dd class="landing-hw-trust__desc">{{ block.settings.subtext | escape }}</dd>
                  {%- endif -%}
                </dl>
                </div>
              </li>
          {%- endcase -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Trust",
  "tag": "section",
  "class": "landing-hw-trust-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label (accessibility)",
      "default": "Unsere Versprechen"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "inline", "label": "Inline (Figma strip)" },
        { "value": "stacked", "label": "Stacked (icon above)" }
      ],
      "default": "inline"
    },
    {
      "type": "checkbox",
      "id": "show_icon_tile",
      "label": "Icon tile background",
      "default": false,
      "info": "Off for the landing strip; on for a warm tile behind icons"
    },
    {
      "type": "checkbox",
      "id": "show_vertical_rules",
      "label": "Vertical dividers between items",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f2e3d5"
    },
    {
      "type": "color",
      "id": "accent_icon_color",
      "label": "Line icon color",
      "default": "#d14f3f"
    },
    {
      "type": "color",
      "id": "icon_tile_color",
      "label": "Icon tile fill",
      "default": "#fbebdf"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Description color",
      "default": "#7b5d4d"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon"
        },
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Built-in line icon",
          "options": [
            { "value": "", "label": "None" },
            { "value": "location", "label": "Location pin" },
            { "value": "layers", "label": "Layers" },
            { "value": "truck", "label": "Truck" }
          ],
          "default": "",
          "info": "Used when no icon image. Matches landing trust bar artwork."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji fallback",
          "info": "If no icon image. Leave empty to use ☕ or stars."
        },
        {
          "type": "checkbox",
          "id": "show_star_row",
          "label": "Star rating (4 filled + 1 outline)",
          "default": false,
          "info": "Stacks above title when no icon image / preset"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Title",
          "default": "Trust point"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Description",
          "info": "Optional second line (New Frank style)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing HW Trust",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "label": "4,9/5 Sterne",
            "show_star_row": true
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Frisch aus Hameln",
            "icon_preset": "location"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Kleine Batches",
            "icon_preset": "layers"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Versandfrei ab 40€",
            "icon_preset": "truck"
          }
        }
      ]
    }
  ]
}
{% endschema %}
