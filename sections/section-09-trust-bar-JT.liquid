{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 09: TRUST BAR
  File: sections/section-09-trust-bar.liquid

  Design: Compact centered strip on surface background
  - 4 USP items centered within max-width container
  - Each item: icon box (image OR emoji fallback) + title + subtext
  - Icon box: 48×48, surface-container bg, 6px radius (Figma match)
    Note: icon box IS an exception to the "no border-radius" rule
    that applies to cards/buttons — Figma clearly shows soft corners here
  - Global section — blocks only, no metafields
  - Image picker per block, emoji as fallback (not either/or)
  ============================================================
{% endcomment %}

<section
  class="trust-bar"
  id="trust-bar-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Unsere Versprechen"
>
  <div class="trust-bar__inner">

    {%- if section.blocks.size > 0 -%}
    <ul class="trust-bar__grid" role="list">

      {%- for block in section.blocks -%}
      <li
        class="trust-item"
        role="listitem"
        {{ block.shopify_attributes }}
      >

        <!-- ── ICON BOX ── -->
        <!-- Image takes priority; emoji is the lightweight fallback -->
        <div class="trust-item__icon-box" aria-hidden="true">
          {%- if block.settings.icon_image != blank -%}
            <img
              src="{{ block.settings.icon_image | image_url: width: 96 }}"
              alt=""
              width="48"
              height="48"
              loading="lazy"
              class="trust-item__icon-img"
            >
          {%- elsif block.settings.emoji != blank -%}
            <span class="trust-item__emoji" role="img">
              {{- block.settings.emoji -}}
            </span>
          {%- else -%}
            <span class="trust-item__emoji" role="img" aria-label="Trust-Icon">☕</span>
          {%- endif -%}
        </div>

        <!-- ── TEXT ── -->
        <dl class="trust-item__text">
          {%- unless block.settings.title == blank -%}
            <dt class="trust-item__title">{{- block.settings.title -}}</dt>
          {%- endunless -%}
          {%- unless block.settings.text == blank -%}
            <dd class="trust-item__desc">{{- block.settings.text -}}</dd>
          {%- endunless -%}
        </dl>

      </li>
      {%- endfor -%}

    </ul>
    {%- endif -%}

  </div>
</section>


<style>
/* ── DESIGN TOKENS ── */
#trust-bar-{{ section.id }} {
  --db-black:         #00090B;
  --db-mud:           #7B5D4D;
  --db-surface:       #fff8f5;
  --db-surface-low:   #fff1e7;
  --db-surface-mid:   #fbebdf;
  --db-surface-high:  #f5e5d9;
  --db-outline:       #906f6a;
  --db-radius:        2px;
  --db-icon-radius:   6px;  /* icon box exception — matches Figma */
  --db-font-display:  'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:     'New Frank', 'DM Sans', sans-serif;
}

/* ── SECTION ── */
.trust-bar {
  background: var(--db-surface);
  padding: clamp(2rem, 4vw, 3rem) 0;
}

.trust-bar__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  display: flex;
  justify-content: center;
}

/* ── GRID ──
   Items are centered within a constrained inner width.
   max-width: 860px keeps them from spreading too far on wide screens,
   matching the Figma layout where items occupy ~60% of page width.
*/
.trust-bar__grid {
  list-style: none;
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 860px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(1.5rem, 3vw, 2.5rem);
}

/* ── TRUST ITEM ── */
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0;
}

/* ── ICON BOX ── */
/* 48×48 warm beige square with soft corners (Figma-accurate exception to sharp-corner rule) */
.trust-item__icon-box {
  width: 48px;
  height: 48px;
  background: var(--db-surface-mid);
  border-radius: var(--db-icon-radius);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  margin-bottom: 1rem;
}

.trust-item__icon-img {
  width: 28px;
  height: 28px;
  object-fit: contain;
  display: block;
}

.trust-item__emoji {
  font-size: 22px;
  line-height: 1;
  display: block;
  /* Normalize emoji rendering cross-platform */
  font-variant-emoji: text;
}

/* ── TEXT ── */
.trust-item__text {
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
}

/* Title — Social Gothic, small, uppercase */
/* Using <dt> not <h3/h4> — trust labels are not document headings */
.trust-item__title {
  font-family: var(--db-font-display);
  font-weight: 900;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--db-black);
  line-height: 1.2;
}

/* Subtext — New Frank, small, muted */
.trust-item__desc {
  font-family: var(--db-font-body);
  font-size: 0.78rem;
  line-height: 1.5;
  color: var(--db-mud);
  max-width: 180px;
  margin: 0;
}

/* ── RESPONSIVE ── */

/* Tablet: 2×2 grid */
@media (max-width: 1023px) {
  .trust-bar__inner {
    padding: 0 2rem;
  }

  .trust-bar__grid {
    grid-template-columns: repeat(2, 1fr);
    max-width: 560px;
    gap: 2rem;
  }
}

/* Mobile: 2×2 still — avoids long single-column scroll for 4 short items */
@media (max-width: 520px) {
  .trust-bar {
    padding: clamp(1.5rem, 4vw, 2rem) 0;
  }

  .trust-bar__inner {
    padding: 0 1.25rem;
  }

  .trust-bar__grid {
    grid-template-columns: repeat(2, 1fr);
    max-width: 100%;
    gap: 1.5rem 1rem;
  }

  .trust-item__icon-box {
    width: 42px;
    height: 42px;
  }

  .trust-item__desc {
    font-size: 0.72rem;
    max-width: 140px;
  }
}
</style>


{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "barista-section-trust",
  "settings": [],
  "blocks": [
    {
      "type": "usp_item",
