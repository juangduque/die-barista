{{ 'section-landing-subscription.css' | asset_url | stylesheet_tag }}

{% style %}
  #landing-hw-sub-{{ section.id }} {
    --landing-hw-sub-bg: {{ section.settings.section_bg }};
    --landing-hw-sub-accent: {{ section.settings.accent_color }};
    --landing-hw-sub-title: {{ section.settings.title_color }};
  }
{% endstyle %}

<section
  id="landing-hw-sub-{{ section.id }}"
  class="landing-hw-sub"
>
  <div class="landing-hw-sub__grid">
    <div class="landing-hw-sub__content">
      {%- if section.settings.title != blank -%}
        <div class="landing-hw-sub__title rte">{{ section.settings.title }}</div>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="landing-hw-sub__desc rte">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="landing-hw-sub__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <li {{ block.shopify_attributes }}>
                <span class="landing-hw-sub__num">{{ block.settings.number | escape }}</span>
                <div class="landing-hw-sub__item-body">
                  {%- if block.settings.heading != blank -%}
                    <p class="landing-hw-sub__item-text">{{ block.settings.heading | escape }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          class="landing-hw-sub__btn"
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            aria-disabled="true"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="landing-hw-sub__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 40vw, 100vw',
            widths: '400, 700, 1000'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Abo",
  "tag": "section",
  "class": "landing-hw-sub-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>Nie wieder <strong>ohne Kaffee.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Mit unserem Kaffee-Abo erhältst du deine Lieblingsbohnen automatisch nach Hause geliefert. Frisch geröstet, pünktlich und absolut flexibel.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Jetzt abonnieren"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background",
      "default": "#f0eee8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent & border",
      "default": "#759769"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1b1c18"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Text",
          "default": "Vorteil"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing HW Abo",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "number": "01",
            "heading": "10% Dauerhafter Preisvorteil"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "number": "02",
            "heading": "Lieferintervall frei wählbar"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "number": "03",
            "heading": "Jederzeit kündbar oder pausierbar"
          }
        }
      ]
    }
  ]
}
{% endschema %}
