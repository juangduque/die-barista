{{ 'section-countdown.css' | asset_url | stylesheet_tag }}
<script src="{{ 'countdown.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-margin' %}
{%- endstyle -%}

{% style %}

{% if section.settings.countdown_block_font > 30 %}


	#shopify-section-{{ section.id }} .countdown-block-font {
		font-size: 30px;
	}
	@media screen and (min-width: 990px) {
		#shopify-section-{{ section.id }} .countdown-block-font {
			font-size: {{ section.settings.countdown_block_font | times: 0.6 | round: 0 }}px;
		}
	}
	@media screen and (min-width: 1400px) {
		#shopify-section-{{ section.id }} .countdown-block-font {
			font-size: {{ section.settings.countdown_block_font | times: 0.8 | round: 0 }}px;
		}
	}
	@media screen and (min-width: 1600px) {
		#shopify-section-{{ section.id }} .countdown-block-font {
			font-size: {{ section.settings.countdown_block_font }}px;
		}
	}

	{% else %}
	#shopify-section-{{ section.id }} .countdown-block-font {
			font-size: {{ section.settings.countdown_block_font }}px;
		}
	{% endif %}
{% endstyle %}
<div class="container">
	<div
		class="countdown js-countdown {% if section.settings.section_type == 'with_overlay' %} color-{{ section.settings.color_scheme }} {% endif %} section-{{ section.id }}-padding countdown-{{ section.settings.content_position }} js-countdown-{{ section.id }} countdown--{%- if section.settings.section_type == 'with_overlay' -%}overlay{%- endif -%}"
		data-date="{{ section.settings.date_picker }}"
		data-time="{{ section.settings.time_picker }}"
    data-timezone="{{ section.settings.time_zone }}"
		data-completed="{{ section.settings.completed_countdown }}"
	>
		{%- if section.settings.section_type == 'with_overlay' -%}
			<div class="countdown__bg">
				<span
					class="countdown__bg-overlay"
					style="background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }})"
				></span>
				{%- if section.settings.image != blank and section.settings.video == blank -%}
					{%- capture style -%}
						object-position: {{ section.settings.image.presentation.focal_point }};
					{%- endcapture -%}
					{{
						section.settings.image.preview_image
						| image_url: width: section.settings.image.preview_image.width
						| image_tag:
							class: 'countdown__image',
							loading: 'lazy',
							widths: '375, 640, 880, 1300, 1780, 1800, 2200, 2600, 3000, 3600',
              sizes: '100vw',
							style: style
					}}
					{%- elsif section.settings.video != blank -%}
						<div class="banner__media media banner__media--cover ">
							{{
								section.settings.video
								| video_tag:
									image_size: '1100x',
									autoplay: true,
									loop: true,
									controls: false,
									muted: true,
                  class: 'data-alt'
							}}
						</div>
					{%- else -%}
						{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
				{%- endif -%}
			</div>
		{%- endif -%}
		<div class="countdown__container">
	<div class="countdown__wrapper {% if section.settings.section_type == 'with_overlay' %} container {% endif %} {% if section.settings.section_type == 'simple' %} color-{{ section.settings.color_scheme }} {% endif %}">
				{%- if section.settings.section_type == 'simple' -%}
					<div class="simple_image">
						{%- if section.settings.image != blank and section.settings.video == blank -%}
							{%- capture style -%}
						object-position: {{ section.settings.image.presentation.focal_point }};
					{%- endcapture -%}
							{{
								section.settings.image.preview_image
								| image_url: width: 2600
								| image_tag:
									class: 'countdown__image',
									loading: 'lazy',
									widths: '375, 640, 880, 1300, 1780, 1800, 2200, 2600',
                  sizes: '100vw,(min-width: 1100px) 50vw',
									style: style
							}}
							{%- elsif section.settings.video != blank -%}
								<div class="banner__media media banner__media--cover ">
									{{
										section.settings.video
										| video_tag:
											image_size: '1100x',
											autoplay: true,
											loop: true,
											controls: false,
											muted: true,
                      class: 'data-alt'
									}}
								</div>
						{%- else -%}
								{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
						{%- endif -%}
					</div>
				{%- endif -%}
				{%- if section.settings.section_type == 'simple' -%}<div class="simple_countdown ">{%- endif -%}
				<div class="countdown__content">
					{%- if section.settings.heading != blank -%}
						<h2 class="countdown__heading h3">
							{{ section.settings.heading }}
						</h2>
					{%- endif -%}
					{%- if section.settings.section_type == 'simple' -%}
						<div class="countdown__button--container">
							{% if section.settings.button_label != blank -%}
								<a
									{% if section.settings.button_link.url != blank %}
										href="{{ section.settings.button_link }}"
									{% endif %}
									class="countdown__button button button--{{ section.settings.button_style }}"
									{% if section.settings.button_link.url == blank %}
										aria-disabled="true"
									{% endif %}
								>
									<span>
										<span>{{ section.settings.button_label }}</span>
										<span>{{ section.settings.button_label }}</span>
									</span>
								</a>
							{% endif %}
						</div>
					{%- endif -%}
				</div>
				{%- if section.settings.section_type == 'with_overlay' -%}
					<div class="countdown__button--container">
						{% if section.settings.button_label != blank -%}
							<a
								{% if section.settings.button_link.url != blank %}
									href="{{ section.settings.button_link }}"
								{% endif %}
								class="countdown__button button button--{{ section.settings.button_style }}"
								{% if section.settings.button_link.url == blank %}
									aria-disabled="true"
								{% endif %}
							>
								<span>
									<span>{{ section.settings.button_label }}</span>
									<span>{{ section.settings.button_label }}</span>
								</span>
							</a>
						{% endif %}
					</div>
				{%- endif -%}
				{%- if section.settings.date_picker != blank -%}
					<div class="countdown__main">
						<div class="countdown__block">
							<div class="countdown__block_num">
								<span
									class="countdown_block_days h1 countdown-block-font {% if section.settings.cursive_date %}italic{%- endif -%}"
								>
								</span>
								<p class="countdown_block_description">
									{{ 'general.countdown.days' | t }}
								</p>
							</div>
						</div>
						<div class="countdown__block">
							<div class="countdown__block_num">
								<span
									class="countdown_block_hours h1 countdown-block-font {% if section.settings.cursive_date %}italic{%- endif -%}"
								></span>
								<p class="countdown_block_description">
									{{ 'general.countdown.hours' | t }}
								</p>
							</div>
						</div>
						<div class="countdown__block">
							<div class="countdown__block_num">
								<span
									class="countdown_block_minutes h1 countdown-block-font {% if section.settings.cursive_date %}italic{%- endif -%}"
								></span>
								<p class="countdown_block_description">
									{{ 'general.countdown.minutes' | t }}
								</p>
							</div>
						</div>
						<div class="countdown__block">
							<div class="countdown__block_num">
								<span
									class="countdown_block_seconds h1 countdown-block-font {% if section.settings.cursive_date %}italic{%- endif -%}"
								></span>
								<p class="countdown_block_description">
									{{ 'general.countdown.seconds' | t }}
								</p>
							</div>
						</div>
					</div>
				{%- endif -%}
				{% if section.settings.countdown_heading %}
					<div class="countdown__end-info">
						<h3 class="h3 countdown__end-info-text">
							{{ section.settings.countdown_heading }}
						</h3>
					</div>
				{% endif %}
			{%- if section.settings.section_type == 'simple' -%}</div>{%- endif -%}
			</div>
		</div>
	</div>
</div>

{% schema %}
{
  "name": "t:sections.countdown.name",
  "tag": "section",
  "class": "countdown-section",
  "enabled_on": {
    "templates": [
      "*"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_type",
      "options": [
        {
          "value": "simple",
          "label": "t:sections.countdown.settings.section_type.options__1.label"
        },
        {
          "value": "with_overlay",
          "label": "t:sections.countdown.settings.section_type.options__2.label"
        }
      ],
      "default": "simple",
      "label": "t:sections.countdown.settings.section_type.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-2",
      "label": "t:sections.footer.settings.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.countdown.settings.header__1.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.countdown.settings.image.label"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video-banner.settings.video.label"
    },
    {
      "type": "range",
      "id": "opacity_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.countdown.settings.opacity_overlay.label",
      "default": 0.6,
      "info": "t:sections.all.content_position.info"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        {
          "value": "top",
          "label": "t:sections.all.content_position.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.content_position.options__2.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.content_position.options__3.label"
        }
      ],
      "default": "bottom",
      "label": "t:sections.all.content_position.label",
      "info": "t:sections.all.content_position.info"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "t:sections.countdown.settings.heading.default",
      "label": "t:sections.countdown.settings.heading.label"
    },
    {
			"type": "number",
			"id": "time_zone",
			"default": 0,
			"label": "t:sections.countdown.settings.timezone.label"
		},
    {
      "type": "text",
      "id": "date_picker",
      "default": "2025-11-01",
      "info": "YYYY-MM-DD",
      "label": "t:sections.countdown.settings.date_picker.label"
    },
    {
      "type": "text",
      "id": "time_picker",
      "default": "00:00",
      "info": "hh:mm",
      "label": "t:sections.countdown.settings.time_picker.label"
    },
    {
      "type": "checkbox",
      "id": "cursive_date",
      "label": "t:sections.countdown.settings.cursive_date.label",
      "default": false
    },
    {
      "type": "range",
      "id": "countdown_block_font",
      "min": 20,
      "max": 70,
      "step": 5,
      "unit": "px",
      "label": "t:sections.countdown.settings.countdown_block_font.label",
      "default": 50
    },
    {
      "type": "select",
      "id": "completed_countdown",
      "options": [
        {
          "value": "hide_section",
          "label": "t:sections.countdown.settings.completed_countdown.options_1.label"
        },
        {
          "value": "show_text",
          "label": "t:sections.countdown.settings.completed_countdown.options_2.label"
        }
      ],
      "default": "show_text",
      "label": "t:sections.countdown.settings.completed_countdown.label"
    },
    {
      "type": "richtext",
      "id": "countdown_heading",
      "default": "t:sections.countdown.settings.countdown_heading.default",
      "label": "t:sections.countdown.settings.countdown_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.countdown.settings.header__2.content"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.countdown.settings.button_label.default",
      "label": "t:sections.countdown.settings.button_label.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.countdown.settings.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.countdown.settings.button_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.countdown.settings.button_style.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.countdown.settings.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "s",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "s",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.countdown.presets.name"
    }
  ]
}
{% endschema %}
