{% comment %}
  Section: barista-abo.liquid
  Pfad: sections/barista-abo.liquid
{% endcomment %}

<style>
.barista-abo { background: #F5F0E8; padding: 80px 0; }
.barista-abo__container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
.barista-abo__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* Content */
.barista-abo__headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(42px, 5vw, 60px);
  line-height: 0.95;
  margin-bottom: 8px;
  color: #1A1915;
}
.barista-abo__headline .accent { color: #4A5E3A; }
.barista-abo__text {
  color: #888580;
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  font-size: 14px;
  font-weight: 300;
  line-height: 1.7;
  margin: 20px 0 28px;
}
.barista-abo__benefits { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }
.barista-abo__benefit {
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  font-size: 13px;
  font-weight: 600;
  color: #1A1915;
}
.barista-abo__num {
  background: #4A5E3A;
  color: white;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
}
.barista-abo__btn {
  background: #4A5E3A;
  color: white;
  border: none;
  padding: 15px 32px;
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none;
  display: inline-block;
}
.barista-abo__btn:hover { background: #6B7F57; color: white; }

/* Visual side */
.barista-abo__visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 380px;
}
.barista-abo__badge {
  position: absolute;
  top: 20px;
  right: 10px;
  width: 88px;
  height: 88px;
  background: #0F0F0D;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: white;
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  text-align: center;
  line-height: 1.5;
  animation: db-spin 22s linear infinite;
}
.barista-abo__badge .inner-text {
  animation: db-spin 22s linear infinite reverse;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}
.barista-abo__badge .accent {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: #C8231A;
  letter-spacing: 0;
  display: block;
}
@keyframes db-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* Cup illustration */
.barista-abo__cup-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.barista-abo__cup-img { max-height: 260px; max-width: 260px; object-fit: contain; }

/* If no image, fallback CSS cup */
.db-css-cup { position: relative; width: 180px; display: flex; flex-direction: column; align-items: center; }
.db-css-cup__body {
  width: 150px;
  height: 130px;
  background: #EDE8DC;
  border-radius: 0 0 20px 20px;
  border: 2px solid #C8C4BC;
  position: relative;
  overflow: hidden;
}
.db-css-cup__coffee {
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  width: 120px;
  height: 28px;
  background: radial-gradient(ellipse, #5C3A1A 0%, #2A1508 100%);
  border-radius: 50%;
}
.db-css-cup__label {
  position: absolute;
  bottom: 28px;
  width: 100%;
  text-align: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px;
  letter-spacing: 2px;
  color: #888580;
}
.db-css-cup__saucer {
  width: 190px;
  height: 16px;
  background: #EDE8DC;
  border-radius: 50%;
  border: 1px solid #C8C4BC;
  margin-top: -2px;
}

/* Side bag */
.barista-abo__side-bag {
  position: absolute;
  left: 8%;
  top: 18%;
  transform: rotate(-8deg);
  width: 68px;
  height: 100px;
  background: #0F0F0D;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-align: center;
  line-height: 1.3;
}
.barista-abo__side-bag .dot { color: #C8231A; font-size: 16px; display: block; }

@media (max-width: 1024px) {
  .barista-abo__inner { grid-template-columns: 1fr; gap: 40px; }
  .barista-abo__visual { height: 280px; }
}
@media (max-width: 640px) {
  .barista-abo__container { padding: 0 20px; }
  .barista-abo { padding: 60px 0; }
}
</style>

<section class="barista-abo">
  <div class="barista-abo__container">
    <div class="barista-abo__inner">

      <!-- Content -->
      <div class="db-reveal">
        {%- if section.settings.label != blank -%}
          <div class="db-section-label">{{ section.settings.label }}</div>
        {%- endif -%}

        <h2 class="barista-abo__headline">
          {{ section.settings.headline_line1 }}<br>
          <span class="accent">{{ section.settings.headline_accent }}</span>
        </h2>

        {%- if section.settings.text != blank -%}
          <p class="barista-abo__text">{{ section.settings.text }}</p>
        {%- endif -%}

        <div class="barista-abo__benefits">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <div class="barista-abo__benefit" {{ block.shopify_attributes }}>
                <div class="barista-abo__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <a href="{{ section.settings.btn_url | default: '#' }}" class="barista-abo__btn">
          {{ section.settings.btn_label | default: 'Jetzt abonnieren' }} →
        </a>
      </div>

      <!-- Visual -->
      <div class="barista-abo__visual db-reveal db-reveal-d2">

        <div class="barista-abo__badge" aria-hidden="true">
          <div class="inner-text">
            <span class="accent">✦</span>
            FRISCH<br>GERÖSTET<br>FÜR DICH
          </div>
        </div>

        {%- if section.settings.product_image != blank -%}
          <div class="barista-abo__cup-wrap">
            {{
              section.settings.product_image
              | image_url: width: 520
              | image_tag:
                loading: 'lazy',
                alt: section.settings.product_image.alt | default: 'Kaffee Abo',
                class: 'barista-abo__cup-img'
            }}
          </div>
        {%- else -%}
          <div class="db-css-cup">
            <div class="db-css-cup__body">
              <div class="db-css-cup__coffee"></div>
              <div class="db-css-cup__label">DIE BARISTA</div>
            </div>
            <div class="db-css-cup__saucer"></div>
          </div>
        {%- endif -%}

        <div class="barista-abo__side-bag" aria-hidden="true">
          DIE<br>BARISTA<br><span class="dot">●</span>
        </div>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Barista Abo",
  "tag": "div",
  "blocks": [
    {
      "type": "benefit",
      "name": "Vorteil",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Vorteilstext",
          "default": "100% Dauerhafter Preisvorteil"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "Kaffee-Abo"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "Headline Zeile 1",
      "default": "NIE WIEDER"
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline Akzent (grün)",
      "default": "OHNE KAFFEE."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Beschreibungstext",
      "default": "Mit unserem Kaffee-Abo erhältst du deine Lieblingsröstungen automatisch nach Hause geliefert, frisch geröstet, pünktlich und absolut flexibel."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Text",
      "default": "Jetzt abonnieren"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Produkt / Tassen Bild (optional)"
    }
  ],
  "presets": [
    {
      "name": "Barista Abo",
      "blocks": [
        { "type": "benefit", "settings": { "text": "100% Dauerhafter Preisvorteil" } },
        { "type": "benefit", "settings": { "text": "Liefertermin frei wählbar" } },
        { "type": "benefit", "settings": { "text": "Jederzeit kündbar oder pausierbar" } }
      ]
    }
  ]
}
{% endschema %}
