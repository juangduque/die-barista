            "subtitle": "Mittlere Röstung - Nüssig",
            "price": "14,90 €",
            "preset_image": "crema",
            "tone": "beige"
          }
        },
        {
          "type": "roast_static",
          "settings": {
            "title": "Manifesto",
            "subtitle": "Helle Röstung - Fruchtig",
            "price": "14,90 €",
            "preset_image": "manifesto",
