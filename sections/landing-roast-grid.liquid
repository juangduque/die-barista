        {
          "type": "roast_static",
          "settings": {
            "title": "DER ITALIENER",
            "subtitle": "Dunkle Röstung · Schoko-Note",
            "price": "14,90 €",
            "preset_image": "italiener",
            "tone": "red"
          }
        },
        {
          "type": "roast_static",
          "settings": {
            "title": "Kiez Crema",
