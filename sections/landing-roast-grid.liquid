{{ 'section-landing-roast-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- if settings.add_to_cart_enabled -%}
  <link
    rel="stylesheet"
    href="{{ 'component-deferred-media.css' | asset_url }}"
    media="all"
  >
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% style %}
  #landing-hw-roast-{{ section.id }} {
    --landing-hw-roast-page-bg: {{ section.settings.page_bg }};
    --landing-hw-roast-title: {{ section.settings.heading_color }};
  }
{% endstyle %}

<section
  id="landing-hw-roast-{{ section.id }}"
  class="landing-hw-roast"
>
  <div class="landing-hw-roast__head">
    <div>
      {%- if section.settings.subtitle != blank -%}
        <p class="landing-hw-roast__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="landing-hw-roast__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_label != blank -%}
      <a
        class="landing-hw-roast__all"
        {% if section.settings.view_all_link != blank %}
          href="{{ section.settings.view_all_link }}"
        {% else %}
          aria-disabled="true"
        {% endif %}
      >
        {{ section.settings.view_all_label | escape }}
      </a>
    {%- endif -%}
  </div>

  <div class="landing-hw-roast__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_cell' -%}
        {%- assign product = block.settings.product -%}
        {%- if product != blank -%}
          {%- assign card_bg = block.settings.card_bg | default: '#e23528' -%}
          <article
            class="landing-hw-roast__card"
            style="--card-bg: {{ card_bg }};"
            {{ block.shopify_attributes }}
          >
            <div class="landing-hw-roast__media">
              <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                {%- if product.featured_media -%}
                  {{
                    product.featured_media
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '200, 400, 600',
                      sizes: '(min-width: 990px) 200px, 45vw'
                  }}
                {%- endif -%}
              </a>
            </div>
            <div class="landing-hw-roast__foot">
              <h3 class="landing-hw-roast__name">
                <a href="{{ product.url }}">{{ product.title | escape }}</a>
              </h3>
              {%- assign excerpt = block.settings.description -%}
              {%- if excerpt == blank -%}
                {%- assign excerpt = product.description | strip_html | truncate: 120 -%}
              {%- endif -%}
              {%- if excerpt != blank -%}
                <p class="landing-hw-roast__excerpt">{{ excerpt | escape }}</p>
              {%- endif -%}
              <div class="landing-hw-roast__row">
                <div class="landing-hw-roast__price">
                  {% render 'price', product: product, use_variant: true, price_class: '' %}
                </div>
                <div class="landing-hw-roast__atc">
                  {%- liquid
                    assign can_quick_add = false
                    if settings.add_to_cart_enabled and product.available
                      if product.has_only_default_variant
                        assign can_quick_add = true
                      endif
                    endif
                  -%}
                  {%- if can_quick_add -%}
                    {%- assign product_form_id = 'landing-roast-' | append: section.id | append: '-' | append: product.id -%}
                    <product-form>
                      {%- form 'product',
                        product,
                        id: product_form_id,
                        class: 'form',
                        novalidate: 'novalidate',
                        data-type: 'add-to-cart-form'
                      -%}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <button
                          type="submit"
                          name="add"
                          class="button button--primary"
                          aria-label="{{ 'products.product.add_to_cart' | t }}"
                          {% unless product.selected_or_first_available_variant.available %}
                            disabled
                          {% endunless %}
                        >
                          <span class="visually-hidden">{{ 'products.product.add_to_cart' | t }}</span>
                          {% render 'icon-cart' %}
                        </button>
                      {%- endform -%}
                    </product-form>
                  {%- elsif product.available -%}
                    <a
                      href="{{ product.url }}"
                      class="button button--primary"
                      aria-label="{{ product.title | escape }}"
                    >
                      {% render 'icon-cart' %}
                    </a>
                  {%- else -%}
                    <button type="button" class="button button--primary" disabled aria-disabled="true">
                      {% render 'icon-cart' %}
                    </button>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </article>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Roasts",
  "tag": "section",
  "class": "landing-hw-roast-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Die Röstungen"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "page_bg",
      "label": "Section background",
      "default": "#fdfaf7"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Alle ansehen"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "product_cell",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card top color",
          "default": "#e23528"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing HW Roasts"
    }
  ]
}
{% endschema %}
