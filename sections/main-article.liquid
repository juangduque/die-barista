{{ 'section-blog-post.css' | asset_url | stylesheet_tag }}
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-padding' %}

	.article-template__header--overlay .article-template__wrapper::before {
	  background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }} );
	}
{%- endstyle -%}

<article
	class="article-template section-{{ section.id }}-padding {% if section.settings.show_border %} article-template_border {% endif %}"
	itemscope
	itemtype="http://schema.org/BlogPosting"
>
	{%- for block in section.blocks -%}
		{%- case block.type -%}
			{%- when '@app' -%}
				<div
					class="container page-width--narrow"
					{{ block.shopify_attributes }}
				>
					{% render block %}
				</div>
			{%- when 'article-header' -%}
				{% liquid
					assign image = article.image

					if block.settings.image != blank
						assign image = block.settings.image
					endif
				%}
				<header
					class="
						article-template__header {% if section.settings.header_variant == 'column' %} article-template__header--column {%- endif -%} {% if section.settings.header_variant == 'row' %} article-template__header--row {%- endif -%} {% if section.settings.header_variant == 'overlay' %} article-template__header--overlay {%- endif -%}
						{% if section.settings.header_variant == 'overlay' %} article-template__header--{{ block.settings.image_height }} {% endif %}
					"
					{{ block.shopify_attributes }}
				>
					<div class="container">
						<div class="article-template__wrapper {% if image == blank %} article-template__wrapper_no-image {% endif %}">
							<div class="article-template__info {% if section.settings.header_variant == 'overlay' %} container {% endif %}">
								<div class="article-template__text">
									{%- if article.tags != blank
										and block.settings.blog_show_tags == true
									-%}
										<ul class="article-template__tags">
											{% for tag in article.tags %}
												<li class="article-template__tag subtitle">
													<a href="{{ blog.url }}/tagged/{{ tag | handle }}">
														<span title="{{ tag }}">{{ tag }}</span>
													</a>
												</li>
											{% endfor %}
										</ul>
									{%- endif -%}
								</div>
								<div class="article-template__info_bottom">
									<h1
										class="article-template__title title--page h2"
										itemprop="headline"
									>
										{{ article.title | escape }}
									</h1>
									{%- if article.excerpt.size > 0
										and block.settings.blog_show_excerpt
									-%}
										<div class="article-template__excerpt">
											{{ article.excerpt }}
										</div>
									{%- endif -%}
									<div class="article-template__meta">
										{%- if block.settings.blog_show_author -%}
											<span
												class="caption-with-letter-spacing"
												itemprop="author"
												itemscope
												itemtype="http://schema.org/Person"
											>
												<span>{{- 'general.blog.author' | t }}&nbsp; </span>
												{%- if block.settings.blog_image_author != blank -%}
													<div class="article-template__meta-image">
														<img
															srcset="{{ block.settings.blog_image_author | image_url: width: 30 }} 1x, {{ block.settings.blog_image_author | image_url: width: 60 }} 2x"
															src="{{ block.settings.blog_image_author | image_url: width: 30 }}"
															alt="{{ block.settings.blog_image_author.alt | escape }}"
															width="30"
															height="30"
															loading="lazy"
															class="article-template__meta-image_author"
														>
													</div>
												{%- endif -%}
												<span
													itemprop="name"
													class="article-template__meta-author"
												>
													<span>{{ article.author }}</span>
												</span>
											</span>
										{%- endif -%}

										{%- if block.settings.blog_show_date -%}
											<span
												class="caption-with-letter-spacing article-template__meta-date"
												itemprop="dateCreated pubdate datePublished"
											>
												{{ article.created_at | date: format: 'abbreviated_date' }}
											</span>
										{%- endif -%}
									</div>
								</div>
							</div>
							<div
								class="article-template__hero"
								{{ block.shopify_attributes }}
							> 
								{%- if image != blank -%}
									<div
										class="{% if section.settings.header_variant != 'overlay' %} article-template__hero-wrapper--{{ block.settings.image_height }} {% endif %} article-template__hero-wrapper"
										itemprop="image"
									>
										<div
											{% if block.settings.image_height == 'adapt' and image %}
												style="padding-bottom: {{ 1 | divided_by: image.aspect_ratio | times: 100 }}%;"
											{% endif %}
										>
											{{
												image
												| image_url: width: 1900
												| image_tag:
													loading: 'lazy',
													widths: '360, 535, 720, 940, 1070, 1100, 1200, 1300, 1400, 1500, 1600, 1700, 1800, 1900'
											}}
										</div>
									</div>
								{%- endif -%}
							</div>
						</div>
						{% if settings.show_breadcrumbs %}
							<div class="article-template__breadcrumb container">
								<nav
									class="breadcrumb"
									role="navigation"
									aria-label="breadcrumbs"
								>
									<a
										href="{{ routes.root_url }}"
										title="{{ 'general.breadcrumbs.home' | t }}"
									>
										{{ 'general.breadcrumbs.home' | t }}
									</a>
									<div class="breadcrumb__delimiter">
										{% render 'icon-button-arrow' %}
									</div>
									<a
										href="{{ blog.url }}"
										title="{{ blog.title }}"
									>
										{{ blog.title }}
									</a>
									<div class="breadcrumb__delimiter">
										{% render 'icon-button-arrow' %}
									</div>
									<span> {{ article.title }}</span>
								</nav>
							</div>
						{% endif %}
					</div>

					{%- if block.settings.image_height == 'adapt' and image -%}
						{%- style -%}
							.article-template__header--overlay::before {
							  padding-bottom: {{ 1 | divided_by: image.aspect_ratio | times: 100 }}%;
							  content: '';
							  display: block;
							}
						{%- endstyle -%}
					{%- endif -%}
				</header>
			{%- when 'content' -%}
				<div class="article-template__content-block container">
					<div class="article-template__left {% if block.settings.show_share == false %} article-template__hide {% endif %}">
						<div class="article-template__footer ">
							<div class="article-template__footer-content">
								{%- if block.settings.show_share_facebook
									or block.settings.show_share_twitter
									or block.settings.show_share_pinterest
									or block.settings.show_share_copy
								-%}
									{%- if block.settings.share_heading -%}
										<p class="share_heading">
											{{ block.settings.share_heading }}
										</p>
									{%- endif -%}
									<ul class="share-buttons-simple">
										{%- if block.settings.show_share_facebook -%}
											<li class="share-buttons-simple__item">
												<a
													href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}"
													class="share-buttons-simple__button facebook-btn"
													target="_blank"
												>
													{% render 'icon-facebook' %}
													<span>
														{{- 'general.social.links.facebook' | t -}}
													</span>
												</a>
											</li>
										{%- endif -%}

										{%- if block.settings.show_share_twitter -%}
											<li class="share-buttons-simple__item">
												<a
													href="https://twitter.com/share?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
													class="share-buttons-simple__button twitter-btn"
													target="_blank"
												>
													{% render 'icon-twitter' %}
													<span>
														{{- 'general.social.links.twitter' | t -}}
													</span>
												</a>
											</li>
										{%- endif -%}

										{%- if block.settings.show_share_pinterest -%}
											<li class="share-buttons-simple__item">
												<a
													href="https://pinterest.com/pin/create/bookmarklet/?media={{ image | image_url: width: 1100, height: 1100 }}&url={{ shop.url | append: article.url }}&description={{ article.title | escape }}"
													class="share-buttons-simple__button pinterest-btn"
													target="_blank"
												>
													{% render 'icon-pinterest' %}
													<span>
														{{- 'general.social.links.pinterest' | t -}}
													</span>
												</a>
											</li>
										{%- endif -%}

										{%- if block.settings.show_share_copy -%}
											<li class="share-buttons-simple__item">
												<a
													href="{{ shop.url | append: product.url }}"
													class="share-buttons-simple__button copy-btn"
												>
													{% render 'icon-copy' %}
													<span>
														{{- 'general.share.copy_to_clipboard' | t -}}
													</span>
												</a>
											</li>
										{%- endif -%}
									</ul>
								{%- endif -%}
							</div>
						</div>
					</div>

					<div
						class="article-template__content container rte{% if section.settings.rte_image_style == "default" %} rte_images-default{% endif %}"
						itemprop="articleBody"
						{{ block.shopify_attributes }}
					>
						{{ article.content }}
					</div>

					<div class="article-template__promo color-{{ block.settings.color_scheme }} {% if block.settings.show_promo == false %} article-template__hide {% endif %}">
						{%- if block.settings.promo_heading
							or block.settings.promo_image
							or block.settings.button_label
						-%}
							{%- if block.settings.promo_image != blank -%}
								{{
									block.settings.promo_image
									| image_url: width: 1200
									| image_tag:
										loading: 'lazy',
										widths: '300, 610, 1200',
										class: 'promo__image'
								}}
							{%- endif -%}

							<div class="promo_info">
								{%- if block.settings.promo_heading != blank -%}
									<h3>
										{{ block.settings.promo_heading | escape }}
									</h3>
								{%- endif -%}
								{% if block.settings.button_label != blank -%}
									<a
										{% if block.settings.button_link.url != blank %}
											href="{{ block.settings.button_link }}"
										{% endif %}
										class="button button--{{ block.settings.button_style }}"
										{% if block.settings.button_link.url == blank %}
											aria-disabled="true"
										{% endif %}
									>
										<span>
											<span>{{ block.settings.button_label }}</span>
											<span>{{ block.settings.button_label }}</span>
										</span>
									</a>
								{% endif %}
							</div>

							{% if block.settings.button_link != blank %}
								<a
									class="promo__link"
									href="{{ block.settings.button_link }}"
									aria-label="{{ "accessibility.link" | t }}"
								></a>
							{%- endif -%}
						{%- endif -%}
					</div>
				</div>
			{%- when 'article-footer' -%}
				<div class="article-template__footer container">
					<div class="article-template__footer-content">
						<div class="article-template__meta article-template__meta-date">
							{%- if block.settings.blog_show_date -%}
								<span
									class="caption-with-letter-spacing"
									itemprop="dateCreated pubdate datePublished"
								>
									{{ 'general.blog.publish_2' | t | append: ' ' }}
									<span
										>&nbsp;{{ article.published_at | time_tag: format: 'abbreviated_date' -}}
									</span></span
								>
							{%- endif -%}
							{%- if block.settings.blog_show_author -%}
								<span
									class="caption-with-letter-spacing"
									itemprop="author"
									itemscope
									itemtype="http://schema.org/Person"
								>
									{{- 'general.blog.author_2' | t }}&nbsp;
									{%- if block.settings.blog_image_author != blank -%}
										<div class="article-template__meta-image">
											<img
												srcset="{{ block.settings.blog_image_author | image_url: width: 30 }} 1x, {{ block.settings.blog_image_author | image_url: width: 60 }} 2x"
												src="{{ block.settings.blog_image_author | image_url: width: 30 }}"
												alt="{{ block.settings.blog_image_author.alt | escape }}"
												width="30"
												height="30"
												loading="lazy"
												class="article-template__meta-image_author"
											>
										</div>
									{%- endif -%}
									<span itemprop="name" class="article-template__meta-author">
										<span>{{ article.author }}</span></span
									>
								</span>
							{%- endif -%}
						</div>

						{%- if block.settings.show_share_facebook
							or block.settings.show_share_twitter
							or block.settings.show_share_pinterest
							or block.settings.show_share_copy
						-%}
							<ul class="share-buttons-simple share-buttons-simple-footer">
								<li class="share-buttons-text">
									<span>
										{{- 'general.share.share' | t -}}
									</span>
								</li>
								{%- if block.settings.show_share_facebook -%}
									<li class="share-buttons-simple__item">
										<a
											href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}"
											class="share-buttons-simple__button facebook-btn"
											target="_blank"
										>
											{% render 'icon-facebook' %}
										</a>
									</li>
								{%- endif -%}

								{%- if block.settings.show_share_twitter -%}
									<li class="share-buttons-simple__item">
										<a
											href="https://twitter.com/share?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
											class="share-buttons-simple__button twitter-btn"
											target="_blank"
										>
											{% render 'icon-twitter' %}
										</a>
									</li>
								{%- endif -%}

								{%- if block.settings.show_share_pinterest -%}
									<li class="share-buttons-simple__item">
										<a
											href="https://pinterest.com/pin/create/bookmarklet/?media={{ image | image_url: width: 1100, height: 1100 }}&url={{ shop.url | append: article.url }}&description={{ article.title | escape }}"
											class="share-buttons-simple__button pinterest-btn"
											target="_blank"
										>
											{% render 'icon-pinterest' %}
										</a>
									</li>
								{%- endif -%}

								{%- if block.settings.show_share_copy -%}
									<li class="share-buttons-simple__item">
										<a
											href="{{ shop.url | append: product.url }}"
											class="share-buttons-simple__button copy-btn"
										>
											{% render 'icon-copy' %}
										</a>
									</li>
								{%- endif -%}
							</ul>
						{%- endif -%}
					</div>
				</div>
		{%- endcase -%}
	{%- endfor -%}

	{%- if blog.comments_enabled? -%}
		<div class="article-template__comment-wrapper">
			<div id="comments" class="page-width page-width--narrow">
				{%- if article.comments_count > 0 -%}
					{%- assign anchorId = '#Comments-' | append: article.id -%}

					<h2 id="Comments-{{ article.id }}" tabindex="-1">
						{{ 'blogs.article.comments' | t: count: article.comments_count }}
					</h2>
					{% paginate article.comments by 5 %}
						<div class="article-template__comments">
							{%- if comment.status == 'pending' and comment.content -%}
								<article
									id="{{ comment.id }}"
									class="article-template__comments-comment"
								>
									{{ comment.content }}
									<footer class="right">
										<span class="circle-divider caption-with-letter-spacing">
											{{- comment.author -}}
										</span>
									</footer>
								</article>
							{%- endif -%}

							{%- for comment in article.comments -%}
								<article
									id="{{ comment.id }}"
									class="article-template__comments-comment"
								>
									{{ comment.content }}
									<footer class="right">
										<span class="circle-divider caption-with-letter-spacing">
											{{- comment.author -}}</span
										><span class="caption-with-letter-spacing">
											{{- comment.created_at | time_tag: format: 'date' -}}
										</span>
									</footer>
								</article>
							{%- endfor -%}
							{% render 'pagination', paginate: paginate, anchor: anchorId %}
						</div>
					{% endpaginate %}
				{%- endif -%}
				{% form 'new_comment', article %}
					{%- liquid
						assign post_message = 'blogs.article.success'
						if blog.moderated? and comment.status == 'unapproved'
							assign post_message = 'blogs.article.success_moderated'
						endif
					-%}
					<h2>{{ 'blogs.article.comment_form_title' | t }}</h2>
					{%- if form.errors -%}
						<div class="form__message" role="alert">
							<h3
								class="form-status caption-large text-body"
								tabindex="-1"
								autofocus
							>
								{% render 'icon-error' %}
								{{ 'templates.contact.form.error_heading' | t }}
							</h3>
						</div>
						<ul class="form-status-list caption-large">
							{%- for field in form.errors -%}
								<li>
									<a href="#CommentForm-{{ field }}" class="link">
										{%- if form.errors.translated_fields[field]
												contains 'author'
										-%}
											{{ 'blogs.article.name' | t }}
										{%- elsif form.errors.translated_fields[field]
												contains 'body'
										-%}
											{{ 'blogs.article.message' | t }}
										{%- else -%}
											{{ form.errors.translated_fields[field] }}
										{%- endif -%}
										{{ form.errors.messages[field] }}
									</a>
								</li>
							{%- endfor -%}
						</ul>
					{%- elsif form.posted_successfully? -%}
						<div class="form-status-list form__message" role="status">
							<h3 class="form-status" tabindex="-1" autofocus>
								{% render 'icon-success' %}
								{{ post_message | t }}
							</h3>
						</div>
					{%- endif -%}

					<div
						{% if blog.moderated? == false %}
							class="article-template__comments-fields"
						{% endif %}
					>
						<div class="article-template__comment-fields">
							<div class="field field--with-error">
								<input
									dir="ltr"
									type="text"
									name="comment[author]"
									id="CommentForm-author"
									class="field__input"
									autocomplete="name"
									value="{{ form.author }}"
									aria-required="true"
									required
									{% if form.errors contains 'author' %}
										aria-invalid="true"
										aria-describedby="CommentForm-author-error"
									{% endif %}
									placeholder="{{ 'blogs.article.name' | t }}"
								>
								<label for="CommentForm-author">
									{{- 'blogs.article.name' | t -}}
								</label>
								{%- if form.errors contains 'author' -%}
									<small id="CommentForm-author-error">
										<span class="form__message">
											{%- render 'icon-error' -%}
											{{- 'blogs.article.name' | t }}
											{{ form.errors.messages.author }}.</span
										>
									</small>
								{%- endif -%}
							</div>
							<div class="field field--with-error">
								<input
									dir="ltr"
									type="email"
									name="comment[email]"
									id="CommentForm-email"
									class="field__input"
									autocomplete="email"
									value="{{ form.email }}"
									autocorrect="off"
									autocapitalize="off"
									aria-required="true"
									required
									{% if form.errors contains 'email' %}
										aria-invalid="true"
										aria-describedby="CommentForm-email-error"
									{% endif %}
									placeholder="{{ 'blogs.article.email' | t }}"
								>
								<label for="CommentForm-email">
									{{- 'blogs.article.email' | t -}}
								</label>
								{%- if form.errors contains 'email' -%}
									<small id="CommentForm-email-error">
										<span class="form__message">
											{%- render 'icon-error' -%}
											{{- 'blogs.article.email' | t }}
											{{ form.errors.messages.email }}.</span
										>
									</small>
								{%- endif -%}
							</div>
						</div>
						<div class="field field--with-error">
							<textarea
								dir="ltr"
								rows="5"
								name="comment[body]"
								id="CommentForm-body"
								class="text-area field__input"
								aria-required="true"
								required
								{% if form.errors contains 'body' %}
									aria-invalid="true"
									aria-describedby="CommentForm-body-error"
								{% endif %}
								placeholder="{{ 'blogs.article.message' | t }}"
							>{{ form.body }}</textarea>
							<label for="CommentForm-body">
								{{- 'blogs.article.message' | t -}}
							</label>
						</div>
						{%- if form.errors contains 'body' -%}
							<small id="CommentForm-body-error">
								<span class="form__message">
									{%- render 'icon-error' -%}
									{{- 'blogs.article.message' | t }}
									{{ form.errors.messages.body }}.</span
								>
							</small>
						{%- endif -%}
					</div>
					{%- if blog.moderated? -%}
						<p class="article-template__comment-warning caption">
							{{ 'blogs.article.moderated' | t }}
						</p>
					{%- endif -%}
					<button type="submit" class="button button--primary">
						{{ 'blogs.article.post' | t }}
					</button>
				{% endform %}
			</div>
		</div>
	{%- endif -%}
</article>

<script type="application/ld+json">
	{
	  "@context": "http://schema.org",
	  "@type": "Article",
	  "articleBody": {{ article.content | strip_html | json }},
	  "mainEntityOfPage": {
	    "@type": "WebPage",
	    "@id": {{ request.origin | append: page.url | json }}
	  },
	  "headline": {{ article.title | json }},
	  {% if article.excerpt != blank %}
	    "description": {{ article.excerpt | strip_html | json }},
	  {% endif %}
	  {% if article.image %}
				{% assign image_size = article.image.width | append: 'x' %}
	    "image": [
	      {{ article | image_url: image_size | prepend: "https:" | json }}
	    ],
	  {% endif %}
	  "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
	  "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
	  "author": {
	    "@type": "Person",
	    "name": {{ article.author | json }}
	  },
	  "publisher": {
	    "@type": "Organization",
	    {% if settings.share_image %}
					{% assign image_size = settings.share_image.width | append: 'x' %}
	      "logo": {
	        "@type": "ImageObject",
	        "height": {{ settings.share_image.height | json }},
	        "url": {{ settings.share_image | image_url: image_size | prepend: "https:" | json }},
	        "width": {{ settings.share_image.width | json }}
	      },
	    {% endif %}
	    "name": {{ shop.name | json }}
	  }
	}
</script>

