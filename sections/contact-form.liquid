{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
	{% render 'section-margin' %}
{%- endstyle -%}

<div class="contact-form section-{{ section.id }}-padding">
	<div class="container">
		<div class="contact-form__container contact-form__container--{{ section.settings.position }}{% if section.settings.full_width == false %} no_full{% endif %}">
			{%- for block in section.blocks -%}
				{%- case block.type -%}
					{% when 'image-with-text' %}
						<div
							class="image-with-text__left color-{{ block.settings.color_scheme }}"
							{{ block.shopify_attributes }}
						>
							{%- if block.settings.image != blank
								and block.settings.video == blank
							-%}
								{% capture sizes %}
                  (min-width: 990px) 1500, 100vw
                {% endcapture %}
								{{
									block.settings.image
									| image_url: width: 1500
									| image_tag:
										loading: 'lazy',
										sizes: sizes,
										widths: '360, 535, 720, 940, 1100, 1300, 1500',
										class: 'image-with-text__img'
								}}
							{%- elsif block.settings.video != blank -%}
								{{
									block.settings.video
									| video_tag:
										image_size: '1100x',
										autoplay: true,
										loop: true,
										controls: false,
										muted: true,
										class: 'image-with-text__img data-alt'
								}}
							{%- endif -%}
							<span
								class="image-with-text__overlay"
								style="opacity: {{ block.settings.effect_opacity }}"
							></span>
							<div class="image-with-text">
								<div class="image-with-text__content">
									{%- if block.settings.heading != blank -%}
										<h2 class="image-with-text__heading {{ block.settings.heading_size }}">
											{{ block.settings.heading }}
										</h2>
									{%- endif -%}
									<div class="image-with-text__author">
										<div class="image-with-text__author-left">
											{%- if block.settings.image_author != blank -%}
												<div class="image-with-text__author-avatar">
													{%- assign image_size = block.settings.image_author
														| append: 'x'
													-%}
													<img
														srcset="{{ block.settings.image_author | image_url: width: 64 }} 1x, {{ block.settings.image_author | image_url: width: 128 }} 2x"
														src="{{ block.settings.image_author | image_url: width: 64 }}"
														width="64"
														height="64"
														loading="lazy"
													>
												</div>
											{%- endif -%}
											<div class="image-with-text__author-text">
												{%- if block.settings.name != blank -%}
													<div class="image-with-text__author-name">
														{{ block.settings.name }}
													</div>
												{%- endif -%}
												{%- if block.settings.author_position != blank -%}
													<div class="image-with-text__author-position">
														{{ block.settings.author_position }}
													</div>
												{%- endif -%}
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
				{% endcase %}
			{% endfor %}

			<div class="contact-form__text">
				<div class="contact-form__wrapper">
					{%- if section.settings.heading != blank
						or section.settings.description != blank
					-%}
						<div class="contact-form__text-block">
							{%- if section.settings.heading != blank -%}
								<h2 class="contact-form__title {{ section.settings.heading_size }}">
									{{ section.settings.heading }}
								</h2>
							{%- endif -%}
							{%- if section.settings.description != blank -%}
								<div class="contact-form__description">
									{{ section.settings.description }}
								</div>
							{%- endif -%}
						</div>
					{%- endif -%}

					{%- form 'contact', id: 'ContactForm' -%}
						{%- if form.posted_successfully? -%}
							<div
								class="form-status form-status-list form__message"
								tabindex="-1"
								autofocus
							>
								{% render 'icon-success' %}
								{{ 'templates.contact.form.post_success' | t }}
							</div>
						{%- elsif form.errors -%}
						{%- endif -%}
						<div class="contact-form__fields">
							<div class="field field__name">
								<input
									dir="ltr"
									class="field__input"
									autocomplete="name"
									type="text"
									id="ContactForm-name"
									name="contact[{{ 'templates.contact.form.name' | t }}]"
									value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
									placeholder="{{ 'templates.contact.form.name' | t }}"
									required
								>
								<label
									class="field__label"
									for="ContactForm-name"
									placeholder="{{ 'templates.contact.form.name' | t }}"
								>
									{{ 'templates.contact.form.name' | t }}
								</label>
							</div>
							<div class="field field--with-error">
								<input
									dir="ltr"
									autocomplete="email"
									type="email"
									id="ContactForm-email"
									class="field__input"
									name="contact[email]"
									spellcheck="false"
									autocapitalize="off"
									value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
									aria-required="true"
									{% if form.errors contains 'email' %}
										aria-invalid="true"
										aria-describedby="ContactForm-email-error"
									{% endif %}
									placeholder="{{ 'templates.contact.form.email' | t }}"
									required
								>
								<label
									class="field__label"
									for="ContactForm-email"
									placeholder="{{ 'templates.contact.form.email' | t }}"
								>
									{{ 'templates.contact.form.email' | t }}
								</label>
								{%- if form.errors contains 'email' -%}
									<small
										class="contact-form__field-error"
										id="ContactForm-email-error"
									>
										<span class="visually-hidden">
											{{- 'accessibility.error' | t -}}
										</span>
										<span class="form__message">
											{{- form.errors.translated_fields.email | capitalize }}
											{{ form.errors.messages.email -}}
										</span>
									</small>
								{%- endif -%}
							</div>
						</div>
						<div class="field">
							<input
								dir="ltr"
								type="tel"
								id="ContactForm-phone"
								class="field__input"
								autocomplete="tel"
								name="contact[{{ 'templates.contact.form.phone' | t }}]"
								pattern="[0-9\-]*"
								value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
								placeholder="{{ 'templates.contact.form.phone' | t }}"
								required
							>
							<label
								class="field__label"
								for="ContactForm-phone"
								placeholder="{{ 'templates.contact.form.phone' | t }}"
							>
								{{- 'templates.contact.form.phone' | t -}}
							</label>
						</div>
						<div class="field">
							<textarea
								dir="ltr"
								id="ContactForm-body"
								class="text-area field__input"
								name="contact[{{ 'templates.contact.form.comment' | t }}]"
								placeholder="{{ 'templates.contact.form.comment' | t }}"
								aria-required="true"
								required
							>
                {{- form.body -}}
              </textarea>
							<label
								class="form__label field__label"
								for="ContactForm-body"
								placeholder="{{ 'templates.contact.form.comment' | t }}"
							>
								{{- 'templates.contact.form.comment' | t -}}
							</label>
						</div>
						<div class="contact-form__bottom">
							<button type="submit" class="button button--primary">
								<span>
									<span>{{ 'templates.contact.form.send' | t }}</span>
									<span>{{ 'templates.contact.form.send' | t }}</span>
								</span>
							</button>

							<div class="contact-form__add-text">
								{{ section.settings.additional_text }}
							</div>
						</div>
					{%- endform -%}
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.contact-form.name",
	"tag": "section",
	"class": "spaced-section contact-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "select",
			"id": "position",
			"options": [
				{
					"value": "left",
					"label": "t:sections.contact-form.settings.position.options__1.label"
				},
				{
					"value": "right",
					"label": "t:sections.contact-form.settings.position.options__2.label"
				}
			],
			"default": "right",
			"label": "t:sections.contact-form.settings.position.label"
		},
		{
			"type": "checkbox",
			"id": "full_width",
			"default": true,
			"label": "t:sections.slideshow.settings.full_width.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"default": "t:sections.contact-form.settings.heading.default",
			"label": "t:sections.contact-form.settings.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:sections.all.heading_size.options__0.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h3",
			"label": "t:sections.all.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "description",
			"default": "t:sections.contact-form.settings.description.default",
			"label": "t:sections.contact-form.blocks.image-with-text.settings.text.label"
		},
		{
			"type": "richtext",
			"id": "additional_text",
			"default": "t:sections.contact-form.settings.additional_text.default",
			"label": "t:sections.contact-form.settings.additional_text.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-margin.options__6.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-margin.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"blocks": [
		{
			"type": "image-with-text",
			"name": "t:sections.contact-form.blocks.image-with-text.name",
			"limit": 1,
			"settings": [
				{
					"type": "color_scheme",
					"id": "color_scheme",
					"default": "background-3",
					"label": "t:sections.footer.settings.color_scheme.label"
				},
				{
					"type": "richtext",
					"id": "heading",
					"default": "t:sections.contact-form.blocks.image-with-text.settings.heading.default",
					"label": "t:sections.contact-form.blocks.image-with-text.settings.heading.label"
				},
				{
					"type": "select",
					"id": "heading_size",
					"options": [
						{
							"value": "h4",
							"label": "t:sections.all.heading_size.options__0.label"
						},
						{
							"value": "h3",
							"label": "t:sections.all.heading_size.options__1.label"
						},
						{
							"value": "h2",
							"label": "t:sections.all.heading_size.options__2.label"
						},
						{
							"value": "h1",
							"label": "t:sections.all.heading_size.options__3.label"
						}
					],
					"default": "h2",
					"label": "t:sections.all.heading_size.label"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:sections.contact-form.blocks.image-with-text.settings.image.label"
				},
				{
					"type": "video",
					"id": "video",
					"label": "t:sections.video-banner.settings.video.label"
				},
				{
					"type": "range",
					"id": "effect_opacity",
					"min": 0,
					"max": 1,
					"step": 0.1,
					"default": 0.2,
					"label": "t:sections.all.overlay_opacity.label"
				},
				{
					"type": "text",
					"id": "name",
					"default": "t:sections.contact-form.blocks.image-with-text.settings.name.default",
					"label": "t:sections.contact-form.blocks.image-with-text.settings.name.label"
				},
				{
					"type": "text",
					"id": "author_position",
					"default": "t:sections.contact-form.blocks.image-with-text.settings.author_position.default",
					"label": "t:sections.contact-form.blocks.image-with-text.settings.author_position.label"
				},
				{
					"type": "image_picker",
					"id": "image_author",
					"label": "t:sections.contact-form.blocks.image-with-text.settings.image_author.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.contact-form.presets.name",
			"blocks": [
				{
					"type": "image-with-text"
				}
			]
		}
	]
}
{% endschema %}
