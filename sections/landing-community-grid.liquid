{{ 'section-landing-community-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #landing-community-{{ section.id }} {
    --lc-page: {{ section.settings.page_background }};
    --lc-heading: {{ section.settings.heading_color }};
    --lc-sub: {{ section.settings.subtext_color }};
    --lc-btn: {{ section.settings.button_background }};
  }
{% endstyle %}

<section
  id="landing-community-{{ section.id }}"
  class="landing-community"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="landing-community__inner">
    {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
      <header class="landing-community__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="landing-community__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="landing-community__sub">{{ section.settings.subtext | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="landing-community__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'moment' -%}
            <div
              class="landing-community__cell landing-community__cell--{{ block.settings.tone | default: 'cream' }}"
              {{ block.shopify_attributes }}
            >
              <div class="landing-community__cell-media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 25vw, (min-width: 550px) 50vw, 100vw',
                      widths: '375, 550, 750, 1000, 1200'
                  }}
                {%- elsif section.settings.use_theme_image_fallbacks -%}
                  {%- liquid
                    case forloop.index
                      when 1
                        assign fb_asset = 'landing-community-1.png'
                      when 2
                        assign fb_asset = 'landing-community-2.jpg'
                      when 3
                        assign fb_asset = 'landing-community-3.png'
                      else
                        assign fb_asset = 'landing-community-4.jpg'
                    endcase
                  -%}
                  <img
                    src="{{ fb_asset | asset_url }}"
                    alt=""
                    width="800"
                    height="800"
                    loading="lazy"
                    decoding="async"
                    sizes="(min-width: 990px) 25vw, (min-width: 550px) 50vw, 100vw"
                  >
                {%- endif -%}
                {%- if block.settings.desaturate -%}
                  <div class="landing-community__cell-sat" aria-hidden="true"></div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="landing-community__cta-wrap">
        <a
          class="landing-community__cta"
          {% if section.settings.cta_url != blank %}
            href="{{ section.settings.cta_url }}"
            target="_blank"
            rel="noopener noreferrer"
          {% else %}
            aria-disabled="true"
          {% endif %}
        >
          <span
            class="landing-community__cta-icon{% if section.settings.custom_icon != blank %} landing-community__cta-icon--dark{% endif %}"
            aria-hidden="true"
          >
            {%- if section.settings.custom_icon != blank -%}
              <img
                src="{{ section.settings.custom_icon | image_url: width: 40 }}"
                alt=""
                width="20"
                height="18"
                loading="lazy"
              >
            {%- else -%}
              <img
                src="{{ 'landing-community-instagram.svg' | asset_url }}"
                alt=""
                width="20"
                height="18"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
          </span>
          <span>{{ section.settings.cta_label | escape }}</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Landing community grid",
  "tag": "section",
  "class": "landing-community-grid-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "#DieBarista Momente"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Teile deine Kaffee-Routine mit unserer Community in Hameln."
    },
    {
      "type": "header",
      "content": "Instagram CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Folge mir auf Instagram"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Instagram or social URL"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Button icon (optional)",
      "info": "Replaces default camera icon when set."
    },
    {
      "type": "header",
      "content": "Grid fallbacks"
    },
    {
      "type": "checkbox",
      "id": "use_theme_image_fallbacks",
      "label": "Use bundled photos when a cell has no upload",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "page_background",
      "label": "Page background",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext",
      "default": "#7b5d4d"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#759769"
    }
  ],
  "blocks": [
    {
      "type": "moment",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "tone",
          "label": "Fallback tint (letterbox)",
          "options": [
            { "value": "cream", "label": "Cream" },
            { "value": "brown", "label": "Brown" },
            { "value": "red", "label": "Red" },
            { "value": "green", "label": "Green" }
          ],
          "default": "cream"
        },
        {
          "type": "checkbox",
          "id": "desaturate",
          "label": "Desaturate (Figma blend)",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing community grid",
      "blocks": [
        { "type": "moment", "settings": { "tone": "cream", "desaturate": true } },
        { "type": "moment", "settings": { "tone": "brown", "desaturate": true } },
        { "type": "moment", "settings": { "tone": "red", "desaturate": true } },
        { "type": "moment", "settings": { "tone": "green", "desaturate": true } }
      ]
    }
  ]
}
{% endschema %}
