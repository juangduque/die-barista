{{ 'section-product-markers.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card-horizontal.css' | asset_url | stylesheet_tag }}

{%- if settings.quickview_show == false
	and settings.type_color_swatch == 'custom'
-%}
	{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- if settings.quickview_show or settings.add_to_cart_enabled -%}
	<link
		rel="preload"
		href="{{ 'section-main-product.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>
	<link
		rel="stylesheet"
		href="{{ 'component-deferred-media.css' | asset_url }}"
		media="all"
	>
	<link
		rel="preload"
		href="{{ 'quick-add.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>

	<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
	<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
<script src="{{ 'product-markers.js' | asset_url }}" defer="defer"></script>

{% style %}
	{% render 'section-margin' %}
	{% render 'section-padding' %}
{% endstyle %}
{% liquid
	assign slide_effects = section.settings.slide_effects
	assign slideshow_speed = section.settings.slideshow_speed
	assign autoplay = section.settings.is_autoplay
	assign stop_autoplay = section.settings.is_hover_stop_autoplay
	assign delay = section.settings.slide_delay
%}

<div
	class="product-markers product-markers--{%- if section.settings.section_type == 'tabs' -%}section-tabs{% endif %} product-markers--{%- if section.settings.section_type == 'slider' -%}desctop{%- endif -%}"
	data-id="shopify-section-{{ section.id }}"
	{%- if section.settings.section_type != 'tabs' -%}
		data-autoplay="{{ autoplay }}"
	{% endif %}
	data-stop-autoplay="{{ stop_autoplay }}"
	data-speed="{{ slideshow_speed }}"
	data-effect="{{ slide_effects }}"
	data-delay="{{ delay }}"
>
	{%- if section.settings.section_type == 'tabs' -%}
		{% if section.settings.height != 'adapt' %}
			{% liquid
				assign aspect_ratio = section.settings.height | split: '/'
				assign temp = aspect_ratio[0] | append: '.0'
				assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
			%}
		{% elsif section.settings.image != blank %}
			{% assign padding_bottom = 1
				| divided_by: section.settings.image.aspect_ratio
				| times: 100
				| round: 2
			%}
		{% endif %}
		{% style %}
			#shopify-section-{{ section.id }} .product-markers__img-box {
				content: "";
				display: block;
				padding-bottom: {{ padding_bottom }}%;
			}
		{% endstyle %}
	{% endif %}
	{% render 'section-header', has_header_size: section.settings.heading_size %}

	<div class="product-markers__wrapper markers-{{ section.settings.section_type }}">
		<div class="container">
			{%- if section.settings.section_type == 'tabs' -%}
				<div
					class="product-markers-for-mobile"
				>
					{%- for block in section.blocks -%}
						<div
							class="product-markers__item-inner--mobile js-product-markers__item-inner"
							data-index="{{ forloop.index }}"
						>
							{% render 'product-card-horizontal',
								product_card_product: block.settings.product,
								media_size: section.settings.image_ratio,
								media_fit: section.settings.image_fit,
								show_secondary_image: section.settings.show_secondary_image,
								show_vendor: section.settings.show_vendor,
								show_desc: section.settings.show_desc,
								section_id: section.id,
								placeholder_index: forloop.index
							%}
						</div>
					{% endfor %}
				</div>
			{%- endif -%}

			<div class="product-markers__box color-{{ section.settings.color_scheme }}">
				<div class="product-markers__img">
					<div class="product-markers__img-box">
						{%- if section.settings.image != blank -%}
							{{
								section.settings.image
								| image_url: width: 3000
								| image_tag:
									loading: 'lazy',
									width: section.settings.image.width,
									sizes: '100vw',
									widths: '375, 550, 750, 1100, 1500, 1800, 2200, 3000'
							}}
						{%- else -%}
							{{
								'hero-apparel-1'
								| placeholder_svg_tag: 'placeholder-svg placeholder'
							}}
						{%- endif -%}
						{%- if section.settings.section_type == 'slider' -%}
							<div class="swiper product-markers___thumbnail">
								<div class="swiper-wrapper">
						{%- endif -%}
					
									{% for block in section.blocks %}
										{% liquid
											assign x = block.settings.position_x
											assign y = block.settings.position_y

											if x >= 50
												assign horizontal_position = 'right'
												assign x = 100 | minus: x
											else
												assign horizontal_position = 'left'
											endif
											if y >= 50
												assign y = 100 | minus: y
												assign vertical_position = ' bottom'
											else
												assign vertical_position = ' top'
											endif

											assign marker_classes = horizontal_position | append: vertical_position
											if forloop.index == 1 and section.settings.section_type == 'slider'
												assign marker_classes = marker_classes | append: ' swiper-slide-thumb-active'
											endif
										%}
										<div
											class="product-markers__marker {% if section.settings.section_type == 'slider' %}	swiper-slide {% endif %} {% if section.settings.section_type == 'tabs' %}	product-markers__marker-tab {% endif %}{{ marker_classes }}"
											style="{{ horizontal_position }} : {{ x }}%; {{ vertical_position }} : {{ y }}%"
											data-slide-index="{{ forloop.index0 }}"
											data-index="{{ forloop.index }}"
										>
											{% render 'icon-circle' %}
											{%- if section.settings.section_type == 'tabs' -%}
												<div
													data-index="{{ forloop.index }}"
													style="{% if block.settings.product == blank %}padding: 2rem; margin: 1rem{% endif %}"
													class="product-markers__item-inner product-markers__item-inner--desctop js-product-markers__item-inner product-markers__item-inner--desctop--{{ block.settings.tooltip_open_position }} {% if block.settings.product != blank %}collection-product-card collection-popular-card featured-products__item featured-products__item--card quickview{%- if settings.quickview_hover -%}--hover{% endif %}{%- endif -%}"
												>
													{% if block.settings.product != blank %}
														{% render 'product-card',
															product_card_product: block.settings.product,
															media_size: section.settings.image_ratio,
															media_fit: section.settings.image_fit,
															show_secondary_image: section.settings.show_secondary_image,
															show_vendor: section.settings.show_vendor,
															show_sku: section.settings.show_sku,
															show_desc: section.settings.show_desc,
															section_id: section.id
														%}
													{%- else -%}
														{% render 'product-card-placeholder',
															media_size: 'square',
															placeholder_index: forloop.index
														%}
													{% endif %}
												</div>
											{%- endif -%}
										</div>
									{% endfor %}

						{%- if section.settings.section_type == 'slider' -%}
								</div>
							</div>
						{%- endif -%}

						{% comment %} TWP content {% endcomment %}
						{% if section.settings.section_type == 'tabs' %}
							<div class="tabs-with-products twp">
								<div class="twp__content">
									{%- for block in section.blocks -%}
										<div
											class="twp__content-item "
											{% if forloop.index == 1 %}
												style="display: flex;"
											{% endif %}
										>
											<div class="twp__inner">
												<div class="twp__inner-scroll-wrapper">
													<div class="twp__inner-scroll">
														<ul class="twp__product-list list-unstyled">
															{%- for block in section.blocks -%}
																<li class="twp__product-list-item">
																	{% render 'product-card-horizontal',
																		product_card_product: block.settings.product,
																		media_size: section.settings.image_ratio,
																		media_fit: section.settings.image_fit,
																		show_secondary_image: section.settings.show_secondary_image,
																		show_vendor: section.settings.show_vendor,
																		show_desc: section.settings.show_desc,
																		section_id: section.id,
																		placeholder_index: forloop.index
																	%}
																</li>
															{%- endfor -%}
														</ul>
													</div>
												</div>

												<button class="button button--{{ section.settings.button_style }} twp__toggle">
													<span>
														<span>
															{{- section.settings.button_label_twp | escape -}}
														</span>
														<span>
															{{- section.settings.button_label_twp | escape -}}
														</span>
													</span>

													<span class="items-container">
														{{- section.blocks.size | append: ' ' -}} {{ 'sections.product_markers.items' | t }}
														{%- render 'icon-button-arrow' -%}
													</span>
												</button>
											</div>
										</div>
									{%- endfor -%}
								</div>
							</div>
						{% endif %}
					</div>
				</div>

				<div class="product-markers__product-wrapper section-{{ section.id }}-padding ">
					<div class="product-markers__swiper swiper">
						<div class="product-markers__swiper-wrapper swiper-wrapper">
							{% for block in section.blocks %}
								<div class="swiper-slide color-{{ section.settings.color_scheme }}">
									<div class="product-markers__slider">
										{% if block.settings.product != blank %}
											<div class="product-markers__product collection-product-card {% if settings.quickview_hover %}quickview--hover{% endif %}">
												{% render 'product-card',
													product_card_product: block.settings.product,
													media_size: section.settings.image_ratio,
													media_fit: section.settings.image_fit,
													show_secondary_image: section.settings.show_secondary_image,
													show_vendor: section.settings.show_vendor,
													show_desc: section.settings.show_desc,
													show_sku: section.settings.show_sku,
													section_id: section.id,
													product_background: section.settings.color_scheme
												%}
											</div>
										{% else %}
											<div class="product-markers__product collection-product-card">
												{% render 'product-card-placeholder',
													media_size: 'square',
													placeholder_index: forloop.index
												%}
											</div>
										{% endif %}
									</div>
								</div>
							{% endfor %}
						</div>
					</div>
					{% if section.blocks.size > 1 and section.settings.show_arrows %}
						<div class="slideshow__navigation slideshow__navigation--{{ section.settings.controls_color_scheme }} no-js-hidden">
							<div class="swiper-button swiper-button-prev markers-swiper-button-prev swiper-button-absolute">
								<span>{% render 'icon-arrow-left' %}</span>
							</div>
							<div class="swiper-button swiper-button-next markers-swiper-button-next swiper-button-absolute">
								<span>{% render 'icon-arrow-right' %}</span>
							</div>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.product_markers.name",
	"tag": "section",
	"class": "product-markers-section spaced-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "select",
			"id": "section_type",
			"options": [
				{
					"value": "slider",
					"label": "t:sections.product_markers.settings.section_type-1.label"
				},
				{
					"value": "tabs",
					"label": "t:sections.product_markers.settings.section_type-2.label"
				}
			],
			"default": "tabs",
			"label": "t:sections.product_markers.label"
		},
		{
			"type": "select",
			"id": "height",
			"info": "t:sections.product_markers.button_info.info",
			"options": [
				{
					"value": "1/1",
					"label": "t:sections.slideshow.settings.height.options__1.label"
				},
				{
					"value": "3/2",
					"label": "t:sections.slideshow.settings.height.options__2.label"
				},
				{
					"value": "4/3",
					"label": "t:sections.slideshow.settings.height.options__3.label"
				},
				{
					"value": "16/9",
					"label": "t:sections.slideshow.settings.height.options__4.label"
				},
				{
					"value": "21/9",
					"label": "t:sections.slideshow.settings.height.options__5.label"
				},
				{
					"value": "adapt",
					"label": "t:sections.slideshow.settings.height.options__6.label"
				}
			],
			"default": "adapt",
			"label": "t:sections.slideshow.settings.height.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-2",
			"label": "t:sections.footer.settings.color_scheme.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"default": "t:sections.product_markers.settings.heading.default",
			"label": "t:sections.all.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:sections.all.heading_size.options__0.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h3",
			"label": "t:sections.all.heading_size.label"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.all.image.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.card.header_card.content"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "landscape",
					"label": "t:sections.all.card.image_ratio.options__1.label"
				},
				{
					"value": "portrait",
					"label": "t:sections.all.card.image_ratio.options__2.label"
				},
				{
					"value": "square",
					"label": "t:sections.all.card.image_ratio.options__3.label"
				}
			],
			"default": "portrait",
			"label": "t:sections.all.card.image_ratio.label"
		},
		{
			"type": "select",
			"id": "image_fit",
			"label": "t:sections.all.card.image_fit.label",
			"options": [
				{
					"value": "contain",
					"label": "t:sections.all.card.image_fit.options__1.label"
				},
				{
					"value": "cover",
					"label": "t:sections.all.card.image_fit.options__2.label"
				}
			],
			"default": "cover"
		},
		{
			"type": "checkbox",
			"id": "show_secondary_image",
			"default": false,
			"label": "t:sections.all.card.show_secondary_image.label"
		},
		{
			"type": "checkbox",
			"id": "show_vendor",
			"default": true,
			"label": "t:sections.all.card.show_vendor.label"
		},
		{
			"type": "checkbox",
			"id": "show_sku",
			"default": false,
			"label": "t:sections.all.card.show_sku.label"
		},
		{
			"type": "checkbox",
			"id": "show_desc",
			"default": false,
			"label": "t:sections.all.card.show_desc.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content",
			"info": "t:sections.product_markers.button_info.info"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				}
			],
			"default": "primary",
			"label": "t:sections.all.button.button_style.label"
		},
		{
			"type": "text",
			"id": "button_label_twp",
			"default": "t:sections.product_markers.settings.button_label_twp.default",
			"label": "t:sections.all.button.button_label.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.slider_options.header.content",
			"info": "t:sections.product_markers.only_section_slider.info"
		},
		{
			"type": "checkbox",
			"id": "is_autoplay",
			"default": true,
			"label": "t:sections.slideshow.settings.enable_autoplay.label"
		},
		{
			"type": "checkbox",
			"id": "is_hover_stop_autoplay",
			"default": true,
			"label": "t:sections.all.slider_options.slider_hover_autoplay_stop.label"
		},
		{
			"type": "checkbox",
			"id": "show_arrows",
			"default": true,
			"label": "t:sections.slideshow.settings.enable_slider_btns.label"
		},
		{
			"type": "select",
			"id": "controls_color_scheme",
			"options": [
				{
					"value": "light",
					"label": "t:sections.slideshow.settings.controls_color_scheme.options__1.label"
				},
				{
					"value": "dark",
					"label": "t:sections.slideshow.settings.controls_color_scheme.options__2.label"
				}
			],
			"default": "light",
			"label": "t:sections.slideshow.settings.controls_color_scheme.label"
		},
		{
			"type": "range",
			"id": "slideshow_speed",
			"min": 0,
			"max": 6,
			"step": 0.1,
			"default": 1.1,
			"unit": "s",
			"label": "t:sections.all.slider_options.speed.label"
		},
		{
			"type": "range",
			"id": "slide_delay",
			"default": 3,
			"min": 1,
			"max": 10,
			"step": 1,
			"unit": "s",
			"label": "t:sections.product_markers.settings.slide_delay.label"
		},
		{
			"type": "select",
			"id": "slide_effects",
			"options": [
				{
					"value": "slide",
					"label": "t:sections.all.slider_options.effects.options.options__1.label"
				},
				{
					"value": "fade",
					"label": "t:sections.all.slider_options.effects.options.options__2.label"
				},
				{
					"value": "coverflow",
					"label": "t:sections.all.slider_options.effects.options.options__3.label"
				},
				{
					"value": "creative",
					"label": "t:sections.all.slider_options.effects.options.options__4.label"
				},
				{
					"value": "flip",
					"label": "t:sections.all.slider_options.effects.options.options__5.label"
				}
			],
			"default": "slide",
			"label": "t:sections.all.slider_options.effects.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
