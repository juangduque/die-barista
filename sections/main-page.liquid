<link rel="stylesheet" href="{{ 'section-main-page.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'section-main-page.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

<div class="container">
	<div class="page-header">
		<div class="page-header__inner">
			<h1 class="main-page-title page-title title--page">
				{{ page.title | escape }}
			</h1>
		</div>
	</div>
	<div class="rte{% if section.settings.rte_image_style == "default" %} rte_images-default{% endif %}">
		{{ page.content }}
	</div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "page-section",
	"settings": [
		{
			"type": "select",
			"id": "rte_image_style",
			"options": [
				{
					"value": "default",
					"label": "t:sections.all.rte_img_style.options__1.label"
				},
				{
					"value": "custom",
					"label": "t:sections.all.rte_img_style.options__2.label"
				}
			],
			"default": "custom",
			"label": "t:sections.all.rte_img_style.label"
		}
  ]
}
{% endschema %}

