{% comment %}
  Produkt — Reviews (Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:290)
  Soapstone page, Serenade cards, 3px gutter. Blocks: review.
{% endcomment %}

{%- liquid
  assign score_text   = section.settings.aggregate_score | default: '4.8'
  assign review_count  = section.settings.review_count    | default: '127'
  assign count_label   = section.settings.count_label     | default: 'Basierend auf [count] Bewertungen'
  assign count_label   = count_label | replace: '[count]', review_count
-%}

<section
  class="reviews-section"
  id="reviews-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Bewertungen"
>
  <div class="reviews-inner">

    <header
      class="reviews-aggregate"
      aria-label="Durchschnitt {{ score_text }} von 5 Sternen. {{ count_label | escape }}"
    >
      <p class="reviews-aggregate__score">{{ score_text | escape }}</p>
      <div class="reviews-aggregate__meta">
        <p class="reviews-aggregate__stars" aria-hidden="true">
          <span class="reviews-stars reviews-stars--hero">★★★★★</span>
        </p>
        <p class="reviews-aggregate__count">{{ count_label | escape }}</p>
      </div>
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="reviews-grid" role="list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'review' -%}
              {%- liquid
                assign star_n = block.settings.stars | default: 5
                assign quote   = block.settings.quote
                assign author  = block.settings.author
                assign meta    = block.settings.meta
              -%}
              {%- capture star_string -%}
                {%- for i in (1..5) -%}
                  {%- if i <= star_n -%}★{%- else -%}☆{%- endif -%}
                {%- endfor -%}
              {%- endcapture -%}
              <article
                class="reviews-card"
                role="listitem"
                {{ block.shopify_attributes }}
              >
                <div class="reviews-card__inner">
                  <p class="reviews-card__stars" aria-hidden="true">{{ star_string }}</p>
                  {%- unless quote == blank -%}
                    <p class="reviews-card__quote">{{ quote | escape }}</p>
                  {%- endunless -%}
                  {%- unless author == blank -%}
                    <p class="reviews-card__author">{{ author | escape }}</p>
                  {%- endunless -%}
                  {%- unless meta == blank -%}
                    <p class="reviews-card__meta">{{ meta | escape }}</p>
                  {%- endunless -%}
                </div>
              </article>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
.reviews-section {
  --db-red:       #e23528;
  --db-black:     #00090b;
  --db-opium:     #906f6a;
  --db-roman:     #755848;
  --db-serenade:  #fff1e7;
  --db-soapstone: #fff8f5;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

.reviews-section {
  background: var(--db-soapstone);
  padding: 4rem clamp(1.25rem, 10vw, 25.625rem);
  box-sizing: border-box;
}

.reviews-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

/* ── aggregate (Figma 18:292) ── */
.reviews-aggregate {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1.75rem;
}

.reviews-aggregate__score {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: clamp(2.5rem, 6vw, 3.5rem);
  line-height: 1;
  color: var(--db-black);
  margin: 0;
}

.reviews-aggregate__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  min-width: 0;
}

.reviews-stars--hero {
  font-family: var(--db-font-display);
  font-weight: 400;
  font-size: 1.3rem;
  letter-spacing: 0.125rem;
  color: var(--db-red);
  line-height: 1.6;
}

.reviews-aggregate__count {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 0.9rem;
  line-height: 1.61;
  color: var(--db-opium);
  margin: 0;
  white-space: nowrap;
}

/* ── card grid: 3 cols, 3px gutter (18:300) ── */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 3px;
  background: var(--db-soapstone);
  width: 100%;
}

.reviews-card {
  background: var(--db-serenade);
  margin: 0;
  min-height: 14.25rem;
  box-sizing: border-box;
}

.reviews-card__inner {
  padding: 1.75rem;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.35rem;
}

.reviews-card__stars {
  font-family: var(--db-font-display);
  font-weight: 400;
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--db-red);
  letter-spacing: 0.06em;
  margin: 0 0 0.25rem;
}

.reviews-card__quote {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 1rem;
  line-height: 1.61;
  color: var(--db-roman);
  margin: 0 0 auto;
  max-width: 100%;
}

.reviews-card__author {
  font-family: var(--db-font-display);
  font-weight: 700;
  font-size: 1rem;
  line-height: 1.6;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--db-black);
  margin: 0.6rem 0 0;
}

.reviews-card__meta {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--db-opium);
  margin: 0;
}

@media (max-width: 900px) {
  .reviews-section {
    padding: 3rem 1.5rem;
  }

  .reviews-inner {
    padding: 0 1.5rem;
    gap: 2.25rem;
  }

  .reviews-aggregate {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .reviews-aggregate__count {
    white-space: normal;
  }

  .reviews-grid {
    grid-template-columns: 1fr;
  }

  .reviews-card {
    min-height: 0;
  }
}

@media (max-width: 540px) {
  .reviews-section {
    padding: 2.5rem 1rem;
  }

  .reviews-inner {
    padding: 0 0.75rem;
    gap: 1.75rem;
  }

  .reviews-card__inner {
    padding: 1.25rem 1.25rem 1.5rem;
  }
}
</style>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "class": "barista-section-reviews",
  "max_blocks": 9,
  "settings": [
    {
      "type": "header",
      "content": "Gesamtbewertung"
    },
    {
      "type": "text",
      "id": "aggregate_score",
      "label": "Angezeigte Note",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Anzahl Bewertungen",
