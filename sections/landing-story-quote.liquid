{{ 'section-landing-story-quote.css' | asset_url | stylesheet_tag }}

{% style %}
  #landing-hw-story-{{ section.id }} {
    --landing-hw-story-bg: {{ section.settings.section_bg }};
    --landing-hw-story-quote-bg: {{ section.settings.quote_bg }};
    --landing-hw-story-title: {{ section.settings.title_color }};
    --landing-hw-story-accent: {{ section.settings.accent_color }};
    --landing-hw-story-num: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section
  id="landing-hw-story-{{ section.id }}"
  class="landing-hw-story"
>
  <div class="landing-hw-story__grid">
    <div class="landing-hw-story__visual">
      {%- if section.settings.image != blank -%}
        <div class="landing-hw-story__image-wrap">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 990px) 45vw, 100vw',
              widths: '400, 700, 1000, 1200'
          }}
          <div class="landing-hw-story__image-desat" aria-hidden="true"></div>
        </div>
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      {%- if section.settings.quote != blank -%}
        <div class="landing-hw-story__quote-box">
          <div class="landing-hw-story__quote rte">{{ section.settings.quote }}</div>
          {%- if section.settings.quote_author != blank -%}
            <p class="landing-hw-story__quote-author">{{ section.settings.quote_author | escape }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="landing-hw-story__content">
      {%- if section.settings.subtitle != blank -%}
        <p class="landing-hw-story__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="landing-hw-story__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.intro_text != blank -%}
        <div class="landing-hw-story__intro rte">{{ section.settings.intro_text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="landing-hw-story__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'point' -%}
              <li {{ block.shopify_attributes }}>
                <span class="landing-hw-story__num">{{ block.settings.number | escape }}</span>
                <div>
                  {%- if block.settings.heading != blank -%}
                    <h3 class="landing-hw-story__item-title">{{ block.settings.heading | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="landing-hw-story__item-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.link_label != blank -%}
        <a
          class="landing-hw-story__link"
          {% if section.settings.link_url != blank %}
            href="{{ section.settings.link_url }}"
          {% endif %}
        >
          {{ section.settings.link_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Story",
  "tag": "section",
  "class": "landing-hw-story-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote overlay",
      "default": "<p>\"Kaffee ist nicht nur ein Getränk, es ist eine Blaupause für den perfekten Moment.\"</p>"
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote author",
      "default": "— Cemil, Gründer"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Die Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Mehr als nur Bohnen."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text",
      "default": "<p>Seit 2018 röste ich in Hameln. Was als Leidenschaft in der Garage begann, ist heute eine Mission: Den ehrlichsten Kaffee der Region zu produzieren.</p><p>Jede Röstung wird von mir persönlich überwacht. Ohne industrielle Automatik, nur mit Nase, Augen und Erfahrung.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Lies die ganze Story →"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f5ede5"
    },
    {
      "type": "color",
      "id": "quote_bg",
      "label": "Quote box background",
      "default": "#759769"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#00090b"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (numbers, subtitle)",
      "default": "#e23528"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Ursprung"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing HW Story",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "number": "01",
            "heading": "Ursprung",
            "text": "Direkter Handel mit Farmen, die wir beim Namen kennen."
          }
        },
        {
          "type": "point",
          "settings": {
            "number": "02",
            "heading": "Röstung",
            "text": "Schonendes Trommelröstverfahren für maximale Aromaentfaltung."
          }
        },
        {
          "type": "point",
          "settings": {
            "number": "03",
            "heading": "Charakter",
            "text": "Kaffee mit Ecken und Kanten. Nichts für den Massengeschmack."
          }
        }
      ]
    }
  ]
}
{% endschema %}
