{{ 'section-landing-newsletter-cemil.css' | asset_url | stylesheet_tag }}

{% style %}
  #landing-hw-nl-{{ section.id }} {
    --landing-hw-nl-bg: {{ section.settings.section_bg }};
  }
{% endstyle %}

<section
  id="landing-hw-nl-{{ section.id }}"
  class="landing-hw-nl"
>
  <div class="landing-hw-nl__grid">
    <div class="landing-hw-nl__left">
      {%- if section.settings.title != blank -%}
        <h2 class="landing-hw-nl__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="landing-hw-nl__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    <div class="landing-hw-nl__right">
      {%- if section.settings.use_klaviyo_embed and section.settings.klaviyo_embed != blank -%}
        <div class="landing-hw-nl__embed">{{ section.settings.klaviyo_embed }}</div>
      {%- elsif section.settings.show_shopify_form -%}
        <div class="landing-hw-nl__form-wrap">
          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p class="form-message" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</p>
            {%- else -%}
              <label class="visually-hidden" for="LandingNlEmail-{{ section.id }}">
                {{ 'newsletter.label' | t }}
              </label>
              <input
                id="LandingNlEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                required
              >
              <button type="submit" name="commit">
                {%- if section.settings.submit_label != blank -%}
                  {{- section.settings.submit_label | escape -}}
                {%- else -%}
                  {{- 'newsletter.button_label' | t -}}
                {%- endif -%}
              </button>
            {%- endif -%}
          {% endform %}
        </div>
      {%- endif -%}

      <div class="landing-hw-nl__profile">
        {%- if section.settings.portrait != blank -%}
          <div class="landing-hw-nl__avatar">
            {{
              section.settings.portrait
              | image_url: width: 200
              | image_tag: loading: 'lazy', widths: '100, 200'
            }}
          </div>
        {%- endif -%}
        {%- if section.settings.quote != blank -%}
          <div class="landing-hw-nl__quote-wrap">
            <blockquote class="landing-hw-nl__quote rte">{{ section.settings.quote }}</blockquote>
            {%- if section.settings.quote_author != blank -%}
              <p class="landing-hw-nl__author">{{ section.settings.quote_author | escape }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Newsletter",
  "tag": "section",
  "class": "landing-hw-nl-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Kaffee-Wissen. Direkt von Cemil."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Erhalte exklusive Tipps zur Zubereitung, Einblicke in unsere Röst-Protokolle und erfahre als Erster von neuen Limited Editions."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "checkbox",
      "id": "use_klaviyo_embed",
      "label": "Use Klaviyo embed HTML",
      "default": false
    },
    {
      "type": "html",
      "id": "klaviyo_embed",
      "label": "Klaviyo embed",
      "info": "Paste Klaviyo form div/snippet. If empty, use Shopify customer form below."
    },
    {
      "type": "checkbox",
      "id": "show_shopify_form",
      "label": "Show Shopify newsletter form",
      "default": true
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Deine E-Mail Adresse"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button",
      "default": "Abonnieren"
    },
    {
      "type": "header",
      "content": "Profile"
    },
    {
      "type": "image_picker",
      "id": "portrait",
      "label": "Portrait"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote",
      "default": "<p>\"Kein Spam, versprochen. Nur echte Leidenschaft für Genießer des schwarzen Goldes.\"</p>"
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote author",
      "default": "— Cemil"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background",
      "default": "#efdfd3"
    }
  ],
  "presets": [
    {
      "name": "Landing HW Newsletter"
    }
  ]
}
{% endschema %}
