{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 01: HERO + BUY BLOCK
  File: sections/barista-hero-buyblock.liquid
  
  Features:
  - Split layout: Product gallery (left) + Buy block (right)
  - Weight selector: 250g / 1kg (1kg default + bestseller badge)
  - Grind selector: Siebträger / Moka / Filter / Ganze Bohne
  - Coffee need slider → smart recommendation box
  - Purchase toggle: Einmalkauf / Abo (Abo preselected)
  - Dynamic pricing with price-per-cup display
  - Seal Subscriptions compatible
  - Mobile sticky ATC bar
  - Tasting tags, flavor scales, trust micro-bar
  - Category color strip (per product: Espresso=Red, Crema=Crema, Green=Wechselnd)
  ============================================================
{% endcomment %}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  
  comment
    Resolve category color from product tags or metafield
    Tag: "kategorie-espresso" → red, "kategorie-crema" → crema, "kategorie-wechselnd" → green
  endcomment
  assign category_color = '#E23528'
  if product.tags contains 'kategorie-crema'
    assign category_color = '#EFDFD3'
  elsif product.tags contains 'kategorie-wechselnd'
    assign category_color = '#759769'
  endif

  comment
    Metafields used:
    product.metafields.coffee_attributes.roasting_level → integer 0–6
    product.metafields.coffee_attributes.acid_level     → integer 0–6
    product.metafields.coffee_attributes.strength_level → integer 0–6
    product.metafields.barista.tasting_notes            → comma-separated string e.g. "Schokolade, Nuss, Karamell"
    product.metafields.barista.category_label           → string e.g. "Espresso · Ganze Bohne"
    product.metafields.barista.short_desc               → string (1–2 sentences)
  endcomment
  assign roast_level    = product.metafields.coffee_attributes.roasting_level.value | default: 4
  assign acidity        = product.metafields.coffee_attributes.acid_level.value | default: 3
  assign strength       = product.metafields.coffee_attributes.strength_level.value | default: 2
  assign tasting_notes  = product.metafields.barista.tasting_notes | default: ''
  assign category_label = product.metafields.barista.category_label | default: 'Espresso · Ganze Bohne'
  assign short_desc     = product.metafields.barista.short_desc | default: product.description | truncate: 160

  # Scale 0–6 → percentage (divide by 6, not 5)
  assign roast_pct    = roast_level | times: 100 | divided_by: 6
  assign strength_pct = strength | times: 100 | divided_by: 6
  assign acidity_pct  = acidity | times: 100 | divided_by: 6

  comment
    Identify 250g and 1kg variants by title keyword
    We loop product.variants to find them
  endcomment
  assign variant_250 = nil
  assign variant_1kg = nil
  for v in product.variants
    if v.title contains '250' or v.option1 contains '250' or v.option2 contains '250'
      if variant_250 == nil
        assign variant_250 = v
      endif
    endif
    if v.title contains '1 kg' or v.title contains '1kg' or v.option1 contains '1 kg' or v.option1 contains '1kg' or v.option2 contains '1 kg' or v.option2 contains '1kg'
      if variant_1kg == nil
        assign variant_1kg = v
      endif
    endif
  endfor

  if variant_250 == nil
    assign variant_250 = product.variants[0]
  endif
  if variant_1kg == nil
    assign variant_1kg = product.variants[1] | default: product.variants[0]
  endif

  comment
    Price-per-cup: 1 cup ≈ 7g
    250g → ~35 cups, 1kg → ~142 cups
  endcomment
  assign cups_250  = 35
  assign cups_1kg  = 142
  assign price_250_cents = variant_250.price
  assign price_1kg_cents = variant_1kg.price
  assign ppc_250 = price_250_cents | divided_by: cups_250
  assign ppc_1kg = price_1kg_cents | divided_by: cups_1kg
-%}

{{ 'barista-hero-buyblock.css' | asset_url | stylesheet_tag }}

<section 
  class="barista-hero" 
  id="barista-hero"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-variant-250="{{ variant_250.id }}"
  data-variant-1kg="{{ variant_1kg.id }}"
  data-price-250="{{ variant_250.price }}"
  data-price-1kg="{{ variant_1kg.price }}"
  data-ppc-250="{{ ppc_250 }}"
  data-ppc-1kg="{{ ppc_1kg }}"
  style="--category-color: {{ category_color }};"
>

  <!-- ═══════════════════════════════════════════════
       GALLERY (LEFT)
       ═══════════════════════════════════════════════ -->
  <div class="barista-gallery">
    <!-- Category color strip -->
    <div class="barista-gallery__strip"></div>

    <!-- Main image -->
    <div class="barista-gallery__main" id="galleryMain">
      {%- if product.featured_media -%}
        <img
          src="{{ product.featured_media | image_url: width: 800 }}"
          alt="{{ product.featured_media.alt | escape }}"
          width="800"
          height="{{ 800 | divided_by: product.featured_media.aspect_ratio | round }}"
          loading="eager"
          fetchpriority="high"
          class="barista-gallery__img"
          id="galleryMainImg"
        >
      {%- else -%}
        <div class="barista-gallery__placeholder">Produktbild</div>
      {%- endif -%}
    </div>

    <!-- Thumbnails -->
    {%- if product.media.size > 1 -%}
    <div class="barista-gallery__thumbs" role="list">
      {%- for media in product.media limit: 4 -%}
      <button
        class="barista-gallery__thumb {% if forloop.first %}is-active{% endif %}"
        data-media-src="{{ media | image_url: width: 800 }}"
        data-media-alt="{{ media.alt | escape }}"
        aria-label="Produktbild {{ forloop.index }}"
        role="listitem"
      >
        <img
          src="{{ media | image_url: width: 130 }}"
          alt="{{ media.alt | escape }}"
          width="65"
          height="65"
          loading="lazy"
        >
      </button>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>

  <!-- ═══════════════════════════════════════════════
       BUY BLOCK (RIGHT)
       ═══════════════════════════════════════════════ -->
  <div class="barista-buyblock">

    <!-- Category label -->
    <p class="barista-cat-label" aria-label="Produktkategorie">
      {{- category_label -}}
    </p>

    <!-- Product title -->
    <h1 class="barista-title">{{ product.title }}</h1>

    <!-- Short description -->
    <p class="barista-desc">{{ short_desc }}</p>

    <!-- Tasting Notes Tags -->
    {%- unless tasting_notes == '' -%}
    <div class="barista-tasting-notes" aria-label="Geschmacksrichtungen">
      {%- assign notes_arr = tasting_notes | split: ',' -%}
      {%- for note in notes_arr -%}
        <span class="barista-tag">{{ note | strip }}</span>
      {%- endfor -%}
    </div>
    {%- endunless -%}

    <!-- Flavor Scales — matches existing .coffee-scale structure -->
    <div class="coffee-scale barista-scales" aria-label="Kaffeeprofil">

      <div class="scale-row">
        <span class="label barista-scale__label">Röstgrad</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ roast_level }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Röstgrad: {{ roast_level }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ roast_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>

      <div class="scale-row">
        <span class="label barista-scale__label">Stärke</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ strength }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Stärke: {{ strength }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ strength_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>

      <div class="scale-row">
        <span class="label barista-scale__label">Säure</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ acidity }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Säure: {{ acidity }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ acidity_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>

    </div>

    <!-- ─────────────────────────────────────────────
         CONFIGURATOR FORM
         ───────────────────────────────────────────── -->
    {%- form 'product', product, id: 'barista-product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}

      <input type="hidden" name="id" id="barista-variant-id" value="{{ variant_1kg.id }}">
      
      <!-- Subscription properties (Seal Subscriptions) -->
      <input type="hidden" id="barista-selling-plan" name="selling_plan" value="" disabled>

      <!-- ── 1. WEIGHT SELECTOR ── -->
      <div class="barista-group">
        <span class="barista-group__label">Gewicht wählen</span>
        <div class="barista-weight-options" role="radiogroup" aria-label="Gewicht auswählen">

          <!-- 250g -->
          <button
            type="button"
            class="barista-weight-btn"
            data-weight="250"
            data-variant-id="{{ variant_250.id }}"
            data-price="{{ variant_250.price }}"
            data-ppc="{{ ppc_250 }}"
            aria-pressed="false"
            aria-label="250 Gramm, {{ ppc_250 | money }} pro Tasse"
          >
            <span class="barista-weight-btn__size">250g</span>
            <span class="barista-weight-btn__sub">Perfekt zum Probieren</span>
            <span class="barista-weight-btn__ppc" id="ppc250Display">
              Nur {{ ppc_250 | money }} / Tasse
            </span>
          </button>

          <!-- 1kg — DEFAULT + BESTSELLER -->
          <button
            type="button"
            class="barista-weight-btn barista-weight-btn--featured is-active"
            data-weight="1000"
            data-variant-id="{{ variant_1kg.id }}"
            data-price="{{ variant_1kg.price }}"
            data-ppc="{{ ppc_1kg }}"
            aria-pressed="true"
            aria-label="1 Kilogramm, {{ ppc_1kg | money }} pro Tasse, Bestseller"
          >
            <span class="barista-weight-btn__badge">🔥 Bestseller</span>
            <span class="barista-weight-btn__size">1 kg</span>
            <span class="barista-weight-btn__sub">Bester Preis pro Tasse</span>
            <span class="barista-weight-btn__ppc" id="ppc1kgDisplay">
              Nur {{ ppc_1kg | money }} / Tasse
            </span>
          </button>

        </div>
      </div>

      <!-- ── 2. GRIND SELECTOR ── -->
      <div class="barista-group">
        <span class="barista-group__label">Mahlgrad für</span>
        <div class="barista-grind-options" role="radiogroup" aria-label="Mahlgrad auswählen">

          <button type="button" class="barista-grind-btn" data-grind="Siebträger" aria-pressed="false">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="8" width="16" height="12" rx="1" stroke="currentColor" stroke-width="1.8"/>
                <path d="M20 13h4v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <rect x="7" y="20" width="4" height="3" rx="0.5" fill="currentColor"/>
                <rect x="13" y="20" width="4" height="3" rx="0.5" fill="currentColor"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Siebträger</span>
          </button>

          <button type="button" class="barista-grind-btn" data-grind="Moka" aria-pressed="false">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 22V18c0-2 1-3 4-4V8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M10 8h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M18 8v6c-3 1-4 2-4 4v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M8 22h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <ellipse cx="14" cy="11" rx="2" ry="1.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Moka</span>
          </button>

          <button type="button" class="barista-grind-btn" data-grind="Filter" aria-pressed="false">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 8h14l-2 12H9L7 8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                <path d="M5 8h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M12 12v6M16 12v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Filter</span>
          </button>

          <button type="button" class="barista-grind-btn is-active" data-grind="Ganze Bohne" aria-pressed="true">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="14" cy="14" rx="7" ry="5" stroke="currentColor" stroke-width="1.8" transform="rotate(-30 14 14)"/>
                <path d="M14 9.5 Q16 14 14 18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Ganze Bohne</span>
          </button>

        </div>
      </div>

      <!-- ── 3. COFFEE NEED SLIDER ── -->
      <div class="barista-slider-box">
        <div class="barista-slider-box__header">
          <span class="barista-slider-box__title">Dein Kaffee-Bedarf</span>
          <span class="barista-slider-box__sub">Tassen pro Tag</span>
          <span class="barista-slider-box__count" id="cupsDisplay" aria-live="polite">2 Tassen</span>
        </div>
        <input
          type="range"
          id="cupsSlider"
          class="barista-slider"
          min="1"
          max="10"
          value="2"
          step="1"
          aria-label="Tassen pro Tag"
          aria-valuemin="1"
          aria-valuemax="10"
          aria-valuenow="2"
        >
        <!-- Smart recommendation box -->
        <div class="barista-recommendation" id="recommendationBox" aria-live="polite">
          <span class="barista-recommendation__text" id="recommendationText">
            Wir empfehlen: <strong>1 kg alle 5 Wochen</strong>
          </span>
          <span class="barista-recommendation__savings" id="savingsText">
            Du sparst <strong id="savingsAmount">0,00&nbsp;€</strong> pro Monat mit dem Abo
          </span>
        </div>
      </div>

      <!-- ── 4. PURCHASE TYPE TOGGLE ── -->
      <div class="barista-group">
        <div class="barista-purchase-options" role="radiogroup" aria-label="Kaufoption wählen">

          <!-- Einmalkauf -->
          <label class="barista-purchase-opt" id="optEinmal" aria-pressed="false">
            <input
              type="radio"
              name="purchase_type"
              value="einmal"
              class="barista-purchase-radio"
              aria-label="Einmalkauf, Direktversand"
            >
            <span class="barista-purchase-opt__radio"></span>
            <span class="barista-purchase-opt__content">
              <span class="barista-purchase-opt__title">Einmalkauf</span>
              <span class="barista-purchase-opt__sub">Direktversand</span>
            </span>
            <span class="barista-purchase-opt__price" id="priceEinmal">
              {{ variant_1kg.price | money }}
            </span>
          </label>

          <!-- Abo — PRESELECTED -->
          <label class="barista-purchase-opt barista-purchase-opt--abo is-active" id="optAbo" aria-pressed="true">
            <input
              type="radio"
              name="purchase_type"
              value="abo"
              class="barista-purchase-radio"
              checked
              aria-label="Abo-Lieferung, 10% sparen"
            >
            <span class="barista-purchase-opt__radio"></span>
            <span class="barista-purchase-opt__content">
              <span class="barista-purchase-opt__title">
                Abo-Lieferung
                <span class="barista-badge barista-badge--popular">Most Popular</span>
              </span>
              <span class="barista-purchase-opt__sub">Spare 10% bei jeder Sendung</span>
            </span>
            <span class="barista-purchase-opt__price barista-purchase-opt__price--abo" id="priceAbo">
              {{ variant_1kg.price | times: 0.9 | money }}
            </span>
          </label>

        </div>
      </div>

      <!-- ── 5. PRICE DISPLAY ── -->
      <div class="barista-price-row" aria-live="polite">
        <span class="barista-price-main" id="priceMain">{{ variant_1kg.price | money }}</span>
        <span class="barista-price-per-kg" id="pricePerKg">
          {%- assign price_per_kg = variant_1kg.price | times: 100 -%}
          {{ variant_1kg.price | money }} / kg inkl. MwSt.
        </span>
        <span class="barista-price-old" id="priceOld" style="display:none;"></span>
      </div>

      <!-- ── 6. ADD TO CART BUTTON ── -->
      <button
        type="submit"
        class="barista-atc-btn"
        id="barista-atc-main"
        aria-label="In den Warenkorb legen"
      >
        <svg class="barista-atc-btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
          <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2"/>
        </svg>
        In den Warenkorb
      </button>
      <p class="barista-atc-microcopy" id="atcMicrocopy">Spare heute 10% mit dem Abo</p>

      <!-- ── Trust Micro-Bar ── -->
      <div class="barista-trust-bar" aria-label="Vertrauenssignale">
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          Frisch geröstet
        </span>
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          Versand in 1–3 Tagen
        </span>
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          Ab 39€ kostenlos
        </span>
      </div>

    {%- endform -%}
  </div><!-- /barista-buyblock -->

</section><!-- /barista-hero -->


<!-- ═══════════════════════════════════════════════
     STICKY MOBILE ATC BAR
     ═══════════════════════════════════════════════ -->
<div class="barista-sticky-atc" id="barista-sticky-atc" role="region" aria-label="Schnellkauf" hidden>
  <div class="barista-sticky-atc__info">
    <span class="barista-sticky-atc__title">{{ product.title }}</span>
    <span class="barista-sticky-atc__meta" id="stickyMeta">1 kg · Ganze Bohne</span>
  </div>
  <div class="barista-sticky-atc__right">
    <span class="barista-sticky-atc__price" id="stickyPrice">{{ variant_1kg.price | money }}</span>
    <button
      type="button"
      class="barista-sticky-atc__btn"
      id="barista-sticky-btn"
      aria-label="In den Warenkorb legen"
    >
      In den Warenkorb
    </button>
  </div>
</div>


<!-- ═══════════════════════════════════════════════
     SCOPED CSS
     ═══════════════════════════════════════════════ -->
<style>
/* ── DESIGN TOKENS ── */
.barista-hero,
.barista-sticky-atc {
  --db-red:    #E23528;
  --db-red-hover: #c9291e;
  --db-black:  #00090B;
  --db-crema:  #EFDFD3;
  --db-green:  #759769;
  --db-mud:    #7B5D4D;
  --db-surface:      #fff8f5;
  --db-surface-low:  #fff1e7;
  --db-surface-mid:  #fbebdf;
  --db-surface-high: #f5e5d9;
  --db-surface-top:  #f0e0d4;
  --db-outline:      #906f6a;
  --db-radius: 2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── HERO LAYOUT ── */
.barista-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 90vh;
  background: var(--db-surface);
  position: relative;
}

/* ── GALLERY ── */
.barista-gallery {
  background: var(--db-surface-low);
  padding: 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.barista-gallery__strip {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6px;
  background: var(--category-color, var(--db-red));
}

.barista-gallery__main {
  width: 100%;
  max-width: 440px;
  aspect-ratio: 3/4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  overflow: hidden;
  border-radius: var(--db-radius);
  background: var(--db-surface-mid);
}

.barista-gallery__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.25s ease;
}

.barista-gallery__img.is-loading {
  opacity: 0;
}

.barista-gallery__placeholder {
  color: var(--db-outline);
  font-family: var(--db-font-body);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.barista-gallery__thumbs {
  display: flex;
  gap: 8px;
}

.barista-gallery__thumb {
  width: 65px;
  height: 65px;
  padding: 3px;
  border: 2px solid transparent;
  border-radius: var(--db-radius);
  background: var(--db-surface-high);
  cursor: pointer;
  transition: border-color 0.2s;
  overflow: hidden;
}

.barista-gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--db-radius);
}

.barista-gallery__thumb.is-active,
.barista-gallery__thumb:hover {
  border-color: var(--db-black);
}

/* ── BUY BLOCK ── */
.barista-buyblock {
  padding: 3.5rem 3rem 3rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow-y: auto;
  max-height: 100vh;
  background: var(--db-surface);
}

/* Category label */
.barista-cat-label {
  font-family: var(--db-font-body);
  font-size: 0.72rem;
  font-weight: 700;
