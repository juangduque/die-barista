{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 01: HERO + BUY BLOCK
  File: sections/barista-hero-buyblock.liquid
  
  Features:
  - Split layout: Product gallery (left) + Buy block (right) — Figma 18:95
  - Weight selector: 250g / 500g (optional) / 1kg
  - Grind selector: Ganze Bohne / Gemahlen
  - Purchase: segmented Einmalkauf / Abo (−% badge)
  - Dynamic pricing with price-per-cup display
  - Seal Subscriptions compatible
  - Mobile sticky ATC bar
  - Tasting tags, flavor scales, trust micro-bar
  - Category color strip (per product: Espresso=Red, Crema=Crema, Green=Wechselnd)
  ============================================================
{% endcomment %}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  
  comment
    Resolve category color from product tags or metafield
    Tag: "kategorie-espresso" → red, "kategorie-crema" → crema, "kategorie-wechselnd" → green
  endcomment
  assign category_color = '#E23528'
  if product.tags contains 'kategorie-crema'
    assign category_color = '#EFDFD3'
  elsif product.tags contains 'kategorie-wechselnd'
    assign category_color = '#759769'
  endif

  comment
    Metafields used:
    product.metafields.coffee_attributes.roasting_level → integer 0–6
    product.metafields.coffee_attributes.acid_level     → integer 0–6
    product.metafields.coffee_attributes.strength_level → integer 0–6
    product.metafields.barista.tasting_notes            → comma-separated string e.g. "Schokolade, Nuss, Karamell"
    product.metafields.barista.category_label           → string e.g. "Espresso · Ganze Bohne"
    product.metafields.barista.short_desc               → rich text / multi-line short copy
    product.metafields.barista.headline                 → optional shop headline (e.g. BRAZIL SANTOS - ESPRESSO); falls back to product.title
  endcomment
  assign roast_level    = product.metafields.coffee_attributes.roasting_level.value | default: 4
  assign acidity        = product.metafields.coffee_attributes.acid_level.value | default: 3
  assign strength       = product.metafields.coffee_attributes.strength_level.value | default: 2
  assign tasting_notes  = product.metafields.barista.tasting_notes | default: ''
  assign category_label = product.metafields.barista.category_label | default: 'Espresso · Ganze Bohne'
  assign hero_headline = product.title
  if product.metafields.barista.headline != blank
    assign hero_headline = product.metafields.barista.headline.value
  endif

  # Scale 0–6 → percentage (divide by 6, not 5)
  assign roast_pct    = roast_level | times: 100 | divided_by: 6
  assign strength_pct = strength | times: 100 | divided_by: 6
  assign acidity_pct  = acidity | times: 100 | divided_by: 6

  comment
    Identify 250g / 500g / 1kg variants by title or option keywords
  endcomment
  assign variant_250 = nil
  assign variant_500 = nil
  assign variant_1kg = nil
  assign show_weight_500 = false
  for v in product.variants
    if v.title contains '250' or v.option1 contains '250' or v.option2 contains '250'
      if variant_250 == nil
        assign variant_250 = v
      endif
    endif
    if v.title contains '500g' or v.title contains '500 g' or v.option1 contains '500g' or v.option1 contains '500 g' or v.option2 contains '500g' or v.option2 contains '500 g' or v.title contains '0,5 kg' or v.title contains '0.5 kg'
      if variant_500 == nil
        assign variant_500 = v
      endif
    endif
    if v.title contains '1 kg' or v.title contains '1kg' or v.option1 contains '1 kg' or v.option1 contains '1kg' or v.option2 contains '1 kg' or v.option2 contains '1kg'
      if variant_1kg == nil
        assign variant_1kg = v
      endif
    endif
  endfor

  if variant_250 == nil
    assign variant_250 = product.variants[0]
  endif
  if variant_1kg == nil
    assign variant_1kg = product.variants[1] | default: product.variants[0]
  endif
  if variant_500 != nil and variant_500.id != variant_250.id and variant_500.id != variant_1kg.id
    assign show_weight_500 = true
  endif

  comment
    Price-per-cup: 1 cup ≈ 7g (250g → ~35, 500g → ~71, 1kg → ~142)
  endcomment
  assign cups_250  = 35
  assign cups_500  = 71
  assign cups_1kg  = 142
  assign price_250_cents = variant_250.price
  assign price_500_cents = 0
  if variant_500 != nil
    assign price_500_cents = variant_500.price
  endif
  assign price_1kg_cents = variant_1kg.price
  assign ppc_250 = price_250_cents | divided_by: cups_250
  assign ppc_500 = 0
  if show_weight_500
    assign ppc_500 = price_500_cents | divided_by: cups_500
  endif
  assign ppc_1kg = price_1kg_cents | divided_by: cups_1kg

  assign abo_discount_pct = section.settings.abo_discount_pct | default: 10
  assign abo_price_num = 100 | minus: abo_discount_pct
-%}

{{ 'barista-hero-buyblock.css' | asset_url | stylesheet_tag }}

<section 
  class="barista-hero" 
  id="barista-hero"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-variant-250="{{ variant_250.id }}"
  data-variant-500="{% if show_weight_500 %}{{ variant_500.id }}{% endif %}"
  data-variant-1kg="{{ variant_1kg.id }}"
  data-price-250="{{ variant_250.price }}"
  data-price-500="{% if show_weight_500 %}{{ variant_500.price }}{% else %}0{% endif %}"
  data-price-1kg="{{ variant_1kg.price }}"
  data-ppc-250="{{ ppc_250 }}"
  data-ppc-500="{% if show_weight_500 %}{{ ppc_500 }}{% else %}0{% endif %}"
  data-ppc-1kg="{{ ppc_1kg }}"
  data-show-weight-500="{% if show_weight_500 %}true{% else %}false{% endif %}"
  data-abo-price-num="{{ abo_price_num }}"
  data-selling-plan-id="{{ section.settings.selling_plan_id }}"
  style="--category-color: {{ category_color }};"
>

  <!-- ═══════════════════════════════════════════════
       GALLERY (LEFT)
       ═══════════════════════════════════════════════ -->
  <div class="barista-gallery">
    <!-- Main image -->
    <div class="barista-gallery__main" id="galleryMain">
      {%- if product.featured_media -%}
        <img
          src="{{ product.featured_media | image_url: width: 800 }}"
          alt="{{ product.featured_media.alt | escape }}"
          width="800"
          height="{{ 800 | divided_by: product.featured_media.aspect_ratio | round }}"
          loading="eager"
          fetchpriority="high"
          class="barista-gallery__img"
          id="galleryMainImg"
        >
      {%- else -%}
        <div class="barista-gallery__placeholder">Produktbild</div>
      {%- endif -%}
    </div>

    <!-- Thumbnails -->
    {%- if product.media.size > 1 -%}
    <div class="barista-gallery__thumbs" role="list">
      {%- for media in product.media limit: 4 -%}
      <button
        class="barista-gallery__thumb {% if forloop.first %}is-active{% endif %}"
        data-media-src="{{ media | image_url: width: 800 }}"
        data-media-alt="{{ media.alt | escape }}"
        aria-label="Produktbild {{ forloop.index }}"
        role="listitem"
      >
        <img
          src="{{ media | image_url: width: 182 }}"
          alt="{{ media.alt | escape }}"
          width="91"
          height="91"
          loading="lazy"
        >
      </button>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>

  <!-- ═══════════════════════════════════════════════
       BUY BLOCK (RIGHT)
       ═══════════════════════════════════════════════ -->
  <div class="barista-buyblock">

    <!-- Category label -->
    <p class="barista-cat-label" aria-label="Produktkategorie">
      {{- category_label -}}
    </p>

    <!-- Product title (metafield barista.headline overrides admin title when set) -->
    <h1 class="barista-title">{{ hero_headline }}</h1>

    <!-- Short description — avoid duplicate titles leaking from RTE (extra h1/h2) -->
    <div class="barista-desc rte">
      {%- if product.metafields.barista.short_desc != blank -%}
        {{ product.metafields.barista.short_desc | metafield_tag }}
      {%- elsif product.description != blank -%}
        {{ product.description }}
      {%- endif -%}
    </div>

    {%- liquid
      assign hero_badge_count = 0
      for block in section.blocks
        if block.type == 'badge' and block.settings.label != blank
          assign hero_badge_count = hero_badge_count | plus: 1
        endif
      endfor
    -%}
    {%- if hero_badge_count > 0 -%}
      <div
        class="barista-hero-badges"
        role="list"
        aria-label="{{ section.settings.badges_aria_label | default: 'Produkt-Hinweise' | escape }}"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'badge' -%}
              {%- if block.settings.label != blank -%}
                {%- liquid
                  assign b_style = block.settings.style | default: 'neutral'
                  if b_style != 'neutral' and b_style != 'outline' and b_style != 'accent' and b_style != 'dark'
                    assign b_style = 'neutral'
                  endif
                -%}
                {%- if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    class="barista-hero-badge barista-hero-badge--{{ b_style }}"
                    {{ block.shopify_attributes }}
                    role="listitem"
                  >
                    {{- block.settings.label | escape -}}
                  </a>
                {%- else -%}
                  <span
                    class="barista-hero-badge barista-hero-badge--{{ b_style }}"
                    {{ block.shopify_attributes }}
                    role="listitem"
                  >
                    {{- block.settings.label | escape -}}
                  </span>
                {%- endif -%}
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- Tasting Notes Tags -->
    {%- unless tasting_notes == '' -%}
    <div class="barista-tasting-notes" aria-label="Geschmacksrichtungen">
      {%- assign notes_arr = tasting_notes | split: ',' -%}
      {%- for note in notes_arr -%}
        <span class="barista-tag">{{ note | strip }}</span>
      {%- endfor -%}
    </div>
    {%- endunless -%}

    <!-- Flavor scales — Figma 18:124: three columns in one row -->
    <div class="coffee-scale barista-scales barista-scales--row" aria-label="Kaffeeprofil">
      <div class="barista-scale-col">
        <span class="label barista-scale__label">Röstgrad</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ roast_level }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Röstgrad: {{ roast_level }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ roast_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>
      <div class="barista-scale-col">
        <span class="label barista-scale__label">Stärke</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ strength }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Stärke: {{ strength }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ strength_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>
      <div class="barista-scale-col">
        <span class="label barista-scale__label">Säure</span>
        <div class="scale-container">
          <div class="scale-bar barista-scale__track"
               role="progressbar"
               aria-valuenow="{{ acidity }}"
               aria-valuemin="0"
               aria-valuemax="6"
               aria-label="Säure: {{ acidity }} von 6">
            <div class="scale-fill barista-scale__fill" style="width: {{ acidity_pct }}%; background-color: var(--db-black, #00090B);"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─────────────────────────────────────────────
         CONFIGURATOR FORM
         ───────────────────────────────────────────── -->
    {%- form 'product', product, id: 'barista-product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}

      <input type="hidden" name="id" id="barista-variant-id" value="{{ variant_250.id }}">
      <input type="hidden" name="properties[Mahlgrad]" id="barista-grind-prop" value="Ganze Bohne">
      
      <!-- Subscription properties (Seal Subscriptions) -->
      <input type="hidden" id="barista-selling-plan" name="selling_plan" value="" disabled>

      <!-- ── 1. WEIGHT SELECTOR (Figma 18:141) ── -->
      <div class="barista-group">
        <span class="barista-group__label">Gewicht</span>
        <div class="barista-weight-options" role="radiogroup" aria-label="Gewicht auswählen">

          <button
            type="button"
            class="barista-weight-btn is-active"
            data-weight="250"
            data-variant-id="{{ variant_250.id }}"
            data-price="{{ variant_250.price }}"
            data-ppc="{{ ppc_250 }}"
            aria-pressed="true"
            aria-label="250 Gramm, {{ ppc_250 | money }} pro Tasse"
          >
            <span class="barista-weight-btn__size">250g</span>
            <span class="barista-weight-btn__ppc" id="ppc250Display">{{ ppc_250 | money }} / Tasse</span>
          </button>

          {%- if show_weight_500 -%}
          <button
            type="button"
            class="barista-weight-btn"
            data-weight="500"
            data-variant-id="{{ variant_500.id }}"
            data-price="{{ variant_500.price }}"
            data-ppc="{{ ppc_500 }}"
            aria-pressed="false"
            aria-label="500 Gramm, {{ ppc_500 | money }} pro Tasse"
          >
            <span class="barista-weight-btn__size">500g</span>
            <span class="barista-weight-btn__ppc" id="ppc500Display">{{ ppc_500 | money }} / Tasse</span>
          </button>
          {%- endif -%}

          <button
            type="button"
            class="barista-weight-btn{% unless show_weight_500 %} barista-weight-btn--grow{% endunless %}"
            data-weight="1000"
            data-variant-id="{{ variant_1kg.id }}"
            data-price="{{ variant_1kg.price }}"
            data-ppc="{{ ppc_1kg }}"
            aria-pressed="false"
            aria-label="1 Kilogramm, {{ ppc_1kg | money }} pro Tasse"
          >
            <span class="barista-weight-btn__size">1 kg</span>
            <span class="barista-weight-btn__ppc" id="ppc1kgDisplay">{{ ppc_1kg | money }} / Tasse</span>
          </button>

        </div>
      </div>

      <!-- ── 2. GRIND SELECTOR (Figma 18:158 — Ganze Bohne / Gemahlen) ── -->
      <div class="barista-group">
        <span class="barista-group__label">Mahlgrad</span>
        <div class="barista-grind-options barista-grind-options--two" role="radiogroup" aria-label="Mahlgrad auswählen">

          <button type="button" class="barista-grind-btn is-active" data-grind="Ganze Bohne" aria-pressed="true">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="14" cy="14" rx="7" ry="5" stroke="currentColor" stroke-width="1.8" transform="rotate(-30 14 14)"/>
                <path d="M14 9.5 Q16 14 14 18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Ganze Bohne</span>
          </button>

          <button type="button" class="barista-grind-btn" data-grind="Gemahlen" aria-pressed="false">
            <span class="barista-grind-btn__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="6" y="5" width="16" height="10" rx="1" stroke="currentColor" stroke-width="1.8"/>
                <path d="M9 15v6M14 15v6M19 15v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M7 22h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <circle cx="14" cy="10" r="2" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </span>
            <span class="barista-grind-btn__label">Gemahlen</span>
          </button>

        </div>
      </div>

      <!-- ── 3. PURCHASE SEGMENTED TOGGLE (Figma 18:169) ── -->
      <div class="barista-group barista-group--purchase">
        <div class="barista-purchase-segment" role="radiogroup" aria-label="Kaufoption wählen">
          <label class="barista-purchase-segment__opt is-active" id="optEinmalSeg">
            <input
              type="radio"
              name="purchase_type"
              value="einmal"
              class="barista-purchase-radio"
              checked
              aria-label="Einmalkauf"
            >
            <span class="barista-purchase-segment__label">Einmalkauf</span>
          </label>
          <label class="barista-purchase-segment__opt" id="optAboSeg">
            <input
              type="radio"
              name="purchase_type"
              value="abo"
              class="barista-purchase-radio"
              aria-label="Abo, {{ abo_discount_pct }} Prozent Rabatt"
            >
            <span class="barista-purchase-segment__label barista-purchase-segment__label--abo">
              <span>Abo</span>
              <span class="barista-purchase-segment__badge">−{{ abo_discount_pct }}%</span>
            </span>
          </label>
        </div>
      </div>

      <!-- ── 4. PRICE DISPLAY ── -->
      <div class="barista-price-row" aria-live="polite">
        <span class="barista-price-main" id="priceMain">{{ variant_250.price | money }}</span>
        <span class="barista-price-per-kg" id="pricePerKg">
          {{ variant_250.price | times: 4 | money }} / kg inkl. MwSt.
        </span>
        <span class="barista-price-old" id="priceOld" style="display:none;"></span>
      </div>

      <!-- ── 6. ADD TO CART BUTTON ── -->
      <button
        type="submit"
        class="barista-atc-btn"
        id="barista-atc-main"
        aria-label="In den Warenkorb legen"
      >
        <svg class="barista-atc-btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
          <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2"/>
        </svg>
        In den Warenkorb
      </button>
      <p class="barista-atc-microcopy" id="atcMicrocopy">Oder {{ abo_discount_pct }}% sparen mit Abo</p>

      <!-- ── Trust Micro-Bar (Figma 18:183) ── -->
      <div class="barista-trust-bar" aria-label="Vertrauenssignale">
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          {{ section.settings.trust_item_1 }}
        </span>
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          {{ section.settings.trust_item_2 }}
        </span>
        <span class="barista-trust-item">
          <span class="barista-trust-item__dot barista-trust-item__dot--green" aria-hidden="true"></span>
          {{ section.settings.trust_item_3 }}
        </span>
      </div>

    {%- endform -%}
  </div><!-- /barista-buyblock -->

</section><!-- /barista-hero -->


<!-- ═══════════════════════════════════════════════
     STICKY MOBILE ATC BAR
     ═══════════════════════════════════════════════ -->
<div class="barista-sticky-atc" id="barista-sticky-atc" role="region" aria-label="Schnellkauf" hidden>
  <div class="barista-sticky-atc__info">
    <span class="barista-sticky-atc__title">{{ hero_headline }}</span>
    <span class="barista-sticky-atc__meta" id="stickyMeta">250 g · Ganze Bohne</span>
  </div>
  <div class="barista-sticky-atc__right">
    <span class="barista-sticky-atc__price" id="stickyPrice">{{ variant_250.price | money }}</span>
    <button
      type="button"
      class="barista-sticky-atc__btn"
      id="barista-sticky-btn"
      aria-label="In den Warenkorb legen"
    >
      In den Warenkorb
    </button>
  </div>
</div>


<!-- ═══════════════════════════════════════════════
     SCOPED CSS
     ═══════════════════════════════════════════════ -->
<style>
/* ── DESIGN TOKENS ── */
.barista-hero,
.barista-sticky-atc {
  --db-red:    #E23528;
  --db-red-hover: #c9291e;
  --db-black:  #00090B;
  --db-crema:  #EFDFD3;
  --db-green:  #759769;
  --db-mud:    #7B5D4D;
  --db-surface:      #fff8f5;
  --db-surface-low:  #fff1e7;
  --db-surface-mid:  #fbebdf;
  --db-surface-high: #f5e5d9;
  --db-surface-top:  #f0e0d4;
  --db-outline:      #906f6a;
  --db-radius: 2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── HERO LAYOUT — Figma 18:95 two-column frame ── */
.barista-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  min-height: min(100vh, 64rem);
  max-width: 100%;
  background: var(--db-surface);
  position: relative;
}

/* ── GALLERY — Figma 18:96 (#fff1e7, px-48 py ~11.75rem) ── */
.barista-gallery {
  background: #fff1e7;
  padding: clamp(4rem, 12vw, 11.75rem) 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.barista-gallery__main {
  width: 100%;
  max-width: 31.25rem;
  aspect-ratio: 500 / 721;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  overflow: hidden;
  border-radius: var(--db-radius);
  background: var(--db-surface-mid);
}

.barista-gallery__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.25s ease;
}

.barista-gallery__img.is-loading {
  opacity: 0;
}

.barista-gallery__placeholder {
  color: var(--db-outline);
  font-family: var(--db-font-body);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.barista-gallery__thumbs {
  display: flex;
  gap: 0.65rem;
  flex-wrap: wrap;
  justify-content: center;
}

.barista-gallery__thumb {
  width: 5.7rem;
  height: 5.7rem;
  padding: 2px;
  border: 2px solid transparent;
  border-radius: var(--db-radius);
  background: var(--db-surface-high);
  cursor: pointer;
  transition: border-color 0.2s;
  overflow: hidden;
}

.barista-gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--db-radius);
}

.barista-gallery__thumb.is-active,
.barista-gallery__thumb:hover {
  border-color: #00090b;
}

