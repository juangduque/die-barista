     JAVASCRIPT
     ═══════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  /* ─ State ─ */
  const state = {
    weightGrams:   1000,
    grind:         'Ganze Bohne',
    purchaseType:  'abo',
    cups:          2,
    variantId:     null,
    prices: {
      250:  parseInt(document.querySelector('[data-variant-250]')?.dataset.price250 || '0'),
      1000: parseInt(document.querySelector('[data-variant-1kg]')?.dataset.price1kg || '0')
    }
  };

  /* ─ Read data from section element ─ */
  const sectionEl  = document.getElementById('barista-hero');
  if (!sectionEl) return;

  const variantId250  = sectionEl.dataset.variant250;
  const variantId1kg  = sectionEl.dataset.variant1kg;
  const rawPrice250   = parseInt(sectionEl.dataset.price250  || 0);
  const rawPrice1kg   = parseInt(sectionEl.dataset.price1kg  || 0);
  const rawPpc250     = parseInt(sectionEl.dataset.ppc250    || 0);
  const rawPpc1kg     = parseInt(sectionEl.dataset.ppc1kg    || 0);

  state.prices[250]  = rawPrice250;
  state.prices[1000] = rawPrice1kg;
  state.variantId    = variantId1kg;

  /* ─ Money formatter ─ */
  function formatMoney(cents) {
    return (cents / 100).toLocaleString('de-DE', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }) + '\u00a0€';
  }

  /* ─ Animate number (for savings count-up) ─ */
  function animateNumber(el, from, to, suffix, duration) {
    const start = performance.now();
    function step(now) {
      const progress = Math.min((now - start) / duration, 1);
      const val = from + (to - from) * easeOut(progress);
      el.textContent = formatMoney(Math.round(val)) + (suffix || '');
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  /* ─ Update price display ─ */
  function updatePrices() {
    const base = state.prices[state.weightGrams] || 0;
    const isAbo = state.purchaseType === 'abo';
    const displayed = isAbo ? Math.round(base * 0.9) : base;
    const oldPrice  = isAbo ? base : null;
    const ppcCents  = state.weightGrams === 250 ? rawPpc250 : rawPpc1kg;
    const ppcDisp   = isAbo ? Math.round(ppcCents * 0.9) : ppcCents;
    const pricePerKgCents = state.weightGrams === 1000 ? displayed : displayed * 4;

    // Main price
    const priceMainEl = document.getElementById('priceMain');
    if (priceMainEl) priceMainEl.textContent = formatMoney(displayed);

    // Per kg
    const pricePerKgEl = document.getElementById('pricePerKg');
    if (pricePerKgEl) pricePerKgEl.textContent = formatMoney(pricePerKgCents) + ' / kg inkl. MwSt.';

    // Old price (crossed out original when abo active)
    const priceOldEl = document.getElementById('priceOld');
    if (priceOldEl) {
      if (oldPrice) {
        priceOldEl.textContent = formatMoney(oldPrice);
        priceOldEl.style.display = '';
      } else {
        priceOldEl.style.display = 'none';
      }
    }

    // Abo price in option row
    const priceAboEl = document.getElementById('priceAbo');
    if (priceAboEl) priceAboEl.textContent = formatMoney(Math.round(base * 0.9));

    // Einmal price in option row
    const priceEinmalEl = document.getElementById('priceEinmal');
    if (priceEinmalEl) priceEinmalEl.textContent = formatMoney(base);

    // Sticky price
    const stickyPriceEl = document.getElementById('stickyPrice');
    if (stickyPriceEl) stickyPriceEl.textContent = formatMoney(displayed);

    // Microcopy
    const microcopyEl = document.getElementById('atcMicrocopy');
    if (microcopyEl) {
      microcopyEl.textContent = isAbo
        ? 'Spare heute 10% mit dem Abo'
        : 'Oder: 10% sparen mit Abo-Lieferung';
    }
  }

  /* ─ Update recommendation box ─ */
  function updateRecommendation() {
    const cups = state.cups;
    // Monthly usage: cups × 7g × 30 days
    const monthlyGrams = cups * 7 * 30;
    // Bias toward 1kg
    let recKg = 1;
    let recWeeks = Math.max(1, Math.round(1000 / (cups * 7 * 7)));

    const countEl  = document.getElementById('cupsDisplay');
    const textEl   = document.getElementById('recommendationText');
    const savingsEl = document.getElementById('savingsAmount');

    if (countEl) countEl.textContent = cups + ' Tasse' + (cups !== 1 ? 'n' : '');

    if (textEl) {
      textEl.innerHTML = 'Wir empfehlen: <strong>1 kg alle ' + recWeeks + ' Woche' + (recWeeks !== 1 ? 'n' : '') + '</strong>';
    }

    // Monthly savings with abo vs one-time (based on 1kg price)
    const monthlyPurchases = 4 / recWeeks;
    const monthlyCost      = state.prices[1000] * monthlyPurchases;
    const monthlySavings   = Math.round(monthlyCost * 0.1);

    if (savingsEl) {
      animateNumber(savingsEl, 0, monthlySavings, '', 400);
    }

    // Trigger animation on box
    const boxEl = document.getElementById('recommendationBox');
    if (boxEl) {
      boxEl.style.animation = 'none';
      boxEl.offsetHeight; // force reflow
      boxEl.style.animation = '';
    }
  }

  /* ─ Update variant input ─ */
  function updateVariant() {
    const variantInput = document.getElementById('barista-variant-id');
    if (variantInput) {
      variantInput.value = state.weightGrams === 250 ? variantId250 : variantId1kg;
    }
    state.variantId = state.weightGrams === 250 ? variantId250 : variantId1kg;

    // Update selling plan field
    const sellingPlanInput = document.getElementById('barista-selling-plan');
    if (sellingPlanInput) {
      if (state.purchaseType === 'abo') {
        sellingPlanInput.disabled = false;
        // Seal Subscriptions selling plan discovery:
        // The selling plan ID needs to match what Seal Subscriptions creates.
        // We emit a custom event that Seal Subscriptions can listen to,
        // or fall back to a data attribute on the section element.
        const sellingPlanId = sectionEl.dataset.sellingPlanId || '';
        sellingPlanInput.value = sellingPlanId;
      } else {
        sellingPlanInput.disabled = true;
        sellingPlanInput.value = '';
      }
    }
  }

  /* ─ Update sticky meta ─ */
  function updateStickyMeta() {
    const metaEl = document.getElementById('stickyMeta');
    if (!metaEl) return;
    const weightLabel = state.weightGrams === 250 ? '250 g' : '1 kg';
    metaEl.textContent = weightLabel + ' · ' + state.grind;
  }

  /* ─ Full state sync ─ */
  function syncAll() {
    updateVariant();
    updatePrices();
    updateRecommendation();
    updateStickyMeta();
  }

  /* ─ Weight buttons ─ */
  document.querySelectorAll('.barista-weight-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.barista-weight-btn').forEach(function(b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
      state.weightGrams = parseInt(btn.dataset.weight);
      syncAll();
    });
  });

  /* ─ Grind buttons ─ */
  document.querySelectorAll('.barista-grind-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.barista-grind-btn').forEach(function(b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
      state.grind = btn.dataset.grind;
      updateStickyMeta();
    });
  });

  /* ─ Cups slider ─ */
  const slider = document.getElementById('cupsSlider');
  if (slider) {
    slider.addEventListener('input', function() {
      state.cups = parseInt(this.value);
      this.setAttribute('aria-valuenow', state.cups);
      updateRecommendation();
    });
  }

  /* ─ Purchase type ─ */
  document.querySelectorAll('.barista-purchase-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      const val = this.value;
      state.purchaseType = val;

      document.querySelectorAll('.barista-purchase-opt').forEach(function(opt) {
        opt.classList.remove('is-active');
        opt.setAttribute('aria-pressed', 'false');
      });

      const parentOpt = this.closest('.barista-purchase-opt');
      if (parentOpt) {
        parentOpt.classList.add('is-active');
        parentOpt.setAttribute('aria-pressed', 'true');
      }

      updateVariant();
      updatePrices();
    });
  });

  // Make entire label clickable for purchase options
  document.querySelectorAll('.barista-purchase-opt').forEach(function(opt) {
    opt.addEventListener('click', function() {
      const radio = opt.querySelector('.barista-purchase-radio');
      if (radio && !radio.checked) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  /* ─ Gallery thumbnails ─ */
  document.querySelectorAll('.barista-gallery__thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      document.querySelectorAll('.barista-gallery__thumb').forEach(function(t) {
        t.classList.remove('is-active');
      });
      thumb.classList.add('is-active');

      const mainImg = document.getElementById('galleryMainImg');
      if (mainImg && thumb.dataset.mediaSrc) {
        mainImg.classList.add('is-loading');
        mainImg.onload = function() { mainImg.classList.remove('is-loading'); };
        mainImg.src = thumb.dataset.mediaSrc;
        mainImg.alt = thumb.dataset.mediaAlt || '';
      }
    });
  });

  /* ─ Sticky ATC bar (mobile only) ─ */
  const stickyBar = document.getElementById('barista-sticky-atc');
  const heroSection = document.getElementById('barista-hero');

  if (stickyBar && heroSection && window.innerWidth <= 768) {
    stickyBar.removeAttribute('hidden');

    const observer = new IntersectionObserver(function(entries) {
      const atcBtn = document.getElementById('barista-atc-main');
      if (atcBtn) {
        const atcRect = atcBtn.getBoundingClientRect();
        if (atcRect.bottom < 0) {
          stickyBar.classList.add('is-visible');
        } else {
          stickyBar.classList.remove('is-visible');
        }
      }
    }, { threshold: 0 });

    observer.observe(heroSection);

    // Sticky ATC submit
    const stickyBtn = document.getElementById('barista-sticky-btn');
    if (stickyBtn) {
      stickyBtn.addEventListener('click', function() {
        const form = document.getElementById('barista-product-form');
        if (form) form.submit();
      });
    }
  }

  /* ─ Initial sync ─ */
  syncAll();

  // Preselect Abo radio
  const aboRadio = document.querySelector('.barista-purchase-radio[value="abo"]');
  if (aboRadio) {
    aboRadio.checked = true;
    aboRadio.dispatchEvent(new Event('change', { bubbles: true }));
  }

})();
</script>


