<script src="{{ 'information-bar.js' | asset_url }}" defer="defer"></script>

{{ 'section-information-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
	{% render 'section-padding' %}
	{% render 'section-margin' %}
{%- endstyle -%}

<div class="information-bar ">
	<div class="container">
		<div class=" swiper swiper--information-bar">
			<div class="information-bar__wrapper swiper-wrapper section-{{ section.id }}-padding {% if section.settings.border_top %}information-bar__border-top{% endif %} {% if section.settings.border_bottom %}information-bar__border-bottom{% endif %}">
				{%- for block in section.blocks -%}
					{%- if block.settings.text != blank -%}
						<a
							class="information-bar__link swiper-slide"
							{% if block.settings.link.url != blank %}
								href="{{ block.settings.link }}"
							{% endif %}
							{% if block.settings.link.url == blank %}
								aria-disabled="true"
							{% endif %}
							{{ block.shopify_attributes }}
						>
							<div class="information-bar__inner">
								<div class="information-bar__image">
									{%- if block.settings.icon != 'none' -%}
										<div class="icon-pack__image-wrapper icon-pack__image-wrapper--icon icon-pack__image-wrapper--{{- section.settings.image_width }}">
											{% render 'icon-pack', icon: block.settings.icon %}
										</div>
									{%- elsif block.settings.image != blank -%}
										<div class="icon-pack__image-wrapper icon-pack__image-wrapper--{{ section.settings.image_width }}">
											{%- assign height = block.settings.image.height -%}
											{%- assign width = block.settings.image.width -%}
											{%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}
											{%- capture style -%}object-fit: {{ section.settings.object_fit }};{%- endcapture -%}
											{{
												block.settings.image
												| image_url: width: 710
												| image_tag:
													loading: 'lazy',
													sizes: sizes,
													widths: '275, 550, 750',
													height: height,
													width: width,
													style: style
											}}
											{%- if block.settings.image_2 != blank -%}
												{%- assign height = block.settings.image_2.height -%}
												{%- assign width = block.settings.image_2.width -%}
												{%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}
												{%- capture style -%}object-fit: {{ section.settings.object_fit }};{%- endcapture -%}
												{{
													block.settings.image_2
													| image_url: width: 710
													| image_tag:
														loading: 'lazy',
														sizes: sizes,
														widths: '275, 550, 750',
														height: height,
														width: width,
														style: style
												}}
											{% endif %}
										</div>
									{%- endif -%}
								</div>
								<p class="information-bar__message link-hover-line">
									{{ block.settings.text | escape }}
								</p>
							</div>
						</a>
					{%- endif -%}
				{%- endfor -%}
			</div>
		</div>
	</div>
</div>

