{% comment %}
  DIE BARISTA ROASTERY — Cemils Empfehlung
  Figma: kItgXjQzTCQ3nTb4PrD6ZW node 18:358 — 1fr media + 1.4fr panel, headline #000, quote #EFDFD3, ort #000.
{% endcomment %}

{%- liquid
  assign media_side   = section.settings.media_side | default: 'left'
  assign bg_color     = section.settings.bg_color   | default: '#759769'
  assign text_color   = section.settings.text_color | default: '#EFDFD3'
  assign headline     = section.settings.headline   | default: 'Cemils Empfehlung'
  assign quote        = section.settings.quote
  assign person_name  = section.settings.person_name  | default: 'Cemil — Gründer & Röstmeister'
  assign person_title = section.settings.person_title | default: 'Die Barista Roastery, Hammeln'
  assign image        = section.settings.image
  assign image_alt    = section.settings.image_alt | default: 'Cemil — Gründer & Röstmeister der Die Barista Roastery'
  assign default_cemil_photo = 'cemil-empfehlung-default.jpg'
-%}

<section
  class="cemil-section{% if media_side == 'right' %} cemil-section--reversed{% endif %}"
  id="cemils-empfehlung-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="--cemil-bg: {{ bg_color }}; --cemil-text: {{ text_color }}; --cemil-ink: #000000;"
  aria-labelledby="cemil-heading-{{ section.id }}"
>

  <!-- ═══ MEDIA BLOCK (LEFT) ═══ -->
  <!-- Priority: Shopify video → external MP4 → theme image → default asset (Figma Cemil photo) -->
  <div class="cemil-media" id="cemilMedia-{{ section.id }}">

    {%- if section.settings.video != blank -%}
      {{- section.settings.video | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          preload: "metadata",
          class: "cemil-media__video",
          aria-label: image_alt
      -}}

    {%- elsif section.settings.video_url != blank -%}
      <video
        class="cemil-media__video"
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        {% if image != blank -%}
          poster="{{ image | image_url: width: 1200 }}"
        {%- else -%}
          poster="{{ default_cemil_photo | asset_url }}"
        {%- endif %}
        aria-label="{{ image_alt | escape }}"
        id="cemilVideo-{{ section.id }}"
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
        {%- if image != blank -%}
          <img
            src="{{ image | image_url: width: 1200 }}"
            alt="{{ image_alt | escape }}"
            width="1200"
            height="960"
            class="cemil-media__img"
          >
        {%- else -%}
          <img
            src="{{ default_cemil_photo | asset_url }}"
            alt="{{ image_alt | escape }}"
            width="1024"
            height="1024"
            class="cemil-media__img"
          >
        {%- endif -%}
      </video>

    {%- elsif image != blank -%}
      <img
        src="{{ image | image_url: width: 1200 }}"
        srcset="
          {{ image | image_url: width: 600  }} 600w,
          {{ image | image_url: width: 900  }} 900w,
          {{ image | image_url: width: 1200 }} 1200w
        "
        sizes="(max-width: 900px) 100vw, 42vw"
        alt="{{ image_alt | escape }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="lazy"
        class="cemil-media__img"
      >

    {%- else -%}
      <img
        src="{{ default_cemil_photo | asset_url }}"
        alt="{{ image_alt | escape }}"
        width="1024"
        height="1024"
        loading="lazy"
        decoding="async"
        class="cemil-media__img cemil-media__img--default"
      >
    {%- endif -%}

    <!-- Sound toggle (only visible when video is active) -->
    {%- if section.settings.video != blank or section.settings.video_url != blank -%}
      <button
        class="cemil-sound-toggle"
        id="cemilSoundToggle-{{ section.id }}"
        data-section-id="{{ section.id }}"
        aria-label="Ton einschalten"
        aria-pressed="false"
        type="button"
      >
        <!-- Muted icon -->
        <svg class="cemil-sound-icon cemil-sound-icon--off" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
          <line x1="23" y1="9" x2="17" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="17" y1="9" x2="23" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <!-- Unmuted icon -->
        <svg class="cemil-sound-icon cemil-sound-icon--on" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
          <path d="M19.07 4.93a10 10 0 010 14.14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    {%- endif -%}

  </div>

  <!-- ═══ EDITORIAL PANEL (RIGHT) ═══ -->
  <div class="cemil-panel">
    <div class="cemil-panel__inner">

      {%- unless headline == blank -%}
        <h2 class="cemil-headline" id="cemil-heading-{{ section.id }}">
          {{ headline | escape }}
        </h2>
      {%- endunless -%}

      {%- unless quote == blank -%}
        <blockquote class="cemil-quote">
          <p>{{ quote | escape }}</p>
        </blockquote>
      {%- endunless -%}

      <!-- Signature -->
      <footer class="cemil-signature" aria-label="Person">
        {%- unless person_name == blank -%}
          <p class="cemil-signature__name">{{ person_name | escape }}</p>
        {%- endunless -%}
        {%- unless person_title == blank -%}
          <p class="cemil-signature__title">{{ person_title | escape }}</p>
        {%- endunless -%}
      </footer>

    </div>
  </div>

</section>


<!-- ═══════════════════════════════════════════════
     SCOPED CSS
     ═══════════════════════════════════════════════ -->
<style>
/* ── DESIGN TOKENS (scoped to section instance) ── */
.cemil-section {
  --db-red:    #E23528;
  --db-black:  #000000;
  --db-crema:  #EFDFD3;
  --db-green:  #759769;
  --db-mud:    #7B5D4D;
  --db-radius: 2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── SECTION LAYOUT (Figma 18:358 — 1fr : 1.4fr, row ~360px) ── */
.cemil-section {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
  grid-template-rows: minmax(360px, auto);
  width: 100%;
  overflow: hidden;
}

/* Reversed: wider panel column first */
.cemil-section--reversed {
  grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
}

.cemil-section--reversed .cemil-media {
  order: 2;
}

.cemil-section--reversed .cemil-panel {
  order: 1;
}

/* ── MEDIA BLOCK ── */
.cemil-media {
  position: relative;
  overflow: hidden;
  background: #2a2a2a;
  min-height: 360px;
  align-self: stretch;
}

.cemil-media__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.6s ease;
}

.cemil-media:hover .cemil-media__img {
  transform: scale(1.03);
}

/* ── EDITORIAL PANEL ── */
.cemil-panel {
  background: var(--cemil-bg, #759769);
  color: var(--cemil-text, #EFDFD3);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 360px;
  align-self: stretch;
}

.cemil-panel__inner {
  padding: 4.375rem 3rem;
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

/* ── HEADLINE (Figma: Social Gothic 36px / black / uppercase / +1.44px) ── */
.cemil-headline {
  font-family: var(--db-font-display);
  font-weight: 600;
  font-size: clamp(1.75rem, 2.2vw, 2.25rem);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.05;
  color: var(--cemil-ink, #000000);
  margin: 0 0 1.75rem;
}

/* ── QUOTE (Figma: New Frank Medium 24 / lh 36 / crema / 90% / max 480px) ── */
.cemil-quote {
  margin: 0 0 2rem;
  padding: 0;
  border: none;
  max-width: 480px;
}

.cemil-quote p {
  font-family: var(--db-font-body);
  font-size: clamp(1.0625rem, 1.35vw, 1.5rem);
  font-weight: 500;
  line-height: 1.5;
  letter-spacing: 0.05em;
  color: var(--cemil-text, #EFDFD3);
  opacity: 0.9;
  font-style: normal;
  margin: 0;
}

/* ── SIGNATURE (name: crema uppercase 20px; ort: black 18px) ── */
.cemil-signature {
  padding-top: 0;
  margin-top: 0;
}

.cemil-signature__name {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: clamp(1rem, 1.1vw, 1.25rem);
  text-transform: uppercase;
  letter-spacing: 0.054em;
  color: var(--cemil-text, #EFDFD3);
  line-height: 1.36;
  margin: 0 0 0.125rem;
}

.cemil-signature__title {
  font-family: var(--db-font-body);
  font-size: clamp(1rem, 1vw, 1.125rem);
  font-weight: 500;
  color: var(--cemil-ink, #000000);
  line-height: 1.07;
  margin: 0;
  opacity: 1;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .cemil-section,
  .cemil-section--reversed {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
  }

  /* Always: photo top, text bottom on mobile */
  .cemil-media {
    order: 1 !important;
    min-height: 56vw;
    max-height: 400px;
  }

  .cemil-panel {
    order: 2 !important;
    min-height: 0;
  }

  .cemil-panel__inner {
    padding: 2.5rem 1.5rem;
    max-width: 100%;
  }

  .cemil-headline {
    font-size: clamp(1.5rem, 5vw, 2rem);
    margin-bottom: 1.25rem;
    line-height: 1.05;
  }

  .cemil-quote {
    max-width: 100%;
  }

  .cemil-quote p {
    font-size: 1.0625rem;
    line-height: 1.55;
    letter-spacing: 0.04em;
  }
}

@media (max-width: 480px) {
  .cemil-media {
    min-height: 65vw;
  }

  .cemil-panel__inner {
    padding: 2rem 1.25rem;
  }
}
</style>


{% schema %}
{
  "name": "Cemils Empfehlung",
  "tag": "section",
  "class": "barista-section-cemil",
  "settings": [
    {
      "type": "header",
      "content": "Video (Priorität über Foto)"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (Shopify-gehostet)",
      "info": "Hochformat (9:16) empfohlen für mobile. Video spielt automatisch, stumm und in Schleife ab."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video-URL (externes MP4)",
      "info": "Alternative: direkter Link zu einer .mp4-Datei (z.B. von deinem CDN). Wird ignoriert wenn ein Shopify-Video hochgeladen ist."
    },
    {
      "type": "header",
      "content": "Fallback-Bild (wenn kein Video)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cemil Foto",
      "info": "Optional. Wenn leer und kein Video: Standardfoto aus dem Theme (1024×1024, wie Figma). Eigenes Bild überschreibt es."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bild / Video Alt-Text",
      "default": "Cemil — Gründer & Röstmeister der Die Barista Roastery"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Kleines Label (oben)",
      "default": "Cemils Empfehlung",
      "info": "Nicht mehr im Layout ausgegeben (Figma 18:358). Nur Überschrift nutzen."
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Überschrift",
      "default": "Cemils Empfehlung"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Zitat / Empfehlung",
      "default": "„Dieser Kaffee ist wie ein Kurzurlaub in Neapel. Dunkel geröstet, kräftig im Körper, mit einem Finish das an Zartbitterschokolade erinnert. Am liebsten trinke ich ihn als doppelten Espresso — puro, ohne alles.\""
    },
    {
      "type": "text",
      "id": "person_name",
      "label": "Name",
      "default": "Cemil — Gründer & Röstmeister"
    },
    {
      "type": "text",
      "id": "person_title",
      "label": "Titel / Ort",
      "default": "Die Barista Roastery, Hammeln"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Panel-Hintergrundfarbe",
      "default": "#759769",
      "info": "Grün für Wechselnde Sorten, Rot (#E23528) für Espresso-Sorten"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#EFDFD3"
    },
    {
      "type": "select",
      "id": "media_side",
      "label": "Foto-Position",
      "options": [
        { "value": "left",  "label": "Links (Standard)" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Cemils Empfehlung",
      "settings": {
        "label_text": "Cemils Empfehlung",
        "headline": "Cemils Empfehlung",
        "quote": "„Dieser Kaffee ist wie ein Kurzurlaub in Neapel. Dunkel geröstet, kräftig im Körper, mit einem Finish das an Zartbitterschokolade erinnert. Am liebsten trinke ich ihn als doppelten Espresso — puro, ohne alles.\"",
        "person_name": "Cemil — Gründer & Röstmeister",
        "person_title": "Die Barista Roastery, Hammeln",
        "bg_color": "#759769",
        "text_color": "#EFDFD3",
        "media_side": "left"
      }
    }
  ]
}
{% endschema %}

<style>
/* ── VIDEO MEDIA (appended) ── */

/* Video fills the media block identically to an image */
.cemil-media__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.6s ease;
  /* Remove default browser controls chrome */
  background: #000;
}

.cemil-media:hover .cemil-media__video {
  transform: scale(1.03);
}

/* ── SOUND TOGGLE ── */
.cemil-sound-toggle {
  position: absolute;
  bottom: 16px;
  right: 16px;
  z-index: 10;
  width: 36px;
  height: 36px;
  background: rgba(0, 9, 11, 0.72);
  border: 1.5px solid rgba(239, 223, 211, 0.3);
  border-radius: 2px;
  color: #EFDFD3;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  transition: background 0.2s, border-color 0.2s;
}

.cemil-sound-toggle:hover {
  background: rgba(226, 53, 40, 0.85);
  border-color: rgba(226, 53, 40, 0.6);
}

/* Icon visibility states — toggled by JS */
.cemil-sound-icon--on  { display: none; }
.cemil-sound-icon--off { display: block; }

.cemil-sound-toggle[aria-pressed="true"] .cemil-sound-icon--off { display: none; }
.cemil-sound-toggle[aria-pressed="true"] .cemil-sound-icon--on  { display: block; }

/* Ensure .cemil-media is positioned for the absolute toggle */
.cemil-media {
  position: relative;
}
</style>

<script>
(function() {
  var toggleBtn = document.getElementById('cemilSoundToggle-{{ section.id }}');
  if (!toggleBtn) return;

  /* Find the video element inside the same media block */
  var mediaBlock = document.getElementById('cemilMedia-{{ section.id }}');
  var video = mediaBlock ? mediaBlock.querySelector('video') : null;
  if (!video) return;

  toggleBtn.addEventListener('click', function () {
    var muted = video.muted;
    video.muted = !muted;
    toggleBtn.setAttribute('aria-pressed', muted ? 'true' : 'false');
    toggleBtn.setAttribute('aria-label', muted ? 'Ton ausschalten' : 'Ton einschalten');
  });
})();
</script>
