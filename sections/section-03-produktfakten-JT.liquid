{% comment %}
  ============================================================
  DIE BARISTA ROASTERY — SECTION 03: PRODUKTFAKTEN
  Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:193
  — Page: #FFF1E7 · Grid gap: #FFF1E7 · Cells: #FFF8F5 · 3px gutter
  — Header: Steckbrief New Frank 14 #E23528 · Die Fakten Social Gothic 34 #00090B · gap 48px to grid
  — Cells: label Social Gothic Bold 10.4 #906F6A · value New Frank Medium 20 / lh 32 #00090B · sub New Frank 14.4 #755848
  — Metafield-first, Theme Customizer as override

  Metafields (namespace: coffee_attributes):
    .herkunft_value      → e.g. "Brasilien · Indien"
    .herkunft_sub        → e.g. "" (optional)
    .varietaet_value     → e.g. "80% Arabica · 20% Robusta"
    .varietaet_sub       → optional
    .anbauhoe_value     → e.g. "1.200 – 1.600 M"
    .anbauhoe_sub       → optional
    .verarbeitung_value  → e.g. "Washed"
    .verarbeitung_sub    → e.g. "Traditionell gewaschen und sonnengetrocknet"
    .roastprofil_value   → e.g. "Dunkel"
    .roastprofil_sub     → e.g. "Langzeit-Trommelröstung für minimale Säure"
    .geschmack_value     → e.g. "Erdig · Schokoladig"
    .geschmack_sub       → e.g. "Temperamentvoll mit langem, warmem Finish"
  ============================================================
{% endcomment %}

{%- liquid
  # Pull from metafields first, fall back to section settings

  assign mf = product.metafields.coffee_attributes

  assign herkunft_val     = mf.herkunft_value      | default: section.settings.herkunft_value
  assign herkunft_sub     = mf.herkunft_sub         | default: section.settings.herkunft_sub
  assign varietaet_val    = mf.varietaet_value      | default: section.settings.varietaet_value
  assign varietaet_sub    = mf.varietaet_sub        | default: section.settings.varietaet_sub
  assign anbauhoe_val    = mf.anbauhoe_value      | default: section.settings.anbauhoe_value
  assign anbauhoe_sub    = mf.anbauhoe_sub        | default: section.settings.anbauhoe_sub
  assign verarbeitung_val = mf.verarbeitung_value   | default: section.settings.verarbeitung_value
  assign verarbeitung_sub = mf.verarbeitung_sub     | default: section.settings.verarbeitung_sub
  assign roastprofil_val  = mf.roastprofil_value    | default: section.settings.roastprofil_value
  assign roastprofil_sub  = mf.roastprofil_sub      | default: section.settings.roastprofil_sub
  assign geschmack_val    = mf.geschmack_value      | default: section.settings.geschmack_value
  assign geschmack_sub    = mf.geschmack_sub        | default: section.settings.geschmack_sub

  # Custom label/headline override
  assign section_label    = section.settings.section_label | default: 'Steckbrief'
  assign section_headline = section.settings.section_headline | default: 'Die Fakten'
-%}

<section
  class="fakten-section"
  id="produktfakten-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Produktfakten"
>
  <div class="fakten-inner">

    <!-- ── HEADER (Figma 18:195–200) ── -->
    <header class="fakten-header">
      {%- unless section_label == blank -%}
        <p class="fakten-label">{{ section_label | escape }}</p>
      {%- endunless -%}
      <h2 class="fakten-headline">{{ section_headline | escape }}</h2>
    </header>

    <!-- ── FACT GRID ── -->
    <div class="fakten-grid" role="list" aria-label="Produkteigenschaften">

      <!-- 1. Herkunft -->
      {%- unless herkunft_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Herkunft</span>
        <strong class="fakten-card__value">{{ herkunft_val | escape }}</strong>
        {%- unless herkunft_sub == blank -%}
          <p class="fakten-card__sub">{{ herkunft_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

      <!-- 2. Varietät -->
      {%- unless varietaet_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Varietät</span>
        <strong class="fakten-card__value">{{ varietaet_val | escape }}</strong>
        {%- unless varietaet_sub == blank -%}
          <p class="fakten-card__sub">{{ varietaet_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

      <!-- 3. Anbauhöhe -->
      {%- unless anbauhoe_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Anbauhöhe</span>
        <strong class="fakten-card__value">{{ anbauhoe_val | escape }}</strong>
        {%- unless anbauhoe_sub == blank -%}
          <p class="fakten-card__sub">{{ anbauhoe_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

      <!-- 4. Verarbeitung -->
      {%- unless verarbeitung_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Verarbeitung</span>
        <strong class="fakten-card__value">{{ verarbeitung_val | escape }}</strong>
        {%- unless verarbeitung_sub == blank -%}
          <p class="fakten-card__sub">{{ verarbeitung_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

      <!-- 5. Röstprofil -->
      {%- unless roastprofil_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Röstprofil</span>
        <strong class="fakten-card__value">{{ roastprofil_val | escape }}</strong>
        {%- unless roastprofil_sub == blank -%}
          <p class="fakten-card__sub">{{ roastprofil_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

      <!-- 6. Geschmack -->
      {%- unless geschmack_val == blank -%}
      <div class="fakten-card" role="listitem">
        <span class="fakten-card__label">Geschmack</span>
        <strong class="fakten-card__value">{{ geschmack_val | escape }}</strong>
        {%- unless geschmack_sub == blank -%}
          <p class="fakten-card__sub">{{ geschmack_sub | escape }}</p>
        {%- endunless -%}
      </div>
      {%- endunless -%}

    </div><!-- /fakten-grid -->

  </div><!-- /fakten-inner -->
</section>


<style>
/* ── DESIGN TOKENS (Figma 18:193) ── */
.fakten-section {
  --db-red:         #e23528;
  --db-black:       #00090b;
  --db-serenade:    #fff1e7;
  --db-soapstone:   #fff8f5;
  --db-opium:       #906f6a;
  --db-roman:       #755848;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

/* ── SECTION — Serenade bg, generous vertical padding ── */
.fakten-section {
  background: var(--db-serenade);
  padding: 4rem clamp(1.25rem, 10vw, 25.625rem);
  box-sizing: border-box;
}

.fakten-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  box-sizing: border-box;
}

/* ── HEADER — 8px label↔headline; 48px to grid ── */
.fakten-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
  margin-bottom: 3rem;
}

/* Steckbrief: New Frank Medium 14 / #E23528 / +1.44px */
.fakten-label {
  font-family: var(--db-font-body);
  font-size: 0.875rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.103em;
  color: var(--db-red);
  line-height: 1.0285714286;
  margin: 0;
}

/* Die Fakten: Social Gothic Medium 34 / #00090B / −0.576px */
.fakten-headline {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: clamp(1.5rem, 3.2vw, 2.125rem);
  text-transform: uppercase;
  letter-spacing: -0.017em;
  line-height: 0.804;
  color: var(--db-black);
  margin: 0;
}

/* ── GRID — 3×2, 3px gutter shows Serenade ── */
.fakten-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 3px;
  background: var(--db-serenade);
  width: 100%;
}

/* ── CELL — Soapstone, Figma padding ~27px 28px ── */
.fakten-card {
  background: var(--db-soapstone);
  padding: 1.6875rem 1.75rem 1.75rem;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.375rem;
  min-width: 0;
}

/* Label: Social Gothic Bold 10.4 / Opium / +1.56px */
.fakten-card__label {
  font-family: var(--db-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--db-opium);
  line-height: 1.6;
  margin: 0;
}

/* Value: New Frank Medium 20 / lh 32 (Figma), uppercase */
.fakten-card__value {
  font-family: var(--db-font-body);
  font-weight: 500;
  font-size: clamp(1rem, 1.25vw, 1.25rem);
  text-transform: uppercase;
  letter-spacing: 0;
  line-height: 1.6;
  color: var(--db-black);
  display: block;
  margin: 0;
}

/* Sub: New Frank Medium 14.4 / lh 21.6 / Roman Coffee */
.fakten-card__sub {
  font-family: var(--db-font-body);
  font-size: 0.9rem;
  font-weight: 500;
  line-height: 1.5;
  color: var(--db-roman);
  margin: 0.5rem 0 0;
  max-width: 100%;
}

/* Tablet */
@media (max-width: 900px) {
  .fakten-section {
    padding: 3rem 1.5rem;
  }

  .fakten-inner {
    padding: 0 1.5rem;
  }

  .fakten-header {
    margin-bottom: 2.25rem;
  }

  .fakten-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* Mobile */
@media (max-width: 540px) {
  .fakten-section {
    padding: 2.5rem 1rem;
  }

  .fakten-inner {
    padding: 0 0.75rem;
  }

  .fakten-headline {
    line-height: 1.05;
  }

  .fakten-header {
    margin-bottom: 1.75rem;
  }

  .fakten-grid {
    grid-template-columns: 1fr;
    gap: 3px;
  }

  .fakten-card {
    padding: 1.375rem 1.25rem 1.5rem;
  }
}
</style>


{% schema %}
{
  "name": "Produktfakten",
  "tag": "section",
  "class": "barista-section-fakten",
  "settings": [
    {
      "type": "header",
      "content": "Abschnitts-Header"
    },
    {
      "type": "text",
