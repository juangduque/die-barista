      "label": "Kleines Label",
      "default": "Steckbrief",
      "info": "Wird rot dargestellt. Leer lassen zum Ausblenden."
    },
    {
      "type": "text",
      "id": "section_headline",
      "label": "Überschrift",
      "default": "Die Fakten"
    },
    {
      "type": "paragraph",
      "content": "⚡ Felder werden automatisch aus Produkt-Metafields geladen (coffee_attributes.*). Die folgenden Werte sind nur Fallbacks wenn kein Metafield gesetzt ist."
    },
    {
      "type": "header",
      "content": "1 · Herkunft"
    },
    {
      "type": "text",
      "id": "herkunft_value",
      "label": "Wert",
      "placeholder": "Brasilien · Indien"
    },
    {
      "type": "text",
      "id": "herkunft_sub",
      "label": "Beschreibung (optional)",
    },
    {
      "type": "header",
      "content": "2 · Varietät"
    },
    {
      "type": "text",
      "id": "varietaet_value",
      "label": "Wert",
      "placeholder": "80% Arabica · 20% Robusta"
    },
    {
      "type": "text",
      "id": "varietaet_sub",
      "label": "Beschreibung (optional)",
    },
    {
      "type": "header",
      "content": "3 · Anbauhöhe"
    },
    {
      "type": "text",
      "id": "anbauhoe_value",
      "label": "Wert",
      "placeholder": "1.200 – 1.600 M"
    },
    {
      "type": "text",
      "id": "anbauhoe_sub",
      "label": "Beschreibung (optional)",
    },
    {
      "type": "header",
      "content": "4 · Verarbeitung"
    },
    {
      "type": "text",
      "id": "verarbeitung_value",
      "label": "Wert",
      "placeholder": "Washed"
    },
    {
      "type": "text",
      "id": "verarbeitung_sub",
      "label": "Beschreibung (optional)",
      "placeholder": "Traditionell gewaschen und sonnengetrocknet"
    },
    {
      "type": "header",
      "content": "5 · Röstprofil"
    },
    {
      "type": "text",
      "id": "roastprofil_value",
      "label": "Wert",
      "placeholder": "Dunkel"
    },
    {
      "type": "text",
      "id": "roastprofil_sub",
      "label": "Beschreibung (optional)",
      "placeholder": "Langzeit-Trommelröstung für minimale Säure"
    },
    {
      "type": "header",
      "content": "6 · Geschmack"
    },
    {
      "type": "text",
      "id": "geschmack_value",
      "label": "Wert",
      "placeholder": "Erdig · Schokoladig"
    },
    {
      "type": "text",
      "id": "geschmack_sub",
      "label": "Beschreibung (optional)",
      "placeholder": "Temperamentvoll mit langem, warmem Finish"
    }
  ],
  "presets": [
    {
      "name": "Produktfakten",
      "settings": {
        "section_label": "Steckbrief",
        "section_headline": "Die Fakten",
        "herkunft_value": "Brasilien · Indien",
        "varietaet_value": "80% Arabica · 20% Robusta",
        "anbauhoe_value": "1.200 – 1.600 M",
        "verarbeitung_value": "Washed",
        "verarbeitung_sub": "Traditionell gewaschen und sonnengetrocknet",
