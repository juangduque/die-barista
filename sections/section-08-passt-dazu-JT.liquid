{% comment %}
  Passt Dazu — Cross-Sells
  Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:414 — Serenade surface, 28px header↔grid @1100px+, 4×20px grid @1100px+, 2-col 641–1099, 1-col under 641px, Soapstone cards.
  Data: custom.cross_sells → section product_list → optional fallback_collection → first product collection → collections['all'].
  Current product is never shown twice (skipped in the loop).
{% endcomment %}

{{ 'section-landing-roast-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign passt_products = product.metafields.custom.cross_sells.value
  if passt_products == blank
    assign passt_products = section.settings.cross_sell_products
  endif
  if passt_products == blank
    if section.settings.fallback_collection != blank
      assign passt_products = section.settings.fallback_collection.products
    elsif product.collections.size > 0
      assign passt_products = product.collections.first.products
    else
      assign passt_all_coll = collections['all']
      if passt_all_coll != blank and passt_all_coll.products_count > 0
        assign passt_products = passt_all_coll.products
      endif
    endif
  endif
  assign header_title = section.settings.header_title | default: 'Passt dazu'
  assign cta_label     = section.settings.cta_label     | default: 'Alle Röstungen'
  assign cta_url       = section.settings.cta_url       | default: '/collections/all'
  assign passt_eligible = 0
  if passt_products != blank
    for cross_product in passt_products
      if cross_product.id != product.id
        assign passt_eligible = passt_eligible | plus: 1
        if passt_eligible >= 4
          break
        endif
      endif
    endfor
  endif
-%}

<section
  class="passt-section"
  id="passt-dazu-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-labelledby="passt-heading-{{ section.id }}"
>
  <div class="passt-inner">

    <div class="passt-header">
      <h2 class="passt-header__title" id="passt-heading-{{ section.id }}">
        {{ header_title | escape }}
      </h2>
      {%- unless cta_url == blank -%}
        <a
          href="{{ cta_url }}"
          class="passt-header__link"
        >
          {{ cta_label | escape }} →
        </a>
      {%- endunless -%}
    </div>

    {%- if passt_eligible > 0 -%}
      <ul class="landing-roast-grid__grid passt-cross-grid" role="list" aria-label="Empfohlene Produkte">
        {%- assign passt_rendered = 0 -%}
        {%- for cross_product in passt_products -%}
          {%- if cross_product.id == product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- render 'passt-dazu-card-JT', cross_product: cross_product -%}
          {%- assign passt_rendered = passt_rendered | plus: 1 -%}
          {%- if passt_rendered >= 4 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="passt-empty">
        Keine weiteren Produkte gefunden. Wähle unter „Empfohlene Produkte“ bis zu vier Artikel, lege <code>custom.cross_sells</code> (list.product_reference) an, oder weise eine Fallback-Kollektion zu.
      </p>
    {%- endif -%}

  </div>
</section>

<style>
.passt-section {
  --db-red:         #e23528;
  --db-black:       #00090b;
  --db-crema:       #efdfd3;
  --db-opium:       #906f6a;
  --db-serenade:    #fff1e7;
  --db-soapstone:   #fff8f5;
  --db-warm:        #f5e5d9;
  --db-radius:      2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
  /* landing-roast-product-card / section-landing-roast-grid.css */
  --lr-accent: #e23528;
  --lr-card-frame: #fff8f5;
  --lr-panel-title: #00090b;
  --lr-panel-muted: #906f6a;
  --lr-tone-beige: #f5e5d9;
  --lr-tone-red: #e23528;
  --lr-tone-green: #759769;
  --lr-tone-green-inset: #5f8a5c;
  --lr-crema: #efdfd3;
}

.passt-section {
  background: var(--db-serenade);
  /* Figma 18:414 — py 64px section rhythm */
  padding: 4rem 1rem;
  box-sizing: border-box;
}

.passt-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 0.75rem;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.passt-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex-wrap: nowrap;
  justify-content: flex-start;
  gap: 0.75rem;
}

.passt-section .passt-header__title {
  font-family: social-gothic, 'Social Gothic', 'Barlow Condensed', sans-serif;
  font-weight: 500;
  font-style: normal;
  font-size: clamp(1.625rem, 4.2vw, 2.25rem);
  text-transform: uppercase;
  letter-spacing: 2px;
  line-height: 1.08;
  color: var(--db-black);
  margin: 0;
  max-width: 100%;
  white-space: normal;
}

.passt-header__link {
  font-family: 'New Frank', 'DM Sans', sans-serif;
  font-size: 12px;
  font-weight: 500;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  line-height: 19.2px;
  color: var(--db-red);
  text-decoration: none;
  white-space: normal;
  transition: opacity 0.2s;
}

.passt-header__link:hover {
  opacity: 0.75;
}

.passt-header__link:focus-visible {
  outline: 2px solid var(--db-red);
  outline-offset: 3px;
  border-radius: 1px;
}

/* Same card layout as landing roast grid; keep 4-up desktop (grid defaults to 3-up in shared CSS). */
.passt-cross-grid.landing-roast-grid__grid {
  gap: 20px;
  max-width: 100%;
  margin: 0;
}

.passt-empty {
  font-family: var(--db-font-body);
  font-size: 0.875rem;
  line-height: 1.55;
  color: var(--db-opium);
  padding: 1.5rem 1.25rem;
  background: var(--db-soapstone);
  border-radius: var(--db-radius);
  margin: 0;
}

.passt-empty code {
  font-size: 0.8125em;
  word-break: break-word;
}

/* Small tablet+: row header, 2-column grid (Figma 18:414) */
@media (min-width: 641px) {
  .passt-section {
    padding: 4rem 1.5rem;
  }

  .passt-inner {
    padding: 0 1.5rem;
    gap: 28px;
  }

  .passt-header {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem 1.5rem;
  }

  .passt-section .passt-header__title {
    white-space: nowrap;
  }

  .passt-header__link {
    white-space: nowrap;
  }

}

/* Desktop — Figma 18:414: ~410px side inset + 1100 inner @ 48px horizontal */
@media (min-width: 1100px) {
  .passt-section {
    padding: 4rem clamp(1.25rem, 10vw, 25.625rem);
  }

  .passt-inner {
    padding: 0 3rem;
    gap: 28px;
  }

  .passt-section .passt-header__title {
    font-size: 36px;
    letter-spacing: 2px;
    line-height: calc(27.36 / 36);
  }

  .passt-header__link {
    letter-spacing: 1.2px;
  }

  .passt-cross-grid.landing-roast-grid__grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }
}

/* Narrow phones */
@media (max-width: 400px) {
  .passt-inner {
    padding: 0 0.5rem;
  }

  .passt-section .passt-header__title {
    letter-spacing: 1.5px;
  }
}
</style>

{% schema %}
{
  "name": "Passt Dazu — Cross-Sells",
  "tag": "section",
  "class": "barista-section-crosssell",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "header_title",
      "label": "Überschrift",
      "default": "Passt dazu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link-Text rechts",
      "default": "Alle Röstungen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link-URL",
      "info": "z.B. /collections/all"
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "paragraph",
      "content": "Reihenfolge: Metafeld custom.cross_sells (list.product_reference) → Produktliste unten → Fallback-Kollektion → sonst erste Kollektion dieses Produkts → sonst Kollektion „all“."
    },
    {
      "type": "product_list",
      "id": "cross_sell_products",
      "label": "Empfohlene Produkte (Fallback)",
      "limit": 4
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback-Kollektion (optional)",
      "info": "Nur wenn Metafeld und Produktliste leer sind: bis zu vier andere Produkte aus dieser Kollektion."
    }
  ],
  "presets": [
    {
      "name": "Passt Dazu — Cross-Sells",
      "settings": {
        "header_title": "Passt dazu",
        "cta_label": "Alle Röstungen"
      }
    }
  ]
}
{% endschema %}
