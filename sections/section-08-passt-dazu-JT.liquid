{% comment %}
  Passt Dazu — Cross-Sells
  Figma kItgXjQzTCQ3nTb4PrD6ZW node 18:414 — Serenade surface, 28px header↔grid, 4× grid gap 20px, Soapstone cards.
  Data: custom.cross_sells (list.product_reference) → section cross_sell_products fallback.
{% endcomment %}

{%- liquid
  assign cross_sell_products = product.metafields.custom.cross_sells.value
  if cross_sell_products == blank
    assign cross_sell_products = section.settings.cross_sell_products
  endif
  assign header_title = section.settings.header_title | default: 'Passt Dazu'
  assign cta_label     = section.settings.cta_label     | default: 'Alle Röstungen'
  assign cta_url       = section.settings.cta_url       | default: '/collections/all'
-%}

<section
  class="passt-section"
  id="passt-dazu-{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-labelledby="passt-heading-{{ section.id }}"
>
  <div class="passt-inner">

    <div class="passt-header">
      <h2 class="passt-header__title" id="passt-heading-{{ section.id }}">
        {{ header_title | escape }}
      </h2>
      {%- unless cta_url == blank -%}
        <a
          href="{{ cta_url }}"
          class="passt-header__link"
        >
          {{ cta_label | escape }} →
        </a>
      {%- endunless -%}
    </div>

    {%- if cross_sell_products != blank -%}
      <ul class="passt-grid" role="list" aria-label="Empfohlene Produkte">
        {%- for cross_product in cross_sell_products limit: 4 -%}
          {%- render 'passt-dazu-card-JT', cross_product: cross_product -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="passt-empty">
        Produkte im Theme-Editor oder über das Metafeld <code>custom.cross_sells</code> (list.product_reference) hinzufügen.
      </p>
    {%- endif -%}

  </div>
</section>

<style>
.passt-section {
  --db-red:         #e23528;
  --db-black:       #00090b;
  --db-crema:       #efdfd3;
  --db-opium:       #906f6a;
  --db-serenade:    #fff1e7;
  --db-soapstone:   #fff8f5;
  --db-warm:        #f5e5d9;
  --db-radius:      2px;
  --db-font-display: 'Social Gothic', 'Barlow Condensed', sans-serif;
  --db-font-body:    'New Frank', 'DM Sans', sans-serif;
}

.passt-section {
  background: var(--db-serenade);
  padding: 4rem clamp(1.25rem, 10vw, 25.625rem);
  box-sizing: border-box;
}

.passt-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.passt-header {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-end;
  gap: 1rem 1.5rem;
}

.passt-header__title {
  font-family: var(--db-font-display);
  font-weight: 500;
  font-size: clamp(1.5rem, 3.2vw, 2.25rem);
  text-transform: uppercase;
  letter-spacing: 0.055em;
  line-height: 0.76;
  color: var(--db-black);
  margin: 0;
}

.passt-header__link {
  font-family: var(--db-font-body);
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  line-height: 1.6;
  color: var(--db-red);
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.2s;
}

.passt-header__link:hover {
  opacity: 0.75;
}

.passt-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.25rem;
  width: 100%;
}

.passt-empty {
  font-family: var(--db-font-body);
  font-size: 0.875rem;
  color: var(--db-opium);
  padding: 2rem;
  background: var(--db-soapstone);
  border-radius: var(--db-radius);
  margin: 0;
}

@media (max-width: 1024px) {
  .passt-section {
    padding: 3rem 1.5rem;
  }

  .passt-inner {
    padding: 0 1.5rem;
  }

  .passt-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .passt-section {
    padding: 2.5rem 1rem;
  }

  .passt-inner {
    padding: 0 0.75rem;
    gap: 1.25rem;
  }

  .passt-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .passt-header__link {
    white-space: normal;
  }

  .passt-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}
</style>

{% schema %}
{
  "name": "Passt Dazu — Cross-Sells",
  "tag": "section",
  "class": "barista-section-crosssell",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "header_title",
      "label": "Überschrift",
      "default": "Passt Dazu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link-Text rechts",
      "default": "Alle Röstungen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link-URL",
      "info": "z.B. /collections/all"
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "paragraph",
      "content": "Produkte aus Metafeld custom.cross_sells (list.product_reference). Fallback: Liste unten."
    },
    {
      "type": "product_list",
      "id": "cross_sell_products",
      "label": "Empfohlene Produkte (Fallback)",
      "limit": 4
    }
  ],
  "presets": [
    {
      "name": "Passt Dazu — Cross-Sells",
      "settings": {
        "header_title": "Passt Dazu",
        "cta_label": "Alle Röstungen"
      }
    }
  ]
}
{% endschema %}
