{% comment %}
  Section: barista-momente.liquid
  Pfad: sections/barista-momente.liquid
  Zeigt entweder manuell hochgeladene Bilder oder einen
  externen Instagram-Feed (erfordert App wie Instafeed).
{% endcomment %}

<style>
.barista-momente { background: #0F0F0D; padding: 70px 0 0; }
.barista-momente__header {
  text-align: center;
  margin-bottom: 40px;
  padding: 0 40px;
}
.barista-momente__hashtag {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(32px, 5vw, 52px);
  color: #FFFFFF;
  letter-spacing: 1px;
}
.barista-momente__sub {
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  color: #888580;
  font-size: 13px;
  margin-top: 8px;
}
.barista-momente__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3px;
}
.barista-momente__item {
  aspect-ratio: 1;
  overflow: hidden;
  cursor: pointer;
  position: relative;
  display: block;
  text-decoration: none;
}
.barista-momente__item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1;
  opacity: 0;
  transition: opacity 0.3s;
}
.barista-momente__item:hover::before { opacity: 1; }
.barista-momente__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.barista-momente__item:hover img { transform: scale(1.06); }
.barista-momente__overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}
.barista-momente__item:hover .barista-momente__overlay { opacity: 1; }
.barista-momente__overlay-text {
  font-family: var(--db-font-body, 'Source Sans 3', sans-serif);
  color: white;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-align: center;
}

/* Fallback placeholder */
.barista-momente__placeholder {
  width: 100%;
  height: 100%;
  background: #1A1208;
}

@media (max-width: 1024px) {
  .barista-momente__grid { grid-template-columns: repeat(4, 1fr); }
}
@media (max-width: 640px) {
  .barista-momente__grid { grid-template-columns: repeat(2, 1fr); }
  .barista-momente__header { padding: 0 20px; }
}
</style>

<section class="barista-momente">

  <div class="barista-momente__header db-reveal">
    <div class="barista-momente__hashtag">{{ section.settings.hashtag }}</div>
    {%- if section.settings.subtitle != blank -%}
      <p class="barista-momente__sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <div class="barista-momente__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'photo' -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="barista-momente__item"
          {{ block.shopify_attributes }}
          {% if block.settings.link == blank %}onclick="return false;"{% endif %}>

          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                alt: block.settings.image.alt | default: section.settings.hashtag
            }}
          {%- else -%}
            <div class="barista-momente__placeholder" style="background: hsl({{ forloop.index | times: 25 | plus: 15 }}, 30%, {{ forloop.index | modulo: 2 | times: 5 | plus: 10 }}%);"></div>
          {%- endif -%}

          <div class="barista-momente__overlay">
            <span class="barista-momente__overlay-text">{{ section.settings.hashtag }}</span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "Barista Momente",
  "tag": "div",
  "blocks": [
    {
      "type": "photo",
      "name": "Foto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional, z.B. Instagram Post)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "hashtag",
      "label": "Hashtag / Überschrift",
      "default": "#DIEBARISTA MOMENTE"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Untertitel",
      "default": "Teile deine Kaffee-Momente mit unserer Community in den sozialen Medien"
    }
  ],
  "presets": [
    {
      "name": "Barista Momente",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
