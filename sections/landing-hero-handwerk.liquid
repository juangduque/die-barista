{{ 'section-landing-hero-handwerk.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-landing-hero-handwerk.js' | asset_url }}" defer="defer"></script>

{% style %}
  #landing-hw-hero-{{ section.id }} {
    --landing-hw-page-bg: {{ section.settings.page_bg }};
    --landing-hw-hero-bg: {{ section.settings.hero_bg }};
    --landing-hw-hero-accent: {{ section.settings.accent_color }};
    --landing-hw-hero-green: {{ section.settings.status_dot_color }};
    --landing-hw-hero-text-muted: {{ section.settings.subtext_color }};
  }
{% endstyle %}

<section
  id="landing-hw-hero-{{ section.id }}"
  class="landing-hw-hero"
>
  <div class="landing-hw-hero__inner">
    <div class="landing-hw-hero__visual">
      {%- liquid
        assign hero_bg = section.settings.image_background
        assign hero_fg = section.settings.image_foreground
        assign use_bg_fallback = false
        assign use_fg_fallback = false
        if hero_bg == blank and section.settings.use_theme_image_fallbacks
          assign use_bg_fallback = true
        endif
        if hero_fg == blank and section.settings.use_theme_image_fallbacks
          assign use_fg_fallback = true
        endif

        assign slide_from_blocks_count = 0
        for block in section.blocks
          if block.type == 'slide'
            assign bbg = block.settings.image_background
            assign bfg = block.settings.image_foreground
            assign bba = block.settings.slide_background_bundled
            assign bfa = block.settings.slide_portrait_bundled
            if bbg != blank or bfg != blank or bba != blank or bfa != blank
              assign slide_from_blocks_count = slide_from_blocks_count | plus: 1
            endif
          endif
        endfor

        assign legacy_has_visual = false
        if hero_bg != blank or hero_fg != blank or use_bg_fallback or use_fg_fallback
          assign legacy_has_visual = true
        endif
      -%}
      {%- if slide_from_blocks_count > 0 -%}
        <div
          class="landing-hw-hero__carousel"
          data-landing-hw-hero-carousel
          data-autoplay="{% if section.settings.carousel_autoplay == false %}false{% else %}true{% endif %}"
          data-interval-ms="{{ section.settings.carousel_interval_seconds | default: 5 | times: 1000 }}"
          role="region"
          aria-roledescription="carousel"
          aria-label="{{ section.settings.carousel_aria_label | default: 'Hero images' | escape }}"
        >
          {%- assign slide_is_first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'slide' -%}
              {%- assign slide_bg = block.settings.image_background -%}
              {%- assign slide_fg = block.settings.image_foreground -%}
              {%- assign bg_asset = block.settings.slide_background_bundled -%}
              {%- assign fg_asset = block.settings.slide_portrait_bundled -%}
              {%- if slide_bg != blank or slide_fg != blank or bg_asset != blank or fg_asset != blank -%}
                {%- if slide_is_first -%}
                  {%- assign slide_loading = 'eager' -%}
                  {%- assign slide_fetch = 'high' -%}
                {%- else -%}
                  {%- assign slide_loading = 'lazy' -%}
                  {%- assign slide_fetch = '' -%}
                {%- endif -%}
                {%- render 'landing-hw-hero-slide',
                  slide_bg: slide_bg,
                  slide_fg: slide_fg,
                  bg_asset: bg_asset,
                  fg_asset: fg_asset,
                  use_bg_fallback: false,
                  use_fg_fallback: false,
                  is_active: slide_is_first,
                  slide_loading: slide_loading,
                  fetch_priority: slide_fetch,
                  block: block
                -%}
                {%- assign slide_is_first = false -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- elsif legacy_has_visual -%}
        <div
          class="landing-hw-hero__carousel landing-hw-hero__carousel--single"
          data-landing-hw-hero-carousel
          data-autoplay="{% if section.settings.carousel_autoplay == false %}false{% else %}true{% endif %}"
          data-interval-ms="{{ section.settings.carousel_interval_seconds | default: 5 | times: 1000 }}"
          role="region"
          aria-roledescription="carousel"
          aria-label="{{ section.settings.carousel_aria_label | default: 'Hero images' | escape }}"
        >
          {%- render 'landing-hw-hero-slide',
            slide_bg: hero_bg,
            slide_fg: hero_fg,
            use_bg_fallback: use_bg_fallback,
            use_fg_fallback: use_fg_fallback,
            is_active: true,
            slide_loading: 'eager',
            fetch_priority: 'high'
          -%}
        </div>
      {%- endif -%}
    </div>

    <div class="landing-hw-hero__content">
      {%- if section.settings.status_text != blank -%}
        <div class="landing-hw-hero__status">
          <span class="landing-hw-hero__status-dot"></span>
          <p class="landing-hw-hero__status-text">{{ section.settings.status_text | escape }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.eyebrow_text != blank -%}
        <div class="landing-hw-hero__eyebrow-row">
          <span class="landing-hw-hero__eyebrow-rule" aria-hidden="true"></span>
          <p class="landing-hw-hero__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.heading_line_1 != blank
        or section.settings.heading_line_statt != blank
        or section.settings.heading_accent != blank
        or section.settings.heading_line_2 != blank
      -%}
        <div class="landing-hw-hero__heading-frame">
          <h1 class="landing-hw-hero__heading">
            {%- if section.settings.heading_line_1 != blank -%}
              <span class="landing-hw-hero__heading-line">{{ section.settings.heading_line_1 | escape }}</span>
            {%- endif -%}
            {%- if section.settings.heading_line_statt != blank -%}
              <span class="landing-hw-hero__heading-line">{{ section.settings.heading_line_statt | escape }}</span>
            {%- endif -%}
            {%- if section.settings.heading_accent != blank -%}
              <span class="landing-hw-hero__heading-line landing-hw-hero__heading-accent">
                {{- section.settings.heading_accent | escape -}}
              </span>
            {%- endif -%}
            {%- if section.settings.heading_line_2 != blank -%}
              <span class="landing-hw-hero__heading-line">{{ section.settings.heading_line_2 | escape }}</span>
            {%- endif -%}
          </h1>
        </div>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="landing-hw-hero__subtext rte">{{ section.settings.subtext }}</div>
      {%- endif -%}

      <div class="landing-hw-hero__buttons">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="landing-hw-hero__btn landing-hw-hero__btn--primary"
            {% if section.settings.primary_link != blank %}
              href="{{ section.settings.primary_link }}"
            {% else %}
              aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a
            class="landing-hw-hero__btn landing-hw-hero__btn--secondary"
            {% if section.settings.secondary_link != blank %}
              href="{{ section.settings.secondary_link }}"
            {% else %}
              aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing HW Hero",
  "tag": "section",
  "class": "landing-hw-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero carousel"
    },
    {
      "type": "checkbox",
      "id": "carousel_autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "carousel_interval_seconds",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Time on each slide",
      "default": 5
    },
    {
      "type": "text",
      "id": "carousel_aria_label",
      "label": "Carousel accessibility label",
      "default": "Hero images",
      "info": "Announced to screen reader users."
    },
    {
      "type": "header",
      "content": "Fallback images (no slides)"
    },
    {
      "type": "paragraph",
      "content": "Add Hero slides below for a carousel. When at least one slide has an image, those slides are used and the pickers here are ignored. If there are no slides with images, these settings apply."
    },
    {
      "type": "image_picker",
      "id": "image_background",
      "label": "Background image (left)"
    },
    {
      "type": "image_picker",
      "id": "image_foreground",
      "label": "Foreground image (portrait)"
    },
    {
      "type": "checkbox",
      "id": "use_theme_image_fallbacks",
      "label": "Use bundled hero photos when uploads are empty",
      "default": true,
      "info": "Shows landing-hero-handwerk-bg.jpg and landing-hero-handwerk-portrait.jpg from Assets until you pick images in the theme editor (or in settings_data)."
    },
    {
      "type": "checkbox",
      "id": "image_saturation_overlay",
      "label": "Saturation blend overlay (desaturates left column)",
      "default": false,
      "info": "Figma used a white + mix-blend-mode layer for a muted look. Turn on only if you want that effect."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "status_text",
      "label": "Status line",
      "default": "Wir rösten jede drei Tage"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow",
      "default": "Direkt aus Hameln"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Handwerk",
      "info": "Figma: first line (e.g. HANDWERK)"
    },
    {
      "type": "text",
      "id": "heading_line_statt",
      "label": "Heading line 2 (white)",
      "default": "statt",
      "info": "Line under first word (e.g. STATT). Leave empty to use only line 1."
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent line (red)",
      "default": "Massen-"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading last line (white)",
      "default": "Produktion"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Body text",
      "default": "<p>Jede Bohne ein Fingerabdruck. Cemil röstet in kleinen Chargen für maximalen Charakter.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Unsere Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "page_bg",
      "label": "Page background",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "hero_bg",
      "label": "Hero column background",
      "default": "#00090b"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (buttons, eyebrow)",
      "default": "#e23528"
    },
    {
      "type": "color",
      "id": "status_dot_color",
      "label": "Status dot",
      "default": "#759769"
    },
    {
      "type": "text",
      "id": "subtext_color",
      "label": "Body text color (CSS)",
      "default": "rgba(239, 223, 211, 0.6)",
      "info": "Any valid CSS color."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_background",
          "label": "Background image (left)"
        },
        {
          "type": "image_picker",
          "id": "image_foreground",
          "label": "Portrait image"
        },
        {
          "type": "select",
          "id": "slide_background_bundled",
          "label": "Bundled background (if empty)",
          "options": [
            { "value": "", "label": "None" },
            { "value": "landing-hero-handwerk-bg.jpg", "label": "Original Handwerk background" },
            { "value": "landing-community-1.png", "label": "Community 1" },
            { "value": "landing-community-2.jpg", "label": "Community 2" },
            { "value": "landing-community-3.png", "label": "Community 3" },
            { "value": "landing-community-4.jpg", "label": "Community 4" }
          ],
          "default": "",
          "info": "Theme assets used when Background image is not set (Handwerk defaults or Community grid photos)."
        },
        {
          "type": "select",
          "id": "slide_portrait_bundled",
          "label": "Bundled portrait (if empty)",
          "options": [
            { "value": "", "label": "None" },
            { "value": "landing-hero-handwerk-portrait.jpg", "label": "Original Handwerk portrait" },
            { "value": "landing-community-1.png", "label": "Community 1" },
            { "value": "landing-community-2.jpg", "label": "Community 2" },
            { "value": "landing-community-3.png", "label": "Community 3" },
            { "value": "landing-community-4.jpg", "label": "Community 4" }
          ],
          "default": "",
          "info": "Theme assets used when Portrait image is not set (Handwerk defaults or Community grid photos)."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Landing HW Hero"
    }
  ]
}
{% endschema %}
