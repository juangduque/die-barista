{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card-row.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card-column.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>
	{{- 'component-article-card.css' | asset_url | stylesheet_tag -}}
</noscript>
<noscript>
	{{- 'component-article-card-row.css' | asset_url | stylesheet_tag -}}
</noscript>

{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

{%- style -%}
	{% render 'section-padding' %}


	#shopify-section-{{ section.id }} .blog__posts .blog__post:nth-child(n+{{ section.settings.post_limit | plus: 1 }}) {
	  display: flex;
	}

	#shopify-section-{{ section.id }} .blog__posts .blog__post:nth-child(n+{{ section.settings.post_limit_mobile | plus: 1 }}) {
	  display: none;
	}

	@media screen and (min-width: 576px) {
	  #shopify-section-{{ section.id }} .blog__posts .blog__post:nth-child(n+{{ section.settings.post_limit_mobile | plus: 1 }}) {
	    display: flex;
	  }

	  #shopify-section-{{ section.id }} .blog__posts .blog__post:nth-child(n+{{ section.settings.post_limit | plus: 1 }}) {
	    display: none;
	  }
	}
{%- endstyle -%}

<div
	class="section-{{ section.id }}-padding"
>
	<div class="blog {% if section.settings.heading == blank %} blog_no-heading {% endif %} container">
		<div class="title-wrapper">
			{%- if section.settings.heading != blank -%}
				<h2 class=" {{ section.settings.heading_size }}">
					{{ section.settings.heading }}
				</h2>
			{%- endif -%}
			{%- if section.settings.show_view_all
				or section.settings.show_view_all_mobile
			-%}
				{% liquid
					assign show_desktop = false
					if section.settings.show_view_all and section.settings.post_limit < section.settings.blog.articles_count
						assign show_desktop = true
					endif

					assign show_mobile = false
					if section.settings.show_view_all_mobile and section.settings.post_limit_mobile < section.settings.blog.articles_count
						assign show_mobile = true
					endif
				%}

				{% if show_desktop or show_mobile %}
					<a
						{% if section.settings.button_label != blank %}
							href="{{ section.settings.blog.url }}"
						{% endif %}
						class="
							button button--simple-move
							{%- if show_desktop == false and show_mobile == true %} blog__button-wrapper_mobile {%- endif -%}
							{%- if show_desktop == true and show_mobile == false %} blog__button-wrapper_desktop {%- endif -%}
						"
						{% if section.settings.button_label == blank %}
							aria-disabled="true"
						{% endif %}
					>
						<span>{{ section.settings.button_label }}</span>
						<span>
							{% render 'icon-button-arrow' %}
						</span>
					</a>
				{%- else -%}
					<div class="	button button--simple-move">
					<span>{{ section.settings.button_label }}</span>
					<span>
						{% render 'icon-button-arrow' %}
					</span>
				</div>
				{% endif %}
			{%- endif -%}
		</div>
		{%- liquid
			if section.settings.post_limit <= section.settings.blog.articles_count
				assign posts_exceed_limit = true
			endif
		-%}
		{% liquid
			assign limit_post = section.settings.post_limit
			if limit_post < section.settings.post_limit_mobile
				assign limit_post = section.settings.post_limit_mobile
			endif
		%}
		{%- if section.settings.blog != blank
			and section.settings.blog.articles_count > 0
		-%}
			<ul
				class="
					blog__posts blog__posts--{%- if section.settings.post_layout == 'column' -%}column{%- else -%}grid{% endif %} articles-wrapper
					{% if posts_exceed_limit %} blog__posts--{{ section.settings.post_layout }}-items
					{% else %} blog__posts--{{ section.settings.post_layout }}-items{% endif %}
				"
				role="list"
			>
				{%- for article in section.settings.blog.articles limit: limit_post -%}
					<li class="blog__post article">
						<div
							class="article__overlay"
							style="opacity: {{ section.settings.overlay_opacity }}"
						>
							<a
								class="article-card-link"
								href="{{ article.url }}"
								aria-label="{{ "accessibility.article_link" | t }}"
							></a>
						</div>
						{% if section.settings.post_layout == 'column' %}
							{% render 'article-card',
								blog: section.settings.blog,
								article: article,
								show_image: section.settings.show_image,
								show_tags: section.settings.show_tags,
								show_date: section.settings.show_date,
								show_author: section.settings.show_author,
								show_excerpt: section.settings.show_excerpt
							%}
						{% else %}
							{%
								render 'article-card-row',
								blog: section.settings.blog,
								article: article,
								show_image: section.settings.show_image,
								show_tags: section.settings.show_tags,
								show_date: section.settings.show_date,
								show_author: section.settings.show_author,
								show_excerpt: section.settings.show_excerpt,
							%}
						{% endif %}
					</li>
				{%- endfor -%}
			</ul>
		{%- else -%}
			<ul
				class="
					blog__posts blog__posts--{%- if section.settings.post_layout == 'column' -%}column{%- else -%}grid{% endif %} articles-wrapper
					{% if posts_exceed_limit %} blog__posts--{{ section.settings.post_layout }}-items
					{% else %} blog__posts--{{ section.settings.post_layout }}-items{% endif %}
				"
			>
				{% for i in (1..4) %}
					{% assign placeholder_index = forloop.index | modulo: 3 | plus: 1 %}

					{%- if section.settings.post_layout == 'column' -%}
						<li class="blog__post article">
							<article class="article-card">
								<div class="article-card__image-wrapper">
									<div class="article-card__image media media--landscape">
								
										{{
											'blog-apparel-'
											| append: placeholder_index
											| placeholder_svg_tag: 'placeholder-svg'
										}}
									</div>
								</div>
								<div class="article-content motion-reduce">
									<div class="article-card__info">
										<header class="article-card__header">
											<h2 class="article-card__title h4">
												{{ 'sections.featured_blog.onboarding_title' | t }}
											</h2>
										</header>
										<p class="article-card__excerpt">
											{{ 'sections.featured_blog.onboarding_content' | t }}
										</p>
									</div>
								</div>
							</article>
						</li>
					{%- else -%}
						<li class="blog__post article">
							<div
								class="article__overlay"
								style="opacity: {{ section.settings.overlay_opacity }}"
							></div>
							<article class="article-card-row">
								<div class="article-card-row__image-wrapper">
									<div class="article-card-row__image media media--landscape">
										{{
											'blog-apparel-'
											| append: placeholder_index
											| placeholder_svg_tag: 'placeholder-svg'
										}}
									</div>
								</div>
								<div class="article-card-row__content motion-reduce">
									<div class="article-card-row__info">
										<span class="article-card-row__tag subtitle">{{ 'sections.featured_blog.show_tags' | t }}</span>
										<div class="article-card-row__info-group blog-apparel-placeholder">
											<header class="article-card-row__header">
												<h2 class="article-card-row__title h4">
													{{ 'sections.featured_blog.onboarding_title' | t }}
												</h2>
											</header>
											<div class="article-card-row__meta">
													<span class="article-card-row__author line-divider line-divider_vertical"
														>by<span>Author</span></span
													>
													<span class="line-divider line-divider_vertical">{{"general.blog.date" | t }}</span>
											</div>
										</div>
									</div>
								</div>
							</article>
						</li>
					{% endif %}
				{% endfor %}
			</ul>
		{%- endif -%}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.featured-blog.name",
	"tag": "section",
	"class": "spaced-section section-featured-blog",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "inline_richtext",
			"id": "heading",
			"default": "t:sections.featured-blog.settings.heading.default",
			"label": "t:sections.featured-blog.settings.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:sections.all.heading_size.options__0.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h4",
			"label": "t:sections.all.heading_size.label"
		},
		{
			"type": "select",
			"id": "post_layout",
			"options": [
				{
					"value": "2",
					"label": "t:sections.featured-blog.settings.article_post_layout.options__2.label"
				},
				{
					"value": "3",
					"label": "t:sections.featured-blog.settings.article_post_layout.options__3.label"
				},
				{
					"value": "4",
					"label": "t:sections.featured-blog.settings.article_post_layout.options__4.label"
				},
				{
					"value": "column",
					"label": "t:sections.featured-blog.settings.article_post_layout.options__5.label"
				}
			],
			"default": "3",
			"label": "t:sections.featured-blog.settings.article_post_layout.label"
		},
		{
			"type": "blog",
			"id": "blog",
			"label": "t:sections.featured-blog.settings.blog.label"
		},
		{
			"type": "range",
			"id": "post_limit",
			"min": 1,
			"max": 10,
			"step": 1,
			"default": 3,
			"label": "t:sections.featured-blog.settings.post_limit.label"
		},
		{
			"type": "range",
			"id": "post_limit_mobile",
			"min": 1,
			"max": 10,
			"step": 1,
			"default": 3,
			"label": "t:sections.featured-blog.settings.post_limit_mobile.label"
		},
		{
			"type": "checkbox",
			"id": "show_image",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_image.label"
		},
		{
			"type": "checkbox",
			"id": "show_tags",
			"default": true,
			"label": "t:sections.main-blog.settings.show_tags.label"
		},
		{
			"type": "checkbox",
			"id": "show_date",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_date.label"
		},
		{
			"type": "checkbox",
			"id": "show_author",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_author.label"
		},
		{
			"type": "checkbox",
			"id": "show_excerpt",
			"default": false,
			"label": "t:sections.featured-blog.settings.show_excerpt.label"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"min": 0,
			"max": 1,
			"step": 0.1,
			"label": "t:sections.slideshow.settings.overlay_opacity.label",
			"default": 0.3,
			"info": "Only for collage type"
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "checkbox",
			"id": "show_view_all",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_view_all.label"
		},
		{
			"type": "checkbox",
			"id": "show_view_all_mobile",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_view_all_mobile.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.featured-blog.settings.button_label.default",
			"label": "t:sections.featured-blog.settings.button_label.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.featured-blog.presets.name"
		}
	]
}
{% endschema %}
