{{ 'section-all-brands.css' | asset_url | stylesheet_tag }}

{% style %}
	{% render 'section-margin' %}
	{% render 'section-padding' %}

	#shopify-section-{{ section.id }} {
		--per-row : {{ section.settings.per_row }}
	}
{% endstyle %}

<div class="all-brands">
	<div class="container">
		<div class="section-{{ section.id }}-padding {% if section.settings.border_top %}all-brands__border-top{% endif %} {% if section.settings.border_bottom %}all-brands__border-bottom{% endif %}">
			<h2 class="all-brands__title {{ section.settings.heading_size }}">
				{{ section.settings.heading }}
			</h2>
			{% assign vendors = shop.vendors | compact %}
			{% if vendors.size > 0 %} 
				<ul class="all-brands__main-list list-unstyled">
					{% for vendor in vendors %}
						{% liquid
							if forloop.first
								assign check_first_letter = vendor_arr[0] | upcase
							endif

							assign vendor_arr = vendor | split: ''
							assign main_first_letter = vendor_arr[0] | upcase

							if check_first_letter == main_first_letter
								continue
							endif
						%}
						<li>
							<div class="all-brands__letter">{{ main_first_letter }}</div>
							<ul class="all-brands__list list-unstyled all-brands__list-vendors">
								{% for vendor in vendors %}
									{% liquid
										assign vendor_arr = vendor | split: ''
										assign first_letter = vendor_arr[0] | upcase

										if first_letter != main_first_letter
											continue
										endif
									%}
									<li>
										{{-
											vendor
											| link_to_vendor:
												class: 'vendor-link unstyled-link link-hover-line'
										}}
									</li>
								{% endfor %}
							</ul>
						</li>
						{% assign check_first_letter = main_first_letter %}
					{% endfor %}
				</ul>
			{% else %}
				<p>{{ 'sections.vendor.empty' | t }}</p>
			{% endif %}
		</div>
	</div>
</div>
{% schema %}
{
	"name": "t:sections.all_brands.name",
	"class": "section-brans",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "range",
			"id": "per_row",
			"min": 1,
			"max": 8,
			"step": 1,
			"default": 8,
			"label": "t:sections.all_brands.settings.columns_per_row.label",
			"info": "t:sections.all_brands.settings.columns_per_row.info"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"label": "t:sections.all.heading.label",
			"default": "t:sections.all_brands.settings.heading.default"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:sections.all.heading_size.options__0.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h3",
			"label": "t:sections.all.heading_size.label"
		},
		{
			"type": "checkbox",
			"id": "border_top",
			"default": true,
			"label": "t:sections.all.border_top.label"
		},
		{
			"type": "checkbox",
			"id": "border_bottom",
			"default": false,
			"label": "t:sections.all.border_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-padding.options__6.label"
				}
			],
			"default": "s",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-margin.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				},
				{
					"value": "xl",
					"label": "t:sections.all.section-margin.options__6.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
