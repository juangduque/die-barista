            "custom_liquid": "<div class=\"coffee-scale\">\n  {% assign roast = product.metafields.coffee_attributes.roasting_level.value | default: 7 %}\n  {% assign acidity = product.metafields.coffee_attributes.acid_level.value | default: 3 %}\n  {% assign strength = product.metafields.coffee_attributes.strength_level.value | default: 8 %}\n\n\n  <div class=\"scale-row\">\n    <span class=\"label\">Röstgrad</span>\n    <div class=\"scale-container\">\n      <div class=\"scale-bar\">\n        <div class=\"scale-fill\" style=\"width: {{ roast }}0%; background-color: #1f1f1f; display: block;\"></div>\n      </div>\n    </div>\n  </div>\n  <div class=\"scale-row\">\n    <span class=\"label\">Säure</span>\n    <div class=\"scale-container\">\n      <div class=\"scale-bar\">\n        <div class=\"scale-fill\" style=\"width: {{ acidity }}0%; background-color: #1f1f1f; display: block;\"></div>\n      </div>\n    </div>\n  </div>\n  <div class=\"scale-row\">\n    <span class=\"label\">Stärke</span>\n    <div class=\"scale-container\">\n      <div class=\"scale-bar\">\n        <div class=\"scale-fill\" style=\"width: {{ strength }}0%; background-color: #1f1f1f; display: block;\"></div>\n      </div>\n    </div>\n  </div>\n\n  <style>\n    .coffee-scale {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n      margin: 20px auto;\n      background-color: #f9f9f9;\n      padding: 10px;\n      border-radius: 5px;\n    }\n    .description {\n      text-align: center;\n      margin-bottom: 20px;\n    }\n    .description h2 {\n      font-size: 16px;\n      color: #333;\n      margin-bottom: 5px;\n    }\n    .description p {\n      font-size: 14px;\n      color: #555;\n      margin: 0;\n    }\n    .scale-row {\n      display: flex;\n      align-items: center;\n      margin: 10px 0;\n      gap: 20px;\n    }\n    .label {\n      flex: 0 0 100px;\n      font-size: 14px;\n      color: #333;\n      font-weight: 500;\n    }\n    .scale-container {\n      flex: 1;\n    }\n    .scale-bar {\n      height: 6px;\n      background: #e0e0e0;\n      border-radius: 3px;\n      position: relative;\n      overflow: visible;\n    }\n    .scale-fill {\n      position: absolute;\n      left: 0;\n      top: 0;\n      height: 100%;\n      min-width: 0;\n      border-radius: 3px;\n      z-index: 1;\n    }\n  </style>\n</div>"
